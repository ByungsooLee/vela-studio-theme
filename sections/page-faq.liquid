{% comment %} FAQ Page Section {% endcomment %}

<div class="faq-page" id="faq-page-{{ section.id }}">
  <section class="faq-hero">
    <p class="about-eyebrow">{{ section.settings.hero_eyebrow }}</p>
    <h1 class="faq-title">{{ section.settings.hero_title }}</h1>
    <p class="faq-subtitle">{{ section.settings.hero_subtitle }}</p>
  </section>

  <section class="faq-body page-width">
    <div class="faq-category">
      <h2 class="faq-category__title">🚚 Shipping</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Shipping' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">🔄 Returns & Refunds</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Returns' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">📦 Products</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Products' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">💳 Payment & Security</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Payment' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-contact">
      <p class="faq-contact__text">{{ section.settings.contact_text }}</p>
      <a href="{{ section.settings.contact_url }}" class="about-cta">{{ section.settings.contact_cta }} →</a>
    </div>
  </section>
</div>

<script>
(() => {
  const faqRoot = document.getElementById('faq-page-{{ section.id }}');
  if (!faqRoot) return;

  const questions = faqRoot.querySelectorAll('.faq-question');

  questions.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      questions.forEach((questionBtn) => {
        questionBtn.setAttribute('aria-expanded', 'false');
        questionBtn.nextElementSibling.style.maxHeight = null;
        questionBtn.querySelector('.faq-icon').textContent = '+';
      });

      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling.style.maxHeight = `${btn.nextElementSibling.scrollHeight}px`;
        btn.querySelector('.faq-icon').textContent = '×';
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero 小見出し",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero タイトル",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero サブタイトル",
      "default": "Everything you need to know before you buy."
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact テキスト",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "contact_cta",
      "label": "Contact ボタンテキスト",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Standard shipping takes 7-15 business days to most countries."
        },
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            {
              "value": "Shipping",
              "label": "Shipping"
            },
            {
              "value": "Returns",
              "label": "Returns"
            },
            {
              "value": "Products",
              "label": "Products"
            },
            {
              "value": "Payment",
              "label": "Payment"
            }
          ],
          "default": "Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
