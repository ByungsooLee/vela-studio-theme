{% comment %} FAQページセクション {% endcomment %}
{{ 'section-page-faq.css' | asset_url | stylesheet_tag }}

<div class="faq-page" id="faq-page-{{ section.id }}">
  <section class="faq-hero">
    <p class="about-eyebrow">{{ section.settings.hero_eyebrow }}</p>
    <h1 class="faq-title">{{ section.settings.hero_title }}</h1>
    <p class="faq-subtitle">{{ section.settings.hero_subtitle }}</p>
  </section>

  <section class="faq-body page-width">
    <div class="faq-category">
      <h2 class="faq-category__title">🚚 配送</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Shipping' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">🔄 返品・返金</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Returns' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">📦 商品</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Products' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-category">
      <h2 class="faq-category__title">💳 お支払い・セキュリティ</h2>
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.category == 'Payment' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button class="faq-question" aria-expanded="false">
              {{ block.settings.question }}
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <p>{{ block.settings.answer | newline_to_br }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="faq-contact">
      <p class="faq-contact__text">{{ section.settings.contact_text }}</p>
      <a href="{{ section.settings.contact_url }}" class="about-cta">{{ section.settings.contact_cta }} →</a>
    </div>
  </section>
</div>

<script>
(() => {
  const faqRoot = document.getElementById('faq-page-{{ section.id }}');
  if (!faqRoot) return;

  const questions = faqRoot.querySelectorAll('.faq-question');

  questions.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      questions.forEach((questionBtn) => {
        questionBtn.setAttribute('aria-expanded', 'false');
        questionBtn.nextElementSibling.style.maxHeight = null;
        questionBtn.querySelector('.faq-icon').textContent = '+';
      });

      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling.style.maxHeight = `${btn.nextElementSibling.scrollHeight}px`;
        btn.querySelector('.faq-icon').textContent = '×';
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQページ",
  "settings": [
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero 小見出し",
      "default": "サポート"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero タイトル",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero サブタイトル",
      "default": "購入前に知っておきたい情報をまとめています。"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact テキスト",
      "default": "まだご不明点がありますか？"
    },
    {
      "type": "text",
      "id": "contact_cta",
      "label": "Contact ボタンテキスト",
      "default": "お問い合わせ"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "お問い合わせURL"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ項目",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "質問",
          "default": "配送にはどれくらいかかりますか？"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "回答",
          "default": "通常配送は多くの国で7〜15営業日かかります。"
        },
        {
          "type": "select",
          "id": "category",
          "label": "カテゴリ",
          "options": [
            {
              "value": "Shipping",
              "label": "配送"
            },
            {
              "value": "Returns",
              "label": "返品"
            },
            {
              "value": "Products",
              "label": "商品"
            },
            {
              "value": "Payment",
              "label": "お支払い"
            }
          ],
          "default": "Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQページ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "配送にはどれくらいかかりますか？",
            "answer": "通常配送は多くの国で7〜15営業日かかります。お急ぎ便（3〜7日）はチェックアウト時に選択できます。発送後、追跡番号をメールでお送りします。",
            "category": "Shipping"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "送料無料ですか？",
            "answer": "はい。すべてのご注文で、世界中どこでも通常配送が無料です。最低購入金額はありません。",
            "category": "Shipping"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "返品ポリシーを教えてください。",
            "answer": "30日間の返品ポリシーをご用意しています。商品到着後30日以内にご連絡いただければ、適切に対応いたします。",
            "category": "Returns"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "商品が破損した状態で届きました。どうすればよいですか？",
            "answer": "注文番号と破損箇所の写真を添えて support@pawlux.com までご連絡ください。交換品の発送または全額返金で対応します。",
            "category": "Returns"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "商品はペットにも安全ですか？",
            "answer": "はい。コレクション内のすべての商品は、国際的な安全基準を満たすよう慎重に選定しています。",
            "category": "Products"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "利用可能な支払い方法は？",
            "answer": "主要なクレジットカード、PayPal、Apple Pay、Google Payをご利用いただけます。",
            "category": "Payment"
          }
        }
      ]
    }
  ]
}
{% endschema %}
