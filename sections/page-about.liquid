{% comment %} About Page Section {% endcomment %}

<div class="about-page">

  <!-- HERO -->
  <section class="about-hero" style="background: {{ section.settings.hero_bg_color }};">
    <div class="about-hero__inner">
      <p class="about-eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="about-title">{{ section.settings.hero_title }}</h1>
      <p class="about-subtitle">{{ section.settings.hero_subtitle }}</p>
    </div>
  </section>

  <!-- MISSION -->
  <section class="about-mission page-width">
    <div class="about-mission__grid {% if section.settings.mission_reverse %}about-mission__grid--reverse{% endif %}">
      <div class="about-mission__content">
        <p class="about-eyebrow">{{ section.settings.mission_eyebrow }}</p>
        <h2>{{ section.settings.mission_title }}</h2>
        <div class="about-mission__body">{{ section.settings.mission_body }}</div>
      </div>
      <div class="about-mission__media">
        {%- if section.settings.mission_video != blank -%}
          {{
            section.settings.mission_video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              playsinline: true
          }}
        {%- elsif section.settings.mission_image != blank -%}
          <img
            src="{{ section.settings.mission_image | image_url: width: 1200 }}"
            alt="{{ section.settings.mission_image.alt }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </section>

  <!-- TRUST PILLARS -->
  <section class="about-pillars">
    <div class="page-width">
      <p class="about-eyebrow" style="text-align:center">
        {{ section.settings.pillars_eyebrow }}
      </p>
      <h2 style="text-align:center;margin-bottom:56px">
        {{ section.settings.pillars_title }}
      </h2>
      <div class="about-pillars__grid">
        {% for block in section.blocks %}
          {% if block.type == 'pillar' %}
          <div class="about-pillar" {{ block.shopify_attributes }}>
            <div class="about-pillar__icon">{{ block.settings.icon }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- PROMISE -->
  <section class="about-promise" style="background: {{ section.settings.promise_bg_color }};">
    <div class="about-promise__inner page-width">
      <p class="about-eyebrow">{{ section.settings.promise_eyebrow }}</p>
      <blockquote class="about-promise__quote">
        {{ section.settings.promise_quote }}
      </blockquote>
      <p class="about-promise__sub">{{ section.settings.promise_sub }}</p>
      <a href="{{ section.settings.promise_cta_url }}" class="about-cta">
        {{ section.settings.promise_cta_text }} →
      </a>
    </div>
  </section>

</div>

