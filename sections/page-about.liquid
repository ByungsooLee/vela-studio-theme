{% comment %} Aboutページセクション {% endcomment %}
{{ 'section-page-about.css' | asset_url | stylesheet_tag }}

<div class="about-page">

  <!-- ヒーロー -->
  <section class="about-hero" style="background: {{ section.settings.hero_bg_color }};">
    <div class="about-hero__inner">
      <p class="about-eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="about-title">{{ section.settings.hero_title }}</h1>
      <p class="about-subtitle">{{ section.settings.hero_subtitle }}</p>
    </div>
  </section>

  <!-- ミッション -->
  <section class="about-mission page-width">
    <div class="about-mission__grid {% if section.settings.mission_reverse %}about-mission__grid--reverse{% endif %}">
      <div class="about-mission__content">
        <p class="about-eyebrow">{{ section.settings.mission_eyebrow }}</p>
        <h2>{{ section.settings.mission_title }}</h2>
        <div class="about-mission__body">{{ section.settings.mission_body }}</div>
      </div>
      <div class="about-mission__media">
        {%- if section.settings.mission_video != blank -%}
          {{
            section.settings.mission_video
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              playsinline: true
          }}
        {%- elsif section.settings.mission_image != blank -%}
          <img
            src="{{ section.settings.mission_image | image_url: width: 1200 }}"
            alt="{{ section.settings.mission_image.alt }}"
            width="{{ section.settings.mission_image.width }}"
            height="{{ section.settings.mission_image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </section>

  <!-- 信頼の柱 -->
  <section class="about-pillars">
    <div class="page-width">
      <p class="about-eyebrow" style="text-align:center">
        {{ section.settings.pillars_eyebrow }}
      </p>
      <h2 style="text-align:center;margin-bottom:56px">
        {{ section.settings.pillars_title }}
      </h2>
      <div class="about-pillars__grid">
        {% for block in section.blocks %}
          {% if block.type == 'pillar' %}
          <div class="about-pillar" {{ block.shopify_attributes }}>
            <div class="about-pillar__icon">{{ block.settings.icon }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- プロミス -->
  <section class="about-promise" style="background: {{ section.settings.promise_bg_color }};">
    <div class="about-promise__inner page-width">
      <p class="about-eyebrow">{{ section.settings.promise_eyebrow }}</p>
      <blockquote class="about-promise__quote">
        {{ section.settings.promise_quote }}
      </blockquote>
      <p class="about-promise__sub">{{ section.settings.promise_sub }}</p>
      <a href="{{ section.settings.promise_cta_url }}" class="about-cta">
        {{ section.settings.promise_cta_text }} →
      </a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Aboutページ",
  "settings": [
    {
      "type": "header",
      "content": "🎬 Hero セクション"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "背景色",
      "default": "#1A1814"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "小見出し",
      "default": "私たちのストーリー"
    },
    {
      "type": "textarea",
      "id": "hero_title",
      "label": "メイン見出し",
      "default": "家族であるペットのために、私たちは存在します。"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "サブテキスト",
      "default": "PAWLUX は、ただ一つの想いから生まれました。あなたと同じ品質の暮らしを、ペットにも。"
    },
    {
      "type": "header",
      "content": "📸 Mission セクション"
    },
    {
      "type": "text",
      "id": "mission_eyebrow",
      "label": "小見出し",
      "default": "私たちの使命"
    },
    {
      "type": "textarea",
      "id": "mission_title",
      "label": "見出し",
      "default": "上質なアイテムで、ペットにもっと幸せを。"
    },
    {
      "type": "richtext",
      "id": "mission_body",
      "label": "本文",
      "default": "<p>私たちは常に一つの基準で商品を選びます。「自分のペットにも本当に使いたいか？」その答えが即座に「はい」でなければ採用しません。</p>"
    },
    {
      "type": "video",
      "id": "mission_video",
      "label": "動画（優先表示）",
      "info": "動画をアップすると画像より優先されます"
    },
    {
      "type": "image_picker",
      "id": "mission_image",
      "label": "画像（動画がない場合）"
    },
    {
      "type": "checkbox",
      "id": "mission_reverse",
      "label": "画像を左側に表示",
      "default": false
    },
    {
      "type": "header",
      "content": "🏆 Trust Pillars セクション"
    },
    {
      "type": "text",
      "id": "pillars_eyebrow",
      "label": "小見出し",
      "default": "PAWLUXが選ばれる理由"
    },
    {
      "type": "textarea",
      "id": "pillars_title",
      "label": "見出し",
      "default": "すべての飼い主にふさわしい基準"
    },
    {
      "type": "header",
      "content": "💬 Promise セクション"
    },
    {
      "type": "color",
      "id": "promise_bg_color",
      "label": "背景色",
      "default": "#1A1814"
    },
    {
      "type": "text",
      "id": "promise_eyebrow",
      "label": "小見出し",
      "default": "私たちの約束"
    },
    {
      "type": "textarea",
      "id": "promise_quote",
      "label": "引用文",
      "default": "販売するすべての商品は、自分たちのペットにも選べるものだけ。"
    },
    {
      "type": "textarea",
      "id": "promise_sub",
      "label": "サブテキスト",
      "default": "それがPAWLUXの基準です。心から納得できないものは出荷しません。"
    },
    {
      "type": "text",
      "id": "promise_cta_text",
      "label": "ボタンテキスト",
      "default": "コレクションを見る"
    },
    {
      "type": "url",
      "id": "promise_cta_url",
      "label": "ボタンリンク",
      "default": "/collections/all"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "信頼の柱",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン（絵文字）",
          "default": "🔍"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "丁寧にキュレーション"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "説明文",
          "default": "世界中の信頼できるサプライヤーから、ひとつずつ厳選しています。"
        }
      ]
    }
  ],
  "presets": [
    {
