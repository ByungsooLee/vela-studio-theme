<section id="pawly-hero-{{ section.id }}" class="pawly-hero">
  <div class="pawly-hero__paw pawly-hero__paw--one" aria-hidden="true">
    <svg viewBox="0 0 64 64" role="presentation">
      <circle cx="32" cy="37" r="13"></circle>
      <circle cx="18" cy="21" r="6"></circle>
      <circle cx="30" cy="14" r="6"></circle>
      <circle cx="44" cy="14" r="6"></circle>
      <circle cx="52" cy="24" r="6"></circle>
    </svg>
  </div>
  <div class="pawly-hero__paw pawly-hero__paw--two" aria-hidden="true">
    <svg viewBox="0 0 64 64" role="presentation">
      <circle cx="32" cy="37" r="13"></circle>
      <circle cx="18" cy="21" r="6"></circle>
      <circle cx="30" cy="14" r="6"></circle>
      <circle cx="44" cy="14" r="6"></circle>
      <circle cx="52" cy="24" r="6"></circle>
    </svg>
  </div>
  <div class="pawly-hero__paw pawly-hero__paw--three" aria-hidden="true">
    <svg viewBox="0 0 64 64" role="presentation">
      <circle cx="32" cy="37" r="13"></circle>
      <circle cx="18" cy="21" r="6"></circle>
      <circle cx="30" cy="14" r="6"></circle>
      <circle cx="44" cy="14" r="6"></circle>
      <circle cx="52" cy="24" r="6"></circle>
    </svg>
  </div>

  <div class="pawly-container pawly-hero__inner">
    <div class="pawly-hero__image-wrap pawly-fade-in">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            class: 'pawly-hero__image',
            loading: 'lazy',
            widths: '500, 700, 900, 1100, 1400',
            sizes: '(min-width: 990px) 45vw, 100vw',
            alt: section.settings.heading
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'pawly-hero__image pawly-hero__image--placeholder' }}
      {% endif %}
    </div>

    <div class="pawly-hero__content">
      <h1 class="pawly-hero__heading pawly-fade-in">{{ section.settings.heading }}</h1>
      <p class="pawly-hero__subheading pawly-fade-in">{{ section.settings.subheading }}</p>

      <div class="pawly-hero__actions pawly-fade-in">
        {% if section.settings.cta_label_1 != blank %}
          <a
            class="pawly-btn-primary"
            href="{% if section.settings.cta_url_1 != blank %}{{ section.settings.cta_url_1 }}{% else %}#{% endif %}"
          >
            {{ section.settings.cta_label_1 }}
          </a>
        {% endif %}
        {% if section.settings.cta_label_2 != blank %}
          <a
            class="pawly-btn-outline"
            href="{% if section.settings.cta_url_2 != blank %}{{ section.settings.cta_url_2 }}{% else %}#{% endif %}"
          >
            {{ section.settings.cta_label_2 }}
          </a>
        {% endif %}
      </div>

      <p class="pawly-hero__trust pawly-fade-in">⭐ 3,000件以上のレビュー</p>
    </div>
  </div>
</section>

<style>
  #pawly-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--pawly-bg-soft);
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 107, 107, 0.14) 1px, transparent 0);
    background-size: 26px 26px;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 48px;
    align-items: center;
    width: 100%;
    padding-top: 60px;
    padding-bottom: 60px;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__content {
    order: 1;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__image-wrap {
    order: 2;
    border-radius: 40% 60% 60% 40% / 60% 40% 40% 60%;
    overflow: hidden;
    box-shadow: var(--pawly-shadow-lg);
    min-height: 320px;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__image--placeholder {
    background: var(--pawly-bg);
    color: var(--pawly-text-sub);
  }

  #pawly-hero-{{ section.id }} .pawly-hero__heading {
    margin: 0 0 18px;
    font-family: var(--pawly-font-display);
    font-size: 56px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--pawly-text);
  }

  #pawly-hero-{{ section.id }} .pawly-hero__subheading {
    margin: 0;
    font-size: 18px;
    line-height: 1.8;
    color: var(--pawly-text-sub);
  }

  #pawly-hero-{{ section.id }} .pawly-hero__actions {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__trust {
    margin: 20px 0 0;
    font-size: 13px;
    color: var(--pawly-text-sub);
  }

  #pawly-hero-{{ section.id }} .pawly-hero__paw {
    position: absolute;
    z-index: 1;
    opacity: 0.15;
    color: var(--pawly-primary);
    animation-name: pawlyFloat;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__paw svg {
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__paw--one {
    width: 40px;
    height: 40px;
    top: 16%;
    left: 10%;
    animation-duration: 3s;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__paw--two {
    width: 52px;
    height: 52px;
    right: 12%;
    top: 18%;
    animation-duration: 4s;
  }

  #pawly-hero-{{ section.id }} .pawly-hero__paw--three {
    width: 60px;
    height: 60px;
    right: 6%;
    bottom: 16%;
    animation-duration: 5s;
  }

  @keyframes pawlyFloat {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(10deg);
    }
  }

  @media screen and (max-width: 989px) {
    #pawly-hero-{{ section.id }} {
      min-height: 75vh;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__inner {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-top: 42px;
      padding-bottom: 42px;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__image-wrap {
      order: 1;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__content {
      order: 2;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__heading {
      font-size: 34px;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__subheading {
      font-size: 15px;
      line-height: 1.7;
    }

    #pawly-hero-{{ section.id }} .pawly-hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    #pawly-hero-{{ section.id }} .pawly-btn-primary,
    #pawly-hero-{{ section.id }} .pawly-btn-outline {
      text-align: center;
      width: 100%;
    }
  }
</style>

<script>
  (() => {
    const sectionEl = document.getElementById('pawly-hero-{{ section.id }}');
    if (!sectionEl) return;

    const targets = sectionEl.querySelectorAll('.pawly-fade-in');
    if (!targets.length) return;

    if (!('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, instance) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            instance.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.2,
        rootMargin: '0px 0px -10% 0px',
      }
    );

    targets.forEach((target, index) => {
      target.style.transitionDelay = `${index * 0.1}s`;
      observer.observe(target);
    });
  })();
</script>

{% schema %}
{
  "name": "PAWLY Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "一緒に、どこへでも。"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "PAWLYのキャリーバッグで、愛するペットとのお出かけをもっと快適に。"
    },
    {
      "type": "text",
      "id": "cta_label_1",
      "label": "ボタン1 ラベル",
      "default": "商品を見る"
    },
    {
      "type": "url",
      "id": "cta_url_1",
      "label": "ボタン1 リンク"
    },
    {
      "type": "text",
      "id": "cta_label_2",
      "label": "ボタン2 ラベル",
      "default": "PAWLYについて"
    },
    {
      "type": "url",
      "id": "cta_url_2",
      "label": "ボタン2 リンク"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "ヒーロー画像"
    }
  ],
  "presets": [
    {
      "name": "PAWLY Hero"
    }
  ]
}
{% endschema %}
