{{ 'section-homepage-blocks.css' | asset_url | stylesheet_tag }}
<section id="homepage-blocks-{{ section.id }}" class="homepage-blocks">
  <section class="brand-values">
    <div class="brand-values__inner page-width">
      {% liquid
        assign brand_value_blocks = section.blocks | where: 'type', 'brand_value'
      %}

      {% if brand_value_blocks.size > 0 %}
        {% for block in brand_value_blocks %}
          <div class="brand-values__item" {{ block.shopify_attributes }}>
            <div class="brand-values__media">
              {% if block.settings.block_video != blank %}
                {{
                  block.settings.block_video
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    playsinline: true,
                    controls: false,
                    class: 'brand-values__video'
                }}
              {% elsif block.settings.block_image != blank %}
                <img
                  src="{{ block.settings.block_image | image_url: width: 800 }}"
                  alt="{{ block.settings.block_image.alt }}"
                  loading="lazy"
                  width="{{ block.settings.block_image.width }}"
                  height="{{ block.settings.block_image.height }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <h3>{{ block.settings.block_title }}</h3>
            <p>{{ block.settings.block_text }}</p>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          {% liquid
            assign image_key = 'value_img_' | append: i
            assign video_key = 'value_video_' | append: i
            assign title_key = 'value_title_' | append: i
            assign text_key = 'value_text_' | append: i
            assign block_image = section.settings[image_key]
            assign block_video = section.settings[video_key]
            assign block_title = section.settings[title_key]
            assign block_text = section.settings[text_key]
          %}
          <div class="brand-values__item">
            <div class="brand-values__media">
              {% if block_video != blank %}
                {{
                  block_video
                  | video_tag:
                    autoplay: true,
                    loop: true,
                    muted: true,
                    playsinline: true,
                    controls: false,
                    class: 'brand-values__video'
                }}
              {% elsif block_image != blank %}
                <img
                  src="{{ block_image | image_url: width: 800 }}"
                  alt="{{ block_image.alt }}"
                  loading="lazy"
                  width="{{ block_image.width }}"
                  height="{{ block_image.height }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <h3>{{ block_title }}</h3>
            <p>{{ block_text }}</p>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </section>

  <section class="link-banners">
    {% for i in (1..3) %}
      {% liquid
        assign image_key = 'banner_img_' | append: i
        assign label_key = 'banner_label_' | append: i
        assign link_key = 'banner_link_' | append: i
        assign banner_image = section.settings[image_key]
        assign banner_label = section.settings[label_key]
        assign banner_link = section.settings[link_key]

        if banner_link == blank
          case i
            when 1
              assign banner_link = '/pages/about'
            when 2
              assign banner_link = '/collections/all'
            when 3
              assign banner_link = '/pages/faq'
          endcase
        endif
      %}
      <a href="{{ banner_link }}" class="link-banner">
        <div class="link-banner__media">
          {% if banner_image != blank %}
            {{
              banner_image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                widths: '500, 900, 1200, 1400',
                sizes: '(min-width: 750px) 33vw, 100vw',
                alt: banner_label
            }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <div class="link-banner__overlay"></div>
        </div>
        <span class="link-banner__label">{{ banner_label }}</span>
      </a>
    {% endfor %}
  </section>

  <section class="featured-products page-width">
    <div class="featured-products__header">
      <h2 class="featured-products__title">{{ section.settings.products_heading }}</h2>
    </div>
    {% liquid
      assign featured_all_collection = collections['all']
      assign has_manual_featured = false
      if section.settings.featured_product_1 != blank or section.settings.featured_product_2 != blank or section.settings.featured_product_3 != blank
        assign has_manual_featured = true
      endif
    %}
    <div class="featured-products__grid">
      {% if has_manual_featured %}
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'featured_product_' | append: i
            assign card_product = section.settings[product_key]
          %}
          {% if card_product != blank %}
            <article class="card-wrapper">
              <a href="{{ card_product.url }}" class="card">
                <div class="card__media">
                  {% if card_product.featured_image != blank %}
                    {{
                      card_product.featured_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        widths: '300, 600, 900, 1200',
                        sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 100vw',
                        alt: card_product.title
                    }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                <h3 class="card__heading">{{ card_product.title }}</h3>
              </a>
              <p class="price__regular">{{ card_product.price | money }}</p>
            </article>
          {% endif %}
        {% endfor %}
      {% elsif featured_all_collection != blank %}
        {% for card_product in featured_all_collection.products limit: 3 %}
          <article class="card-wrapper">
            <a href="{{ card_product.url }}" class="card">
              <div class="card__media">
                {% if card_product.featured_image != blank %}
                  {{
                    card_product.featured_image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 600, 900, 1200',
                      sizes: '(min-width: 990px) 30vw, (min-width: 750px) 45vw, 100vw',
                      alt: card_product.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <h3 class="card__heading">{{ card_product.title }}</h3>
            </a>
            <p class="price__regular">{{ card_product.price | money }}</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </section>

  <section class="insta-feed page-width">
    <p class="insta-feed__handle">{{ section.settings.insta_handle }}</p>
    <div class="insta-feed__grid">
      {% for i in (1..6) %}
        {% liquid
          assign insta_key = 'insta_img_' | append: i
          assign insta_image = section.settings[insta_key]
        %}
        <div class="insta-feed__item">
          {% if insta_image != blank %}
            {{
              insta_image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                widths: '200, 400, 600, 800',
                sizes: '(min-width: 990px) 16vw, (min-width: 750px) 33vw, 33vw',
                alt: section.settings.insta_handle
            }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <div class="insta-feed__hover" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <path d="M12 21s-6.7-4.35-9.34-8.26C.83 10.01 1.56 6.3 4.55 4.5c2.02-1.22 4.66-.8 6.45 1.02 1.79-1.82 4.43-2.24 6.45-1.02 2.99 1.8 3.72 5.51 1.89 8.24C18.7 16.65 12 21 12 21z"></path>
            </svg>
          </div>
        </div>
      {% endfor %}
    </div>
  </section>
</section>

