{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-trust">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="perfume-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    <h2 class="perfume-heading">{{ section.settings.heading }}</h2>

    <div class="perfume-trust__grid" role="list">
      {%- for block in section.blocks -%}
        <article class="perfume-trust__item" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.type == 'review' -%}
            <p class="perfume-trust__quote">“{{ block.settings.quote | escape }}”</p>
            {%- if block.settings.meta != blank -%}
              <p class="perfume-trust__meta">{{ block.settings.meta | escape }}</p>
            {%- endif -%}
          {%- else -%}
            <p class="perfume-trust__meta">{{ block.settings.title | escape }}</p>
            <p class="perfume-copy">{{ block.settings.body | escape }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Trust Notes",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Review & Trust"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "香りの印象と、安心できる理由。"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "レビュー",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "レビュー文",
          "default": "甘さが重すぎず、最後にウッディが残る感じが心地よいです。"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "補足",
          "default": "30代 / 会社員"
        }
      ]
    },
    {
      "type": "assurance",
      "name": "安心要素",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "ギフト対応"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "本文",
          "default": "ラッピングとメッセージカードに対応しています。"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Trust Notes",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "纏った瞬間より、少し時間が経った時の香りが特に好きです。",
            "meta": "40代 / 女性"
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "初めてでも選びやすく、香りの説明がわかりやすかったです。",
            "meta": "20代 / 男性"
          }
        },
        {
          "type": "assurance",
          "settings": {
            "title": "配送目安",
            "body": "通常2〜5営業日で発送。追跡番号付きでお届け。"
          }
        },
        {
          "type": "assurance",
          "settings": {
            "title": "サポート",
            "body": "香り選びのご相談をチャットで受け付けています。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
