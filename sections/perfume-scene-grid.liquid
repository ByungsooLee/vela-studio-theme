{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-section--surface perfume-scene">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="perfume-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    <h2 class="perfume-heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.lead != blank -%}
      <p class="perfume-copy">{{ section.settings.lead }}</p>
    {%- endif -%}

    <div class="perfume-scene__grid" role="list">
      {%- for block in section.blocks -%}
        <a class="perfume-scene__card" href="{{ block.settings.link | default: '#' }}" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                widths: '360, 550, 800, 1200',
                sizes: '(min-width: 990px) 24vw, 50vw',
                loading: 'lazy'
            }}
          {%- else -%}
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="perfume-scene__card-content">
            <h3>{{ block.settings.title }}</h3>
            {%- if block.settings.desc != blank -%}
              <p>{{ block.settings.desc }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Scene Grid",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "By Scene"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "シーンで選ぶ香り。"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "説明",
      "default": "纏う場面を想像しながら、似合う一本を探せます。"
    }
  ],
  "blocks": [
    {
      "type": "scene",
      "name": "シーンカード",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "仕事の日に"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "説明",
          "default": "清潔感と落ち着きを両立するノート。"
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Scene Grid",
      "blocks": [
        {
          "type": "scene",
          "settings": {
            "title": "仕事の日に",
            "desc": "清潔感と落ち着きを両立するノート。"
          }
        },
        {
          "type": "scene",
          "settings": {
            "title": "夜の外出に",
            "desc": "印象を残す深みのある香り。"
          }
        },
        {
          "type": "scene",
          "settings": {
            "title": "余裕をまといたい日に",
            "desc": "静かな存在感を引き出す調香。"
          }
        },
        {
          "type": "scene",
          "settings": {
            "title": "贈り物として",
            "desc": "ギフト人気の高い香りを中心に。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
