{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-how-v2">
  <div class="page-width">
    {%- assign benefits_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign benefits_heading = section.settings.heading | strip -%}
    {%- assign benefits_lead = section.settings.lead | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- if benefits_eyebrow == blank -%}
      {%- assign benefits_eyebrow = 'Why It Works' -%}
    {%- endif -%}
    {%- if benefits_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign benefits_heading = '短く、分かりやすく、実用的に。' -%}
      {%- else -%}
        {%- assign benefits_heading = 'Simple, elegant, functional.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if benefits_lead == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign benefits_lead = '一目で判断できる共通メリット。' -%}
      {%- else -%}
        {%- assign benefits_lead = 'Understand the value at a glance.' -%}
      {%- endif -%}
    {%- endif -%}

    <header class="perfume-how-v2__head">
      <p class="perfume-eyebrow">{{ benefits_eyebrow | escape }}</p>
      <h2 class="perfume-heading perfume-how-v2__heading">{{ benefits_heading }}</h2>
      <p class="perfume-copy perfume-how-v2__lead">{{ benefits_lead }}</p>
    </header>

    <div class="perfume-how-v2__steps" role="list">
      {%- for block in section.blocks -%}
        {%- assign benefit_index = block.settings.index_text | strip -%}
        {%- assign benefit_title = block.settings.title | strip -%}
        {%- assign benefit_body = block.settings.body | strip -%}
        {%- if benefit_title == blank -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign benefit_index = 'Benefit 01' -%}
                {%- assign benefit_title = '置きやすい' -%}
                {%- assign benefit_body = '狭い間取りでも圧迫感が出にくいサイズ感。' -%}
              {%- else -%}
                {%- assign benefit_index = 'Benefit 01' -%}
                {%- assign benefit_title = 'Easy to place' -%}
                {%- assign benefit_body = 'Works in narrow rooms and compact corners.' -%}
              {%- endif -%}
            {%- when 2 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign benefit_index = 'Benefit 02' -%}
                {%- assign benefit_title = '手入れしやすい' -%}
                {%- assign benefit_body = '毎日使っても負担が少ない素材と仕様。' -%}
              {%- else -%}
                {%- assign benefit_index = 'Benefit 02' -%}
                {%- assign benefit_title = 'Easy to maintain' -%}
                {%- assign benefit_body = 'Practical materials and low-care upkeep.' -%}
              {%- endif -%}
            {%- when 3 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign benefit_index = 'Benefit 03' -%}
                {%- assign benefit_title = '長く使いやすい' -%}
                {%- assign benefit_body = '繰り返しの使用に耐える基本性能。' -%}
              {%- else -%}
                {%- assign benefit_index = 'Benefit 03' -%}
                {%- assign benefit_title = 'Easy to keep' -%}
                {%- assign benefit_body = 'Durable enough for everyday repetition.' -%}
              {%- endif -%}
            {%- when 4 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign benefit_index = 'Benefit 04' -%}
                {%- assign benefit_title = '選びやすい' -%}
                {%- assign benefit_body = '仕様と価格の情報を簡潔に整理。' -%}
              {%- else -%}
                {%- assign benefit_index = 'Benefit 04' -%}
                {%- assign benefit_title = 'Easy to choose' -%}
                {%- assign benefit_body = 'Clear specs and honest pricing.' -%}
              {%- endif -%}
          {%- endcase -%}
        {%- endif -%}
        <article class="perfume-how-v2__step" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="perfume-how-v2__step-media">
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  class: 'perfume-how-v2__step-image',
                  widths: '480, 700, 960, 1400',
                  sizes: '(min-width: 990px) 32vw, 100vw',
                  loading: 'lazy'
              }}
            </div>
          {%- endif -%}
          <div class="perfume-how-v2__step-content">
            <p class="perfume-how-v2__step-index">{{ benefit_index | escape }}</p>
            <h3 class="perfume-how-v2__step-title">{{ benefit_title }}</h3>
            {%- if benefit_body != blank -%}
              <p class="perfume-copy">{{ benefit_body }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume How it Works",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Why It Works"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Simple, elegant, functional."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "リード文",
      "default": "Understand the value at a glance."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "ステップ",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "index_text",
          "label": "ステップ番号",
          "default": "Benefit 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "Easy to place"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "本文",
          "default": "Everyday ease."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume How it Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "index_text": "Benefit 01",
            "title": "Easy to place"
          }
        },
        {
          "type": "step",
          "settings": {
            "index_text": "Benefit 02",
            "title": "Easy to maintain"
          }
        },
        {
          "type": "step",
          "settings": {
            "index_text": "Benefit 03",
            "title": "Easy to keep"
          }
        }
      ]
    }
  ]
}
{% endschema %}
