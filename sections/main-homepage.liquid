<section id="main-homepage-{{ section.id }}" class="hero-full">
  <div class="hero-full__media">
    {% if section.settings.hero_video != blank %}
      {{
        section.settings.hero_video
        | video_tag:
          autoplay: true,
          muted: true,
          loop: true,
          controls: false,
          playsinline: true,
          image_size: '2000x',
          class: 'hero-full__video'
      }}
    {% elsif section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag:
          class: 'hero-full__image',
          alt: section.settings.hero_image.alt | default: 'hero',
          loading: 'eager',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-full__image hero-full__image--placeholder' }}
    {% endif %}

    <div class="hero-full__overlay"></div>
  </div>

  <div class="hero-full__content">
    <p class="hero-full__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="hero-full__title">
      {{ section.settings.title_line_1 }}<br>
      <em>{{ section.settings.title_emphasis }}</em>
    </h1>
    <a
      href="{% if section.settings.cta_url != blank %}{{ section.settings.cta_url }}{% else %}/collections/all{% endif %}"
      class="hero-full__cta"
    >
      {{ section.settings.cta_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "PAWLUX Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero video (MP4)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Premium Pet Lifestyle"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title first line",
      "default": "Every adventure,"
    },
    {
      "type": "text",
      "id": "title_emphasis",
      "label": "Title emphasis",
      "default": "together."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "PAWLUX Hero"
    }
  ]
}
{% endschema %}
