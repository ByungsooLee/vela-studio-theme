<section class="ds-home">
  {%- assign hero_image = section.settings.hero_image -%}
  {%- assign category_collection = section.settings.category_collection -%}
  {%- if category_collection == blank -%}
    {%- assign category_collection = collections['all'] -%}
  {%- endif -%}

  <div class="ds-home__hero-image-wrap" data-ds-hero>
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'ds-home__hero-image',
          widths: '640, 960, 1280, 1680, 2048, 2400',
          sizes: '100vw',
          loading: 'eager',
          alt: section.settings.hero_headline
      }}
    {%- else -%}
      <img
        src="{{ 'hero-home-sale.png' | asset_url }}"
        alt="{{ section.settings.hero_headline | escape }}"
        width="2400"
        height="1400"
        loading="eager"
        class="ds-home__hero-image"
      >
    {%- endif -%}
  </div>

  <div class="ds-home__hero-content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="ds-home__eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
    {%- endif -%}
    <h1 class="ds-home__headline">{{ section.settings.hero_headline }}</h1>
    {%- if section.settings.hero_support_copy != blank -%}
      <p class="ds-home__copy">{{ section.settings.hero_support_copy | escape }}</p>
    {%- endif -%}
    {%- liquid
      assign secondary_cta_href = section.settings.secondary_cta_link
      if section.settings.secondary_cta_blog != blank
        assign secondary_cta_href = section.settings.secondary_cta_blog.url
      endif
    -%}
    <div class="ds-home__hero-actions">
      <a class="ds-home__cta ds-home__cta--primary" href="{{ section.settings.primary_cta_link | default: routes.all_products_collection_url }}">
        {{ section.settings.primary_cta_label | escape }}
      </a>
      {%- if section.settings.secondary_cta_label != blank and secondary_cta_href != blank -%}
        <a class="ds-home__cta ds-home__cta--secondary" href="{{ secondary_cta_href }}">
          {{ section.settings.secondary_cta_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <section class="ds-home__brand-promise">
    <div class="ds-home__brand-promise-inner">
      <h2 class="ds-home__brand-promise-headline">{{ section.settings.promise_headline }}</h2>
      <p class="ds-home__brand-promise-body">{{ section.settings.promise_body | escape }}</p>
    </div>
  </section>

  <section class="ds-home__categories">
    <div class="ds-home__category-track">
      {%- if category_collection != blank and category_collection.products_count > 0 -%}
        {%- for item in category_collection.products limit: 12 -%}
          <a class="ds-home__category-card ds-home__product-card" href="{{ item.url }}">
            <div class="ds-home__category-image-wrap">
              {%- if item.featured_image != blank -%}
                {{
                  item.featured_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'ds-home__category-image',
                    widths: '240, 360, 540, 720, 900',
                    sizes: '(min-width: 990px) 220px, 56vw',
                    loading: 'lazy',
                    alt: item.title
                }}
              {%- endif -%}
            </div>
            <span class="ds-home__category-label">{{ item.title | escape }}</span>
            <span class="ds-home__product-price">{{ item.price | money }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        <p class="ds-home__empty">選択されたコレクションに商品がありません。</p>
      {%- endif -%}
    </div>
  </section>

  <section class="ds-home__trust">
    <div class="ds-home__trust-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust' -%}
          <article class="ds-home__trust-item" {{ block.shopify_attributes }}>
            <div class="ds-home__trust-icon">{{ block.settings.icon_svg }}</div>
            <h3 class="ds-home__trust-headline">{{ block.settings.headline | escape }}</h3>
            <p class="ds-home__trust-subtext">{{ block.settings.subtext | escape }}</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
</section>

{% schema %}
{
  "name": "DS ホーム",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "ヒーロー画像" },
    { "type": "collection", "id": "category_collection", "label": "代替コレクション" },
    { "type": "text", "id": "hero_eyebrow", "label": "ヒーロー上部テキスト", "default": "Lifestyle essentials" },
    { "type": "inline_richtext", "id": "hero_headline", "label": "ヒーロー見出し", "default": "Choose small. Live better." },
    { "type": "textarea", "id": "hero_support_copy", "label": "ヒーロー補足文", "default": "Curated home upgrades with thoughtful design and practical comfort." },
    { "type": "text", "id": "primary_cta_label", "label": "メインCTAラベル", "default": "今すぐ購入" },
    { "type": "url", "id": "primary_cta_link", "label": "メインCTAリンク" },
    { "type": "text", "id": "secondary_cta_label", "label": "サブCTAラベル", "default": "コレクションを見る" },
    { "type": "blog", "id": "secondary_cta_blog", "label": "サブCTAブログ" },
    { "type": "url", "id": "secondary_cta_link", "label": "サブCTAリンク" },
    { "type": "inline_richtext", "id": "promise_headline", "label": "ブランドプロミス見出し", "default": "Designed for calmer, better everyday rituals." },
    { "type": "textarea", "id": "promise_body", "label": "ブランドプロミス本文", "default": "We curate products that feel elevated and practical at once. Every item is selected to improve comfort, flow, and long-term satisfaction in real homes." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "カテゴリカード",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "label", "label": "ラベル", "default": "リビング" },
        { "type": "collection", "id": "collection", "label": "コレクション" },
        { "type": "image_picker", "id": "image", "label": "画像" }
      ]
    },
    {
      "type": "trust",
      "name": "信頼項目",
      "limit": 4,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "インラインSVG", "default": "<svg viewBox='0 0 24 24'><path fill='currentColor' d='M12 2 3 6v6c0 5 3.8 9.7 9 11 5.2-1.3 9-6 9-11V6l-9-4Zm0 2.2 7 3.1V12c0 4-2.9 7.9-7 9-4.1-1.1-7-5-7-9V7.3l7-3.1Z'/></svg>" },
        { "type": "text", "id": "headline", "label": "見出し", "default": "丁寧にセレクト" },
        { "type": "text", "id": "subtext", "label": "サブテキスト", "default": "実用性と美しさを両立" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DS ホーム",
      "blocks": [
        { "type": "category", "settings": { "label": "キッチン" } },
        { "type": "category", "settings": { "label": "バス" } },
        { "type": "category", "settings": { "label": "デスク" } },
        { "type": "trust", "settings": { "headline": "厳選品質", "subtext": "毎日使えるものだけを選定" } },
        { "type": "trust", "settings": { "headline": "迅速発送", "subtext": "日本国内へスピード配送" } },
        { "type": "trust", "settings": { "headline": "安全な決済", "subtext": "信頼できる支払い方法" } },
        { "type": "trust", "settings": { "headline": "手厚いサポート", "subtext": "購入後も丁寧に対応" } }
      ]
    }
  ]
}
{% endschema %}
