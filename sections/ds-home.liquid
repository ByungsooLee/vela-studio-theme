<section class="ds-home">
  {%- assign hero_image = section.settings.hero_image -%}
  {%- assign category_collection = section.settings.category_collection -%}
  {%- if category_collection == blank -%}
    {%- assign category_collection = collections['all'] -%}
  {%- endif -%}

  <div class="ds-home__hero-image-wrap" data-ds-hero>
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'ds-home__hero-image',
          widths: '640, 960, 1280, 1680, 2048, 2400',
          sizes: '100vw',
          loading: 'eager',
          alt: section.settings.hero_headline
      }}
    {%- elsif category_collection.products.size > 0 and category_collection.products.first.featured_image != blank -%}
      {{
        category_collection.products.first.featured_image
        | image_url: width: 2400
        | image_tag:
          class: 'ds-home__hero-image',
          widths: '640, 960, 1280, 1680, 2048, 2400',
          sizes: '100vw',
          loading: 'eager',
          alt: section.settings.hero_headline
      }}
    {%- endif -%}
  </div>

  <div class="ds-home__hero-content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="ds-home__eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
    {%- endif -%}
    <h1 class="ds-home__headline">{{ section.settings.hero_headline }}</h1>
    {%- if section.settings.hero_support_copy != blank -%}
      <p class="ds-home__copy">{{ section.settings.hero_support_copy | escape }}</p>
    {%- endif -%}
    <div class="ds-home__hero-actions">
      <a class="ds-home__cta ds-home__cta--primary" href="{{ section.settings.primary_cta_link | default: routes.all_products_collection_url }}">
        {{ section.settings.primary_cta_label | escape }}
      </a>
      {%- if section.settings.secondary_cta_label != blank and section.settings.secondary_cta_link != blank -%}
        <a class="ds-home__cta ds-home__cta--secondary" href="{{ section.settings.secondary_cta_link }}">
          {{ section.settings.secondary_cta_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <section class="ds-home__brand-promise">
    <div class="ds-home__brand-promise-inner">
      <h2 class="ds-home__brand-promise-headline">{{ section.settings.promise_headline }}</h2>
      <p class="ds-home__brand-promise-body">{{ section.settings.promise_body | escape }}</p>
    </div>
  </section>

  <section class="ds-home__categories">
    <div class="ds-home__category-track">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- assign card_image = block.settings.image -%}
          {%- assign card_collection = block.settings.collection -%}
          {%- assign card_label = block.settings.label | default: card_collection.title -%}
          <a class="ds-home__category-card" href="{{ card_collection.url | default: routes.collections_url }}" {{ block.shopify_attributes }}>
            <div class="ds-home__category-image-wrap">
              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'ds-home__category-image',
                    widths: '360, 540, 720, 900',
                    sizes: '(min-width: 990px) 30vw, 70vw',
                    loading: 'lazy',
                    alt: card_label
                }}
              {%- elsif card_collection.image != blank -%}
                {{
                  card_collection.image
                  | image_url: width: 900
                  | image_tag:
                    class: 'ds-home__category-image',
                    widths: '360, 540, 720, 900',
                    sizes: '(min-width: 990px) 30vw, 70vw',
                    loading: 'lazy',
                    alt: card_label
                }}
              {%- endif -%}
            </div>
            <span class="ds-home__category-label">{{ card_label | escape }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>

  <section class="ds-home__trust">
    <div class="ds-home__trust-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust' -%}
          <article class="ds-home__trust-item" {{ block.shopify_attributes }}>
            <div class="ds-home__trust-icon">{{ block.settings.icon_svg }}</div>
            <h3 class="ds-home__trust-headline">{{ block.settings.headline | escape }}</h3>
            <p class="ds-home__trust-subtext">{{ block.settings.subtext | escape }}</p>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
</section>

{% schema %}
{
  "name": "DS Home",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "collection", "id": "category_collection", "label": "Fallback collection" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "Lifestyle essentials" },
    { "type": "inline_richtext", "id": "hero_headline", "label": "Hero headline", "default": "Choose small. Live better." },
    { "type": "textarea", "id": "hero_support_copy", "label": "Hero copy", "default": "Curated home upgrades with thoughtful design and practical comfort." },
    { "type": "text", "id": "primary_cta_label", "label": "Primary CTA label", "default": "Shop now" },
    { "type": "url", "id": "primary_cta_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary CTA label", "default": "View collections" },
    { "type": "url", "id": "secondary_cta_link", "label": "Secondary CTA link" },
    { "type": "inline_richtext", "id": "promise_headline", "label": "Brand promise headline", "default": "Designed for calmer, better everyday rituals." },
    { "type": "textarea", "id": "promise_body", "label": "Brand promise body", "default": "We curate products that feel elevated and practical at once. Every item is selected to improve comfort, flow, and long-term satisfaction in real homes." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Living" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "trust",
      "name": "Trust item",
      "limit": 4,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Inline SVG", "default": "<svg viewBox='0 0 24 24'><path fill='currentColor' d='M12 2 3 6v6c0 5 3.8 9.7 9 11 5.2-1.3 9-6 9-11V6l-9-4Zm0 2.2 7 3.1V12c0 4-2.9 7.9-7 9-4.1-1.1-7-5-7-9V7.3l7-3.1Z'/></svg>" },
        { "type": "text", "id": "headline", "label": "Headline", "default": "Thoughtfully selected" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Practical and beautiful standards" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DS Home",
      "blocks": [
        { "type": "category", "settings": { "label": "Kitchen" } },
        { "type": "category", "settings": { "label": "Bath" } },
        { "type": "category", "settings": { "label": "Desk" } },
        { "type": "trust", "settings": { "headline": "Curated quality", "subtext": "Selected for daily use" } },
        { "type": "trust", "settings": { "headline": "Fast dispatch", "subtext": "Quick shipping in Japan" } },
        { "type": "trust", "settings": { "headline": "Secure checkout", "subtext": "Trusted payment methods" } },
        { "type": "trust", "settings": { "headline": "Real support", "subtext": "We help after purchase" } }
      ]
    }
  ]
}
{% endschema %}
