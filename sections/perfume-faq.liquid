{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-faq-v2">
  <div class="page-width">
    {%- assign faq_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign faq_heading = section.settings.heading | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- if faq_eyebrow == blank -%}
      {%- assign faq_eyebrow = 'FAQ' -%}
    {%- endif -%}
    {%- if faq_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign faq_heading = 'よくある質問' -%}
      {%- else -%}
        {%- assign faq_heading = 'Questions, answered simply.' -%}
      {%- endif -%}
    {%- endif -%}

    <header class="perfume-faq-v2__head">
      <p class="perfume-eyebrow">{{ faq_eyebrow | escape }}</p>
      <h2 class="perfume-heading perfume-faq-v2__heading">{{ faq_heading }}</h2>
    </header>

    <div class="perfume-faq-v2__list">
      {%- for block in section.blocks -%}
        {%- assign faq_question = block.settings.question | strip -%}
        {%- assign faq_answer = block.settings.answer -%}
        {%- if faq_question == blank -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign faq_question = '一人暮らし向けの商品ですか？' -%}
                {%- assign faq_answer = '<p>はい。限られた空間と日常動線を前提に選定しています。</p>' -%}
              {%- else -%}
                {%- assign faq_question = 'Are these products suitable for solo living?' -%}
                {%- assign faq_answer = '<p>Yes. Every item is selected for limited space and daily ease.</p>' -%}
              {%- endif -%}
            {%- when 2 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign faq_question = '貯金中でも購入しやすいですか？' -%}
                {%- assign faq_answer = '<p>はい。生活改善に効く価格帯を中心に構成しています。</p>' -%}
              {%- else -%}
                {%- assign faq_question = 'Can I shop while keeping a monthly budget?' -%}
                {%- assign faq_answer = '<p>Yes. Pricing is curated to stay realistic for saving-focused plans.</p>' -%}
              {%- endif -%}
            {%- when 3 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign faq_question = '配送は早いですか？' -%}
                {%- assign faq_answer = '<p>国内配送を中心に、追跡しやすい形でお届けします。</p>' -%}
              {%- else -%}
                {%- assign faq_question = 'Do you ship quickly?' -%}
                {%- assign faq_answer = '<p>Domestic orders are processed quickly with clear tracking updates.</p>' -%}
              {%- endif -%}
            {%- when 4 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign faq_question = 'どこから見ればいいですか？' -%}
                {%- assign faq_answer = '<p>まずはFeatured Productsから見て、次に使用シーンをご確認ください。</p>' -%}
              {%- else -%}
                {%- assign faq_question = 'Where should I start?' -%}
                {%- assign faq_answer = '<p>Start with the featured products, then explore lifestyle scenes for fit.</p>' -%}
              {%- endif -%}
          {%- endcase -%}
        {%- endif -%}
        <article class="perfume-faq-v2__item" {{ block.shopify_attributes }}>
          <h3 class="perfume-faq-v2__question">{{ faq_question | escape }}</h3>
          <div class="perfume-faq-v2__answer rte">
            {{ faq_answer }}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "FAQ"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Questions, answered simply."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "質問",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "質問",
          "default": "Where should I start?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "回答",
          "default": "<p>Start with featured products.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Where should I start?",
            "answer": "<p>Start with featured products.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I keep budget control?",
            "answer": "<p>Yes, practical pricing is prioritized.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do you ship quickly?",
            "answer": "<p>Domestic orders are processed quickly.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Are these solo-living friendly?",
            "answer": "<p>Yes, selected for compact spaces.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
