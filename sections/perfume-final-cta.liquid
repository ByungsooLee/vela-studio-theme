{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-final-v2">
  <div class="page-width">
    {%- assign cta_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign cta_heading = section.settings.heading | strip -%}
    {%- assign cta_subheading = section.settings.subheading | strip -%}
    {%- assign cta_input = section.settings.input_label | strip -%}
    {%- assign cta_button = section.settings.button_label | strip -%}
    {%- assign cta_blog_heading = section.settings.blog_heading | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- if cta_eyebrow == blank -%}
      {%- assign cta_eyebrow = 'Final Step' -%}
    {%- endif -%}
    {%- if cta_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign cta_heading = '暮らしに合う一品を選ぶ。' -%}
      {%- else -%}
        {%- assign cta_heading = 'Choose a better routine.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if cta_subheading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign cta_subheading = '商品一覧を見るか、新作情報を受け取って次の買い替えに備えましょう。' -%}
      {%- else -%}
        {%- assign cta_subheading = 'Explore the full catalog or get updates on new arrivals.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if cta_input == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign cta_input = 'メールアドレス' -%}
      {%- else -%}
        {%- assign cta_input = 'Email address' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if cta_button == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign cta_button = '登録する' -%}
      {%- else -%}
        {%- assign cta_button = 'Subscribe' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if cta_blog_heading == blank -%}
      {%- assign cta_blog_heading = 'Journal' -%}
    {%- endif -%}

    <div class="perfume-final-v2__layout">
      <div class="perfume-final-v2__news">
        <p class="perfume-eyebrow">{{ cta_eyebrow | escape }}</p>
        <h2 class="perfume-heading perfume-final-v2__heading">{{ cta_heading }}</h2>
        <p class="perfume-copy perfume-final-v2__copy">{{ cta_subheading }}</p>
        <div class="perfume-final-v2__actions">
          <a class="perfume-button perfume-final-v2__shop-link" href="{{ routes.all_products_collection_url | default: '/collections/all' }}">
            {%- if is_ja == 'ja' -%}商品一覧へ{%- else -%}View all products{%- endif -%}
          </a>
        </div>
        {%- form 'customer', id: 'ContactTopCTA', class: 'perfume-final-v2__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="TopCTAEmail">{{ cta_input | escape }}</label>
          <input
            id="TopCTAEmail"
            type="email"
            name="contact[email]"
            class="perfume-final-v2__input"
            value="{{ form.email }}"
            placeholder="{{ cta_input | escape }}"
            required
          >
          <button type="submit" class="perfume-button perfume-final-v2__submit">
            {{ cta_button | escape }}
          </button>
        {%- endform -%}
      </div>
      <div class="perfume-final-v2__blog">
        <p class="perfume-final-v2__blog-label">{{ cta_blog_heading | escape }}</p>
        <div class="perfume-final-v2__blog-list" role="list">
          {%- for block in section.blocks -%}
            {%- assign journal_label = block.settings.label | strip -%}
            {%- if journal_label == blank -%}
              {%- case forloop.index -%}
                {%- when 1 -%}
                  {%- if is_ja == 'ja' -%}
                    {%- assign journal_label = '狭い部屋で使いやすい定番アイテム' -%}
                  {%- else -%}
                    {%- assign journal_label = 'Best essentials for small apartments' -%}
                  {%- endif -%}
                {%- when 2 -%}
                  {%- if is_ja == 'ja' -%}
                    {%- assign journal_label = '予算を守りながら部屋を整える方法' -%}
                  {%- else -%}
                    {%- assign journal_label = 'How to upgrade your room without overspending' -%}
                  {%- endif -%}
                {%- when 3 -%}
                  {%- if is_ja == 'ja' -%}
                    {%- assign journal_label = '視覚ノイズを減らすシンプルな選び方' -%}
                  {%- else -%}
                    {%- assign journal_label = 'Quiet design choices that reduce visual noise' -%}
                  {%- endif -%}
              {%- endcase -%}
            {%- endif -%}
            {%- if block.settings.link != blank -%}
              <a class="perfume-final-v2__blog-item" href="{{ block.settings.link }}" role="listitem" {{ block.shopify_attributes }}>
                <span>{{ journal_label | escape }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Final CTA",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Final Step"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Choose a better routine."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "説明",
      "default": "Explore the catalog or subscribe for updates."
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "入力プレースホルダー",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "送信ボタンラベル",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "blog_heading",
      "label": "ブログ導線見出し",
      "default": "Journal"
    }
  ],
  "blocks": [
    {
      "type": "blog",
      "name": "ブログリンク",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "ラベル",
          "default": "Journal"
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Final CTA",
      "blocks": [
        {
          "type": "blog",
          "settings": {
            "label": "Journal"
          }
        },
        {
          "type": "blog",
          "settings": {
            "label": "Journal"
          }
        },
        {
          "type": "blog",
          "settings": {
            "label": "Journal"
          }
        }
      ]
    }
  ]
}
{% endschema %}
