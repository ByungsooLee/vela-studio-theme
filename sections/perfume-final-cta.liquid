{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-final">
  <div class="page-width">
    <div class="perfume-final__box">
      {%- if section.settings.eyebrow != blank -%}
        <p class="perfume-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="perfume-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="perfume-copy">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="perfume-final__actions">
        {%- for block in section.blocks -%}
          {%- if block.settings.label != blank and block.settings.link != blank -%}
            <a
              class="perfume-button {% if block.settings.style == 'secondary' %}perfume-button--secondary{% endif %}"
              href="{{ block.settings.link }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | escape }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Final CTA",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Final Step"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "あなたの気分に寄り添う香りを。"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "説明",
      "default": "人気、香り、ギフト。目的に合わせて次の一歩を選べます。"
    }
  ],
  "blocks": [
    {
      "type": "action",
      "name": "ボタン",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "ラベル",
          "default": "人気の香りを見る"
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク"
        },
        {
          "type": "select",
          "id": "style",
          "label": "スタイル",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Final CTA",
      "blocks": [
        {
          "type": "action",
          "settings": {
            "label": "人気の香りを見る",
            "style": "primary"
          }
        },
        {
          "type": "action",
          "settings": {
            "label": "自分に合う香りを探す",
            "style": "secondary"
          }
        },
        {
          "type": "action",
          "settings": {
            "label": "ギフトを探す",
            "style": "secondary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
