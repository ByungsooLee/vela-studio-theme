{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-features-v2">
  <div class="page-width">
    {%- assign feature_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign feature_heading = section.settings.heading | strip -%}
    {%- assign feature_lead = section.settings.lead | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- assign fallback_feature_1 = blank -%}
    {%- assign fallback_feature_2 = blank -%}
    {%- assign fallback_feature_3 = blank -%}
    {%- assign fallback_feature_4 = blank -%}
    {%- for product in collections['all'].products limit: 4 -%}
      {%- case forloop.index -%}
        {%- when 1 -%}
          {%- assign fallback_feature_1 = product.featured_media -%}
        {%- when 2 -%}
          {%- assign fallback_feature_2 = product.featured_media -%}
        {%- when 3 -%}
          {%- assign fallback_feature_3 = product.featured_media -%}
        {%- when 4 -%}
          {%- assign fallback_feature_4 = product.featured_media -%}
      {%- endcase -%}
    {%- endfor -%}
    {%- if feature_eyebrow == blank -%}
      {%- assign feature_eyebrow = 'Lifestyle' -%}
    {%- endif -%}
    {%- if feature_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign feature_heading = '整った部屋は、暮らしを軽くする。' -%}
      {%- else -%}
        {%- assign feature_heading = 'A calm room, made practical.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if feature_lead == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign feature_lead = '商品単体ではなく、使うシーンから価値を伝えます。' -%}
      {%- else -%}
        {%- assign feature_lead = 'Image-led scenes to show how each piece fits daily life.' -%}
      {%- endif -%}
    {%- endif -%}

    <header class="perfume-features-v2__head">
      <p class="perfume-eyebrow">{{ feature_eyebrow | escape }}</p>
      <h2 class="perfume-heading perfume-features-v2__heading">{{ feature_heading }}</h2>
      <p class="perfume-copy perfume-features-v2__lead">{{ feature_lead }}</p>
    </header>

    <div class="perfume-features-v2__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign item_kicker = block.settings.kicker | strip -%}
        {%- assign item_title = block.settings.title | strip -%}
        {%- assign item_body = block.settings.body | strip -%}
        {%- assign item_media = block.settings.image -%}
        {%- if item_media == blank -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- assign item_media = fallback_feature_1 -%}
            {%- when 2 -%}
              {%- assign item_media = fallback_feature_2 -%}
            {%- when 3 -%}
              {%- assign item_media = fallback_feature_3 -%}
            {%- when 4 -%}
              {%- assign item_media = fallback_feature_4 -%}
          {%- endcase -%}
        {%- endif -%}
        {%- if item_kicker == blank -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign item_kicker = 'Morning' -%}
                {%- assign item_title = '朝の支度をスムーズに' -%}
                {%- assign item_body = '必要な物をすぐ使える配置で時間を短縮。' -%}
              {%- else -%}
                {%- assign item_kicker = 'Morning' -%}
                {%- assign item_title = 'Start the day with less friction' -%}
                {%- assign item_body = 'Organize essentials so routines stay light.' -%}
              {%- endif -%}
            {%- when 2 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign item_kicker = 'Work' -%}
                {%- assign item_title = '作業空間を静かに保つ' -%}
                {%- assign item_body = '小さな面積でも散らかりにくい設計。' -%}
              {%- else -%}
                {%- assign item_kicker = 'Work' -%}
                {%- assign item_title = 'Keep your desk visually quiet' -%}
                {%- assign item_body = 'Small-footprint tools that reduce clutter.' -%}
              {%- endif -%}
            {%- when 3 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign item_kicker = 'Evening' -%}
                {%- assign item_title = '夜のリセットを短時間で' -%}
                {%- assign item_body = '手入れしやすく、毎日続けやすい素材感。' -%}
              {%- else -%}
                {%- assign item_kicker = 'Evening' -%}
                {%- assign item_title = 'Reset your room in minutes' -%}
                {%- assign item_body = 'Easy-care items built for repeat use.' -%}
              {%- endif -%}
            {%- when 4 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign item_kicker = 'Weekend' -%}
                {%- assign item_title = '少しずつ暮らしを更新する' -%}
                {%- assign item_body = '買い足しでも統一感を崩さないラインアップ。' -%}
              {%- else -%}
                {%- assign item_kicker = 'Weekend' -%}
                {%- assign item_title = 'Upgrade little by little' -%}
                {%- assign item_body = 'Thoughtful additions that improve comfort over time.' -%}
              {%- endif -%}
          {%- endcase -%}
        {%- endif -%}
        <article class="perfume-features-v2__item{% if forloop.first %} perfume-features-v2__item--feature{% endif %}{% if item_media == blank %} perfume-features-v2__item--text{% endif %}" role="listitem" {{ block.shopify_attributes }}>
          {%- if item_media != blank -%}
            <a class="perfume-features-v2__media" href="{{ block.settings.link | default: '#' }}">
              {{
                item_media
                | image_url: width: 1800
                | image_tag:
                  class: 'perfume-features-v2__image',
                  widths: '480, 700, 960, 1300, 1800',
                  sizes: '(min-width: 990px) 45vw, 100vw',
                  loading: 'lazy'
              }}
            </a>
          {%- endif -%}
          <div class="perfume-features-v2__content">
            <p class="perfume-features-v2__kicker">{{ item_kicker | escape }}</p>
            <h3 class="perfume-features-v2__title">{{ item_title }}</h3>
            {%- if item_body != blank -%}
              <p class="perfume-copy perfume-features-v2__body">{{ item_body }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Features",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Lifestyle"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "A calm room, made practical."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "リード文",
      "default": "Image-led scenes for everyday routines."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "特徴",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "小見出し",
          "default": "Morning"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "Start with less friction"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "本文",
          "default": "Small changes that improve routine."
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "kicker": "Morning",
            "title": "Start with less friction"
          }
        },
        {
          "type": "feature",
          "settings": {
            "kicker": "Work",
            "title": "Keep your desk visually quiet"
          }
        },
        {
          "type": "feature",
          "settings": {
            "kicker": "Evening",
            "title": "Reset your room in minutes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
