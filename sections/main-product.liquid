      .lp-product--{{ section.id }} .lp-trust {
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-trust__divider {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-trust__item {
        flex: 0 1 calc(50% - 0.8rem);
        justify-content: center;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table {
        min-width: 68rem;
      }

      .lp-product--{{ section.id }} .lp-moments {
        column-count: 1;
      }

      .lp-product--{{ section.id }} .lp-story {
        min-height: 38rem;
      }

      .lp-product--{{ section.id }} .lp-button {
        min-height: 4.8rem;
      }
    }
  </style>

  <div id="product-raw-desc" style="display:none;">
    {{ product.description }}
  </div>

  <div class="page-width lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-gallery" data-lp-gallery>
        <div class="lp-gallery__viewport" data-gallery-viewport>
          <div class="lp-gallery__track" data-gallery-track>
            {%- if product.images.size > 0 -%}
              {%- for image in product.images -%}
                <div
                  class="lp-gallery__slide"
                  data-gallery-slide
                  data-media-id="{{ image.id }}"
                  aria-label="{{ product.title | escape }} image {{ forloop.index }}"
                >
                  {{
                    image
                    | image_url: width: 1800
                    | image_tag:
                      class: 'lp-gallery__image',
                      widths: '540, 720, 960, 1200, 1600, 1800',
                      sizes: '(min-width: 750px) 50vw, 100vw',
                      loading: 'eager',
                      alt: image.alt | default: product.title
                  }}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="lp-gallery__slide">
                {{ 'product-1' | placeholder_svg_tag: 'lp-gallery__image placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- if product.images.size > 1 -%}
          <div class="lp-gallery__thumb-carousel" aria-label="Product thumbnails">
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-prev aria-label="左へ">◀</button>
            <div class="lp-gallery__thumbs-viewport" data-thumbs-viewport>
              <div class="lp-gallery__thumbs" data-thumbs-track>
                {%- for image in product.images -%}
                  <button
                    type="button"
                    class="lp-gallery__thumb{% if image.id == active_media_id or active_media_id == blank and forloop.first %} is-active{% endif %}"
                    data-gallery-thumb
                    data-index="{{ forloop.index0 }}"
                    data-media-id="{{ image.id }}"
                    aria-label="画像 {{ forloop.index }} を表示"
                  >
                    {{
                      image
                      | image_url: width: 400
                      | image_tag:
                        class: 'lp-gallery__thumb-image',
                        widths: '80, 120, 160, 240, 320, 400',
                        sizes: '80px',
                        loading: 'lazy',
                        alt: image.alt | default: product.title
                    }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-next aria-label="右へ">▶</button>
          </div>
        {%- endif -%}

      </div>

      <div class="lp-info">
        <p class="lp-info__brand">pawlux</p>
        <h1 class="lp-info__title lp-serif">{{ product.title }}</h1>

        <div class="lp-info__rating">
          <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
            {{ product.metafields.judgeme.badge }}
          </div>
        </div>

        <div class="lp-info__price" id="LPPrice-{{ section.id }}">
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="lp-info__price-compare" data-compare-price>
              {{ selected_variant.compare_at_price | money }}
            </span>
          {%- else -%}
            <span class="lp-info__price-compare hidden" data-compare-price></span>
          {%- endif -%}
          <span class="lp-info__price-current" data-current-price>{{ selected_variant.price | money }}</span>
        </div>

        {%- if show_concept or show_tagline -%}
          <div class="lp-hero-copy">
            {%- if show_concept -%}
              <p class="lp-hero-copy__concept">{{ concept }}</p>
            {%- endif -%}
            {%- if show_tagline -%}
              <p class="lp-hero-copy__tagline">{{ tagline }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign option_name_downcase = option.name | downcase -%}
            {%- assign is_color_option = false -%}
            {%- assign is_ships_from_option = false -%}
            {%- if option_name_downcase contains 'color'
              or option_name_downcase contains 'colour'
              or option_name_downcase contains 'カラー'
              or option_name_downcase contains '色'
            -%}
              {%- assign is_color_option = true -%}
            {%- endif -%}
            {%- if option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM'
            -%}
              {%- assign is_ships_from_option = true -%}
            {%- endif -%}

            {% unless option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM' %}
              <div class="lp-option-group{% if is_ships_from_option %} ships-from-option{% endif %}" data-option-group data-option-index="{{ forloop.index0 }}">
                <div class="lp-option-group__label-row">
                  <span class="lp-option-group__label">{{ option.name }}</span>
                  <span class="lp-option-group__value{% if is_color_option %} is-color-label{% endif %}" data-option-value-label>
                    {% if is_color_option %}
                      {%- assign selected_color_label = option.selected_value -%}
                      {%- assign selected_color_key = option.selected_value | downcase -%}
                      {%- if selected_color_key contains 'beige' or selected_color_key contains 'ベージュ' -%}
                        {%- assign selected_color_label = 'ベージュ' -%}
                      {%- elsif selected_color_key contains 'gray' or selected_color_key contains 'grey' or selected_color_key contains 'グレー' -%}
                        {%- assign selected_color_label = 'グレー' -%}
                      {%- endif -%}
                      {{ selected_color_label }}
                    {% else %}
                      {{ option.selected_value }}
                    {% endif %}
                  </span>
                </div>

                {%- if is_color_option -%}
                  <div class="lp-swatch-wrap">
                    {% assign selected_color_value_lower = option.selected_value | downcase %}
                    {% assign displayed_colors = "" %}
                    {% for value in option.values %}
                      {% assign color_key = "" %}
                      {% assign swatch_color = "" %}
                      {% assign color_label = "" %}
                      {% assign swatch_key = value | downcase %}
                      {% if swatch_key contains "beige" or swatch_key contains "ベージュ" %}
                        {% assign color_key = "beige" %}
                        {% assign swatch_color = "#E8DCC8" %}
                        {% assign color_label = "ベージュ" %}
                      {% elsif swatch_key contains "gray" or swatch_key contains "grey" or swatch_key contains "グレー" %}
                        {% assign color_key = "gray" %}
                        {% assign swatch_color = "#9E9E9E" %}
                        {% assign color_label = "グレー" %}
                      {% endif %}

                      {% unless displayed_colors contains color_key or color_key == "" %}
                        {% assign displayed_colors = displayed_colors | append: color_key | append: "," %}
                        {% assign is_active_color = false %}
                        {% if selected_color_value_lower contains color_key %}
                          {% assign is_active_color = true %}
                        {% endif %}
                        <button
                          type="button"
                          class="lp-swatch variant-option{% if is_active_color %} is-active{% endif %}"
                          data-option-button
                          data-option-kind="color"
                          data-color-key="{{ color_key }}"
                          data-option-index="{{ forloop.parentloop.index0 }}"
                          data-option-value="{{ value | escape }}"
                          data-option-label="{{ color_label }}"
                          data-option-name="{{ option.name }}"
                          aria-label="{{ option.name }} {{ color_label }}"
                          aria-pressed="{% if is_active_color %}true{% else %}false{% endif %}"
                        >
                          <span class="lp-swatch__fill" style="--swatch-color: {{ swatch_color }};"></span>
                          <span class="visually-hidden">{{ color_label }}</span>
                        </button>
                      {% endunless %}
                    {% endfor %}
                  </div>
                {%- else -%}
                  <div class="lp-option-group__buttons">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="lp-option-button variant-option{% if option.selected_value == value %} is-active{% endif %}"
                        data-option-button
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        data-option-name="{{ option.name }}"
                        aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {% endunless %}
          {%- endfor -%}
        {%- endunless -%}

        <div class="lp-quantity">
          <div class="lp-option-group__label-row">
            <span class="lp-option-group__label">数量</span>
          </div>
          <div class="lp-quantity__control">
            <button type="button" class="lp-quantity__button" data-qty-decrease aria-label="数量を減らす">-</button>
            <input
              class="lp-quantity__input"
              type="number"
              min="1"
              step="1"
              value="1"
              inputmode="numeric"
              data-qty-input
              aria-label="数量"
            >
            <button type="button" class="lp-quantity__button" data-qty-increase aria-label="数量を増やす">+</button>
          </div>
        </div>

        <div class="lp-cta">
          <product-form data-hide-errors="false">
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id-input>
              <input type="hidden" name="quantity" value="1" data-qty-hidden-input>
              <button
                id="ProductSubmitButton-{{ section.id }}"
                type="submit"
                name="add"
                class="lp-button lp-button--primary"
                {% unless selected_variant.available %}disabled{% endunless %}
              >
                <span data-atc-label>
                  {% if selected_variant.available %}
                    カートに追加
                  {% else %}
                    売り切れ
                  {% endif %}
                </span>
                <div class="loading__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
              <div class="product-form__error-message-wrapper lp-form-error" hidden>
                <span class="product-form__error-message"></span>
              </div>
            {%- endform -%}
          </product-form>

          {%- form 'product', product, id: buy_now_form_id, class: 'form lp-buy-now-form' -%}
            <input type="hidden" name="id" value="{{ selected_variant.id }}" data-buy-now-variant-input>
            <input type="hidden" name="quantity" value="1" data-buy-now-qty-input>
            <button
              type="submit"
              name="checkout"
              class="lp-button lp-button--secondary"
              {% unless selected_variant.available %}disabled{% endunless %}
              data-buy-now-button
            >
              今すぐ購入
            </button>
          {%- endform -%}

          <div class="payment-icons-wrapper">
            <p class="payment-icons-label">以下の方法でお支払いいただけます</p>
            <div class="payment-icons-list">
              {% for type in shop.enabled_payment_types %}
                <img
                  src="{{ type | payment_type_img_url }}"
                  alt="{{ type }}"
                  class="payment-icon"
                  loading="lazy"
                >
              {% endfor %}
            </div>
          </div>
        </div>

        {%- if show_trust -%}
          <div class="lp-trust">
            {%- if show_shipping_time -%}
              <div class="lp-trust__item">
                <span class="lp-trust__icon" aria-hidden="true">⌁</span>
                <span class="lp-trust__text">{{ shipping_time }}</span>
              </div>
            {%- endif -%}
            {%- if show_shipping_time and show_return_policy -%}
              <span class="lp-trust__divider" aria-hidden="true">|</span>
            {%- endif -%}
            {%- if show_return_policy -%}
              <div class="lp-trust__item">
                <span class="lp-trust__icon" aria-hidden="true">↺</span>
                <span class="lp-trust__text">{{ return_policy }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if feature_count > 0 -%}
    <section class="lp-section lp-section--alt">
      <div class="page-width">
        <div class="lp-section__intro">
          <p class="lp-section__eyebrow">Feature Highlights</p>
          <h2 class="lp-section__heading lp-serif">{{ feature_section_heading }}</h2>
        </div>
        <div class="lp-highlights" style="--lp-highlight-columns: {{ feature_count }};">
          {%- if show_feature_1 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">01</div>
              <h3 class="lp-highlight__title">{{ feature_1_title }}</h3>
              <p class="lp-highlight__text">{{ feature_1_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_2 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">02</div>
              <h3 class="lp-highlight__title">{{ feature_2_title }}</h3>
              <p class="lp-highlight__text">{{ feature_2_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_3 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">03</div>
              <h3 class="lp-highlight__title">{{ feature_3_title }}</h3>
              <p class="lp-highlight__text">{{ feature_3_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_4 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">04</div>
              <h3 class="lp-highlight__title">{{ feature_4_title }}</h3>
              <p class="lp-highlight__text">{{ feature_4_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_5 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">05</div>
              <h3 class="lp-highlight__title">{{ feature_5_title }}</h3>
              <p class="lp-highlight__text">{{ feature_5_desc }}</p>
            </article>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- if show_closing_message -%}
    <section class="lp-section">
      <div class="page-width">
        <div class="lp-mid-copy">
          <p class="lp-section__eyebrow">Closing Message</p>
          <h2 class="lp-mid-copy__heading lp-serif">{{ closing_heading }}</h2>
          <div class="lp-mid-copy__body lp-info__description">
            {{ closing_message }}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="lp-section">
    <div class="page-width">
      <div class="lp-story">
        {%- if story_image != blank -%}
          {{
            story_image
            | image_url: width: 2200
            | image_tag:
              class: 'lp-story__image',
              widths: '750, 990, 1320, 1680, 2200',
              sizes: '100vw',
              loading: 'lazy',
              alt: section.settings.story_heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'lp-story__image placeholder-svg' }}
        {%- endif -%}
        {%- if show_hero_overlay -%}
          <div class="lp-story__overlay">
            <div>
              <p class="lp-story__hero-text lp-serif">{{ hero_image_text }}</p>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="lp-section">
    <div class="page-width lp-size-guide">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Size Guide</p>
        <h2 class="lp-section__heading lp-serif">商品のサイズ・仕様</h2>
      </div>
      <table class="lp-size-guide__table">
        <thead>
          <tr>
            <th>サイズ</th>
            <th>寸法</th>
            <th>耐荷重</th>
            <th>本体重量</th>
          </tr>
        </thead>
        <tbody>
          {%- if show_size_s -%}
            <tr>
              <td>S</td>
              <td>{% if size_s_dimension != blank and size_s_dimension_key != 'NONE' %}{{ size_s_dimension }}{% endif %}</td>
              <td>{% if size_s_weight_max != blank and size_s_weight_max_key != 'NONE' %}{{ size_s_weight_max }}{% endif %}</td>
              <td>{% if weight_s != blank and weight_s_key != 'NONE' %}{{ weight_s }}{% endif %}</td>
            </tr>
          {%- endif -%}
          {%- if show_size_m -%}
            <tr>
              <td>M</td>
              <td>{% if size_m_dimension != blank and size_m_dimension_key != 'NONE' %}{{ size_m_dimension }}{% endif %}</td>
              <td>{% if size_m_weight_max != blank and size_m_weight_max_key != 'NONE' %}{{ size_m_weight_max }}{% endif %}</td>
              <td>{% if weight_m != blank and weight_m_key != 'NONE' %}{{ weight_m }}{% endif %}</td>
            </tr>
          {%- endif -%}
          {%- if show_size_l -%}
            <tr>
              <td>L</td>
              <td>{% if size_l_dimension != blank and size_l_dimension_key != 'NONE' %}{{ size_l_dimension }}{% endif %}</td>
              <td>{% if size_l_weight_max != blank and size_l_weight_max_key != 'NONE' %}{{ size_l_weight_max }}{% endif %}</td>
              <td></td>
            </tr>
          {%- endif -%}
          {%- if show_material -%}
            <tr>
              <td>素材</td>
              <td colspan="3">{{ material }}</td>
            </tr>
          {%- endif -%}
          {%- if show_wash_method -%}
            <tr>
              <td>洗濯方法</td>
              <td colspan="3">{{ wash_method }}</td>
            </tr>
          {%- endif -%}
        </tbody>
      </table>
    </div>
  </section>

  {%- if recommend_count > 0 -%}
    <section class="lp-section lp-section--alt">
      <div class="page-width">
        <div class="lp-section__intro">
          <p class="lp-section__eyebrow">Recommended For</p>
          <h2 class="lp-section__heading lp-serif">こんな方におすすめ</h2>
        </div>
        <div class="lp-recommend-card">
          <ul class="lp-recommend-list">
            {%- if show_recommend_1 -%}<li>{{ recommend_1 }}</li>{%- endif -%}
            {%- if show_recommend_2 -%}<li>{{ recommend_2 }}</li>{%- endif -%}
            {%- if show_recommend_3 -%}<li>{{ recommend_3 }}</li>{%- endif -%}
          </ul>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- if show_caution -%}
    <section class="lp-section">
      <div class="page-width">
        <div class="lp-note-box">
          <h2 class="lp-note-box__title lp-serif">ご注意ください</h2>
          <p class="lp-note-box__text">{{ caution }}</p>
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="lp-section lp-section--alt">
    <div class="page-width">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Real Moments</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }}</h2>
      </div>
      {%- if has_moments -%}
        <div class="lp-moments">
          {%- assign rendered_moments = 0 -%}
          {%- for image in product.images offset: 1 limit: 6 -%}
            {%- assign rendered_moments = rendered_moments | plus: 1 -%}
            <figure class="lp-moments__item">
              {{
                image
                | image_url: width: 1200
                | image_tag:
                  class: 'lp-moments__image',
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  loading: 'lazy',
                  alt: image.alt | default: product.title
              }}
            </figure>
          {%- endfor -%}
          {%- if rendered_moments == 0 and product.featured_image != blank -%}
            <figure class="lp-moments__item">
              {{
                product.featured_image
                | image_url: width: 1200
                | image_tag:
                  class: 'lp-moments__image',
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  loading: 'lazy',
                  alt: product.title
              }}
            </figure>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  <section class="lp-section" id="reviews">
    <div class="page-width lp-reviews">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Reviews</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }} Reviews</h2>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="lp-reviews__widget">
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
          {{ product.metafields.judgeme.widget }}
        </div>
      </div>

      <div class="lp-reviews__fallback{% if review_count > 0 %} hidden{% endif %}" data-review-fallback>
        <a class="lp-button lp-button--secondary" href="#judgeme_product_reviews">最初のレビューを書く</a>
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--alt">
    <div class="page-width">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">FAQ</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }} FAQ</h2>
      </div>
      <div class="lp-faq" data-faq-root>
        {%- if faq_items != blank -%}
          {%- for item in faq_items -%}
            <article class="lp-faq__item">
              <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
                <span>{{ item.question | default: item.title | escape }}</span>
                <span class="lp-faq__icon">+</span>
              </button>
              <div class="lp-faq__panel" data-faq-panel>
                <div class="lp-faq__panel-inner">{{ item.answer | default: item.content }}</div>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>{{ product.title }} の特徴は何ですか？</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ key_benefits | default: faq_primary_answer | truncate: 140 }}</div>
            </div>
          </article>
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>サイズや仕様について教えてください。</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ dimensions | default: faq_size_answer }}</div>
            </div>
          </article>
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>お手入れ方法は？</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ care_instructions | default: faq_wash_answer }}</div>
            </div>
          </article>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="lp-section lp-related">
    <div class="page-width">
      <product-recommendations
        data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.recommendations_limit }}"
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
      >
        {% if recommendations.performed and recommendations.products_count > 0 %}
          <h2 class="lp-related__heading lp-serif">{{ product.title }} とあわせて人気の商品</h2>
          <div class="lp-related__grid">
            {% assign skip_card_product_styles = false %}
            {% for recommendation in recommendations.products %}
              <div class="grid__item">
                {% render 'card-product',
                  card_product: recommendation,
                  media_aspect_ratio: 'square',
                  image_shape: 'default',
                  show_secondary_image: true,
                  show_vendor: false,
                  show_rating: false,
                  skip_styles: skip_card_product_styles
                %}
              </div>
              {% assign skip_card_product_styles = true %}
            {% endfor %}
          </div>
        {% endif %}
      </product-recommendations>
    </div>
  </section>

  <script type="application/json" data-variant-json>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "price": {{ variant.price | json }},
          "price_text": {{ variant.price | money | json }},
          "compare_at_price": {{ variant.compare_at_price | default: 0 | json }},
          "compare_at_price_text": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}""{% endif %},
          "featured_media_id": {{ variant.featured_media.id | default: nil | json }},
          "featured_image": {% if variant.featured_image != blank %}{{ variant.featured_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
          "url": {{ product.url | append: '?variant=' | append: variant.id | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  <script>
    (() => {
      const section = document.getElementById('LPMainProduct-{{ section.id }}');
      if (!section) return;

      const variantData = JSON.parse(section.querySelector('[data-variant-json]').textContent);
      const productHasVariants = variantData.length > 0;
      const track = section.querySelector('[data-gallery-track]');
      const viewport = section.querySelector('[data-gallery-viewport]');
      const slides = Array.from(section.querySelectorAll('[data-gallery-slide]'));
      const thumbs = Array.from(section.querySelectorAll('[data-gallery-thumb]'));
      const thumbsTrack = section.querySelector('[data-thumbs-track]');
      const thumbPrevButton = section.querySelector('[data-thumb-prev]');
      const thumbNextButton = section.querySelector('[data-thumb-next]');
      const priceEl = section.querySelector('[data-current-price]');
      const compareEl = section.querySelector('[data-compare-price]');
      const atcButton = section.querySelector('#ProductSubmitButton-{{ section.id }}');
      const atcLabel = section.querySelector('[data-atc-label]');
      const buyNowButton = section.querySelector('[data-buy-now-button]');
      const variantInputs = Array.from(section.querySelectorAll('[data-variant-id-input], [data-buy-now-variant-input]'));
      const qtyInput = section.querySelector('[data-qty-input]');
      const qtyHiddenInputs = Array.from(section.querySelectorAll('[data-qty-hidden-input], [data-buy-now-qty-input]'));
      const optionButtons = Array.from(section.querySelectorAll('[data-option-button]'));
      const reviewWidget = section.querySelector('#judgeme_product_reviews');
      const reviewFallback = section.querySelector('[data-review-fallback]');
      let currentIndex = Math.max(
        0,
        slides.findIndex((slide) => String(slide.dataset.mediaId) === String({{ active_media_id | default: 0 | json }}))
      );
      let thumbStartIndex = 0;
      const visibleThumbCount = 4;

      const isMobile = () => window.matchMedia('(max-width: 767px)').matches;
      const normalizeColorKey = (value = '') => {
        const normalized = String(value).toLowerCase();
        if (normalized.includes('beige') || normalized.includes('ベージュ')) return 'beige';
        if (normalized.includes('gray') || normalized.includes('grey') || normalized.includes('グレー')) return 'gray';
        return '';
      };
      const colorLabelMap = {
        beige: 'ベージュ',
        gray: 'グレー',
      };

      const setQuantity = (value) => {
        const nextValue = Math.max(1, Number(value) || 1);
        qtyInput.value = nextValue;
        qtyHiddenInputs.forEach((input) => {
          input.value = nextValue;
        });
      };

      const syncThumbCarousel = () => {
        if (!thumbsTrack || isMobile()) return;
        const maxStartIndex = Math.max(thumbs.length - visibleThumbCount, 0);
        thumbStartIndex = Math.max(0, Math.min(thumbStartIndex, maxStartIndex));
        const thumbStep = 90;
        thumbsTrack.style.transform = `translateX(-${thumbStartIndex * thumbStep}px)`;
        if (thumbPrevButton) thumbPrevButton.disabled = thumbStartIndex === 0;
        if (thumbNextButton) thumbNextButton.disabled = thumbStartIndex >= maxStartIndex;
      };

      const ensureActiveThumbVisible = (index) => {
        if (isMobile()) return;
        if (index < thumbStartIndex) {
          thumbStartIndex = index;
        } else if (index >= thumbStartIndex + visibleThumbCount) {
          thumbStartIndex = index - visibleThumbCount + 1;
        }
        syncThumbCarousel();
      };

      const setActiveSlide = (index, syncScroll = true) => {
        if (!slides.length) return;
        currentIndex = Math.max(0, Math.min(index, slides.length - 1));
        thumbs.forEach((thumb, thumbIndex) => {
          thumb.classList.toggle('is-active', thumbIndex === currentIndex);
        });
        ensureActiveThumbVisible(currentIndex);
        if (isMobile()) {
          if (syncScroll) {
            viewport.scrollTo({
              left: viewport.clientWidth * currentIndex,
              behavior: 'smooth',
            });
          }
          track.style.transform = 'translateX(0)';
        } else {
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
      };

      const selectedOptions = productHasVariants
        ? (variantData.find((variant) => variant.id === {{ selected_variant.id | json }}) || variantData[0]).options.slice()
        : [];

      const findVariant = () =>
        variantData.find((variant) =>
          variant.options.every((optionValue, optionIndex) => optionValue === selectedOptions[optionIndex])
        );

      const updateOptionAvailability = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const buttonValue = button.dataset.optionValue;
          const isColorButton = button.dataset.optionKind === 'color';
          const colorKey = button.dataset.colorKey;
          const matches = variantData.some((variant) => {
            if (!variant.available) return false;
            if (isColorButton) {
              if (normalizeColorKey(variant.options[buttonIndex]) !== colorKey) return false;
            } else if (variant.options[buttonIndex] !== buttonValue) {
              return false;
            }
            return variant.options.every((optionValue, optionIndex) => {
              if (optionIndex === buttonIndex) return true;
              return optionValue === selectedOptions[optionIndex];
            });
          });
          button.disabled = !matches;
          button.classList.toggle('is-unavailable', !matches);
        });
      };

      const updateOptionUi = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const active =
            button.dataset.optionKind === 'color'
              ? normalizeColorKey(selectedOptions[buttonIndex]) === button.dataset.colorKey
              : selectedOptions[buttonIndex] === button.dataset.optionValue;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        section.querySelectorAll('[data-option-group]').forEach((group) => {
          const label = group.querySelector('[data-option-value-label]');
          const index = Number(group.dataset.optionIndex);
          if (label) {
            const activeColorKey = normalizeColorKey(selectedOptions[index]);
            label.textContent = activeColorKey && colorLabelMap[activeColorKey] ? colorLabelMap[activeColorKey] : selectedOptions[index] || '';
          }
        });
      };

      const updateForVariant = (variant) => {
        if (!variant) return;
        variantInputs.forEach((input) => {
          input.value = variant.id;
        });

        if (priceEl) priceEl.textContent = variant.price_text;
        if (compareEl) {
          if (variant.compare_at_price > variant.price && variant.compare_at_price_text) {
            compareEl.textContent = variant.compare_at_price_text;
            compareEl.classList.remove('hidden');
          } else {
            compareEl.textContent = '';
            compareEl.classList.add('hidden');
          }
        }

        const isAvailable = Boolean(variant.available);
        if (atcButton) atcButton.disabled = !isAvailable;
        if (buyNowButton) buyNowButton.disabled = !isAvailable;
        if (atcLabel) atcLabel.textContent = isAvailable ? 'カートに追加' : '売り切れ';

        if (variant.featured_media_id) {
          const variantIndex = slides.findIndex((slide) => String(slide.dataset.mediaId) === String(variant.featured_media_id));
          if (variantIndex >= 0) setActiveSlide(variantIndex, true);
        }

        if (variant.url && window.history.replaceState) {
          window.history.replaceState({}, '', variant.url);
        }

        updateOptionUi();
        updateOptionAvailability();
      };

      optionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (button.disabled) return;
          const optionIndex = Number(button.dataset.optionIndex);
          let variant = null;
          if (button.dataset.optionKind === 'color') {
            const colorKey = button.dataset.colorKey;
            variant =
              variantData.find((item) => normalizeColorKey(item.options[optionIndex]) === colorKey && item.available) ||
              variantData.find((item) => normalizeColorKey(item.options[optionIndex]) === colorKey);
            if (variant) {
              selectedOptions.splice(0, selectedOptions.length, ...variant.options);
            }
          } else {
            selectedOptions[optionIndex] = button.dataset.optionValue;
            variant = findVariant();
          }
          if (variant) updateForVariant(variant);
        });
      });

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          setActiveSlide(Number(thumb.dataset.index), true);
        });
      });

      thumbPrevButton?.addEventListener('click', () => {
        thumbStartIndex = Math.max(thumbStartIndex - 1, 0);
        syncThumbCarousel();
      });

      thumbNextButton?.addEventListener('click', () => {
        thumbStartIndex = Math.min(thumbStartIndex + 1, Math.max(thumbs.length - visibleThumbCount, 0));
        syncThumbCarousel();
      });

      if (viewport && slides.length > 1) {
        let scrollTimer = null;
        viewport.addEventListener(
          'scroll',
          () => {
            if (!isMobile()) return;
            window.clearTimeout(scrollTimer);
            scrollTimer = window.setTimeout(() => {
              const nextIndex = Math.round(viewport.scrollLeft / Math.max(viewport.clientWidth, 1));
              setActiveSlide(nextIndex, false);
            }, 60);
          },
          { passive: true }
        );
      }

      section.querySelector('[data-qty-decrease]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) - 1);
      });

      section.querySelector('[data-qty-increase]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) + 1);
      });

      qtyInput?.addEventListener('input', () => setQuantity(qtyInput.value));
      qtyInput?.addEventListener('blur', () => setQuantity(qtyInput.value));

      section.querySelectorAll('[data-faq-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const item = trigger.closest('.lp-faq__item');
          const panel = item?.querySelector('[data-faq-panel]');
          const isOpen = item.classList.contains('is-open');
          section.querySelectorAll('.lp-faq__item').forEach((faqItem) => {
            faqItem.classList.remove('is-open');
            const faqTrigger = faqItem.querySelector('[data-faq-trigger]');
            const faqPanel = faqItem.querySelector('[data-faq-panel]');
            if (faqTrigger) faqTrigger.setAttribute('aria-expanded', 'false');
            if (faqPanel) faqPanel.style.maxHeight = '0px';
          });
          if (!isOpen && item && panel) {
            item.classList.add('is-open');
            trigger.setAttribute('aria-expanded', 'true');
            panel.style.maxHeight = `${panel.scrollHeight}px`;
          }
        });
      });

      if (reviewWidget && reviewFallback) {
        const toggleReviewFallback = () => {
          const hasReviewMarkup =
            reviewWidget.querySelector('.jdgm-rev, .jdgm-all-reviews-page, .jdgm-histogram, .jdgm-row-stars') ||
            (reviewWidget.textContent || '').replace(/\s+/g, '').length > 0;
          reviewFallback.classList.toggle('hidden', Boolean(hasReviewMarkup));
        };

        toggleReviewFallback();
        new MutationObserver(toggleReviewFallback).observe(reviewWidget, {
          childList: true,
          subtree: true,
          characterData: true,
        });
      }

      window.addEventListener('resize', () => {
        setActiveSlide(currentIndex, false);
        syncThumbCarousel();
      });

      setQuantity(qtyInput?.value || 1);
      setActiveSlide(currentIndex, true);
      syncThumbCarousel();
      if (productHasVariants) {
        updateOptionUi();
        updateOptionAvailability();
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "LP Main Product",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "ストーリーバナー画像"
    },
    {
      "type": "inline_richtext",
      "id": "story_heading",
      "label": "ストーリーバナー見出し",
      "default": "いつでも、どこでも、一緒に。"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "ストーリーバナー本文",
      "default": "PAWLUXは、ペットとの毎日をもっと上質にするために生まれました。"
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "関連商品数",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
