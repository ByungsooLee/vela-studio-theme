{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign short_value_prop = product.metafields.product_details.short_value_prop.value -%}
{%- assign key_benefits = product.metafields.product_details.key_benefits.value -%}
{%- assign benefit_details = product.metafields.product_details.benefit_details.value -%}
{%- assign materials = product.metafields.product_details.materials.value -%}
{%- assign dimensions = product.metafields.product_details.dimensions.value -%}
{%- assign care_instructions = product.metafields.product_details.care_instructions.value -%}
{%- assign certifications = product.metafields.product_details.certifications.value -%}
{%- assign faq_items = product.metafields.product_details.faq_items.value -%}
{%- assign story_image = section.settings.story_image | default: product.images[1] | default: product.featured_image -%}
{%- assign has_moments = false -%}
{%- if product.images.size > 1 or product.featured_image != blank -%}
  {%- assign has_moments = true -%}
{%- endif -%}
{%- assign review_count = product.metafields.reviews.rating_count | default: 0 -%}
{%- assign product_form_id = 'lp-product-form-' | append: section.id -%}
{%- assign buy_now_form_id = 'lp-buy-now-form-' | append: section.id -%}
{%- assign active_media_id = selected_variant.featured_media.id | default: product.featured_image.id | default: product.images.first.id -%}
{%- assign description_plain = product.description | strip_html | strip_newlines -%}
{%- assign story_heading_text = short_value_prop | default: section.settings.story_heading -%}
{%- assign story_body_text = benefit_details | default: description_plain | truncate: 150 -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<section
  id="LPMainProduct-{{ section.id }}"
  class="lp-product lp-product--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap');

    .lp-product--{{ section.id }} {
      --lp-bg: #ffffff;
      --lp-alt: #f8f7f4;
      --lp-text: #1a1a1a;
      --lp-border: rgba(26, 26, 26, 0.14);
      --lp-muted: rgba(26, 26, 26, 0.64);
      --lp-accent: #1a1a1a;
      --lp-sale: #b23a3a;
      --lp-radius: 2.4rem;
      --lp-shadow: 0 24px 60px rgba(26, 26, 26, 0.08);
      background: var(--lp-bg);
      color: var(--lp-text);
      font-family: 'Noto Sans JP', sans-serif;
    }

    .lp-product--{{ section.id }} *,
    .lp-product--{{ section.id }} *::before,
    .lp-product--{{ section.id }} *::after {
      box-sizing: border-box;
    }

    .lp-product--{{ section.id }} .page-width {
      max-width: 138rem;
    }

    .lp-product--{{ section.id }} .lp-serif {
      font-family: 'Cormorant Garamond', serif;
      letter-spacing: 0.01em;
    }

    .lp-product--{{ section.id }} .lp-section {
      padding: 8rem 0;
    }

    .lp-product--{{ section.id }} .lp-section--alt {
      background: var(--lp-alt);
    }

    .lp-product--{{ section.id }} .lp-section__intro {
      max-width: 72rem;
      margin: 0 auto 3.6rem;
      text-align: center;
    }

    .lp-product--{{ section.id }} .lp-section__eyebrow {
      margin: 0 0 1rem;
      font-size: 1.2rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-section__heading {
      margin: 0;
      font-size: clamp(3.2rem, 5vw, 5.4rem);
      line-height: 0.96;
    }

    .lp-product--{{ section.id }} .lp-section__subtext {
      margin: 1.4rem 0 0;
      font-size: 1.5rem;
      line-height: 1.8;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-hero {
      padding: 5.6rem 0 8rem;
    }

    .lp-product--{{ section.id }} .lp-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
      gap: 4.8rem;
      align-items: start;
    }

    .lp-product--{{ section.id }} .lp-gallery {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.6rem;
      align-items: start;
    }

    .lp-product--{{ section.id }} .lp-gallery__viewport {
      position: relative;
      overflow: hidden;
      border-radius: var(--lp-radius);
      background: #f1f1ef;
      box-shadow: var(--lp-shadow);
    }

    .lp-product--{{ section.id }} .lp-gallery__track {
      display: flex;
      transition: transform 0.45s ease;
      will-change: transform;
    }

    .lp-product--{{ section.id }} .lp-gallery__slide {
      flex: 0 0 100%;
      position: relative;
      aspect-ratio: 1 / 1;
      scroll-snap-align: start;
      background: #f1f1ef;
    }

    .lp-product--{{ section.id }} .lp-gallery__image,
    .lp-product--{{ section.id }} .lp-story__image,
    .lp-product--{{ section.id }} .lp-moments__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-carousel {
      display: grid;
      grid-template-columns: 3.6rem minmax(0, 1fr) 3.6rem;
      align-items: center;
      gap: 1rem;
      max-width: 43rem;
      margin: 0 auto;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-nav {
      width: 3.6rem;
      height: 3.2rem;
      border: 1px solid rgba(26, 26, 26, 0.14);
      border-radius: 999px;
      background: #fff;
      color: var(--lp-text);
      cursor: pointer;
      font-size: 1.3rem;
      line-height: 1;
      transition: opacity 0.2s ease, border-color 0.2s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-nav[disabled] {
      opacity: 0.35;
      cursor: default;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs-viewport {
      width: 100%;
      height: 8rem;
      overflow: hidden;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      width: max-content;
      transition: transform 0.3s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs-grid {
      display: none !important;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb {
      border: 1px solid transparent;
      border-radius: 1.6rem;
      padding: 0;
      background: transparent;
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb:hover {
      transform: translateY(-0.1rem);
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb.is-active {
      border-color: var(--lp-accent);
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-image {
      width: 8rem;
      height: 8rem;
      object-fit: cover;
      display: block;
    }

    .lp-product--{{ section.id }} .lp-info {
      position: sticky;
      top: 3rem;
    }

    .lp-product--{{ section.id }} .lp-info__brand {
      margin: 0 0 1.2rem;
      font-size: 1.2rem;
      letter-spacing: 0.34em;
      text-transform: lowercase;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-info__title {
      margin: 0;
      max-width: 34rem;
      font-size: 2rem;
      line-height: 1.4;
      word-break: break-word;
    }

    .lp-product--{{ section.id }} .lp-info__rating {
      margin: 2rem 0 0;
      min-height: 2.4rem;
    }

    .lp-product--{{ section.id }} .lp-info__rating .jdgm-prev-badge,
    .lp-product--{{ section.id }} .lp-info__rating .jdgm-widget {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      color: var(--lp-text);
      font-size: 1.35rem;
    }

    .lp-product--{{ section.id }} .lp-info__price {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 1rem 1.4rem;
      margin-top: 2rem;
    }

    .lp-product--{{ section.id }} .lp-info__price-current {
      font-size: clamp(2.8rem, 4vw, 3.8rem);
      font-weight: 700;
      color: var(--lp-sale);
      line-height: 1;
    }

    .lp-product--{{ section.id }} .lp-info__price-compare {
      font-size: 1.8rem;
      color: var(--lp-muted);
      text-decoration: line-through;
    }

    .lp-product--{{ section.id }} .lp-info__description {
      margin-top: 0;
      font-size: 1.5rem;
      line-height: 1.85;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-mid-copy {
      max-width: 72rem;
      margin: 0 auto;
      text-align: center;
    }

    .lp-product--{{ section.id }} .lp-mid-copy__heading {
      margin: 0;
      font-size: clamp(2.6rem, 4vw, 4rem);
      line-height: 1.2;
    }

    .lp-product--{{ section.id }} .lp-mid-copy__body {
      margin-top: 1.8rem;
    }

    .lp-product--{{ section.id }} .variant-option[data-option-name="Ships From"],
    .lp-product--{{ section.id }} .variant-option[data-option-name="ships from"],
    .lp-product--{{ section.id }} label[for*="ships"],
    .lp-product--{{ section.id }} .ships-from-option {
      display: none !important;
    }

    .lp-product--{{ section.id }} .lp-option-group {
      margin-top: 2.8rem;
    }

    .lp-product--{{ section.id }} .lp-option-group__label-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.2rem;
      align-items: baseline;
    }

    .lp-product--{{ section.id }} .lp-option-group__label {
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .lp-product--{{ section.id }} .lp-option-group__value {
      font-size: 1.3rem;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-option-group__value.is-color-label {
      font-weight: 600;
      color: var(--lp-text);
    }

    .lp-product--{{ section.id }} .lp-option-group__buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .lp-product--{{ section.id }} .lp-option-button,
    .lp-product--{{ section.id }} .lp-swatch {
      appearance: none;
      border: 1px solid rgba(26, 26, 26, 0.18);
      background: #fff;
      cursor: pointer;
      transition: border-color 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
    }

    .lp-product--{{ section.id }} .lp-option-button:hover,
    .lp-product--{{ section.id }} .lp-swatch:hover {
      transform: translateY(-0.1rem);
    }

    .lp-product--{{ section.id }} .lp-option-button.is-active,
    .lp-product--{{ section.id }} .lp-swatch.is-active {
      border-color: var(--lp-accent);
      box-shadow: inset 0 0 0 1px var(--lp-accent);
    }

    .lp-product--{{ section.id }} .lp-option-button[disabled],
    .lp-product--{{ section.id }} .lp-swatch[disabled] {
      opacity: 0.28;
      cursor: not-allowed;
      transform: none;
    }

    .lp-product--{{ section.id }} .lp-option-button {
      min-height: 4.4rem;
      border-radius: 999px;
      padding: 0.8rem 1.8rem;
      font-size: 1.45rem;
      color: var(--lp-text);
    }

    .lp-product--{{ section.id }} .lp-swatch-wrap {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 1.2rem;
    }

    .lp-product--{{ section.id }} .lp-swatch {
      width: 4.4rem;
      height: 4.4rem;
      border-radius: 50%;
      padding: 0.4rem;
    }

    .lp-product--{{ section.id }} .lp-swatch__fill {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: var(--swatch-color, #d8d8d8);
      border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .lp-product--{{ section.id }} .lp-quantity {
      margin-top: 2.8rem;
    }

    .lp-product--{{ section.id }} .lp-quantity__control {
      display: inline-grid;
      grid-template-columns: 4.8rem minmax(6rem, auto) 4.8rem;
      border: 1px solid var(--lp-border);
      border-radius: 999px;
      overflow: hidden;
      background: #fff;
    }

    .lp-product--{{ section.id }} .lp-quantity__button,
    .lp-product--{{ section.id }} .lp-quantity__input {
      min-height: 4.8rem;
      border: 0;
      background: transparent;
      text-align: center;
      font-size: 1.7rem;
      color: var(--lp-text);
    }

    .lp-product--{{ section.id }} .lp-quantity__button {
      cursor: pointer;
    }

    .lp-product--{{ section.id }} .lp-quantity__input {
      width: 100%;
      -moz-appearance: textfield;
    }

    .lp-product--{{ section.id }} .lp-quantity__input::-webkit-outer-spin-button,
    .lp-product--{{ section.id }} .lp-quantity__input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .lp-product--{{ section.id }} .lp-cta {
      margin-top: 2.8rem;
      display: grid;
      gap: 1rem;
    }

    .lp-product--{{ section.id }} .lp-button {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 5.4rem;
      border-radius: 999px;
      border: 1px solid var(--lp-accent);
      padding: 1.4rem 2rem;
      font-size: 1.45rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
      cursor: pointer;
    }

    .lp-product--{{ section.id }} .lp-button:hover {
      transform: translateY(-0.1rem);
    }

    .lp-product--{{ section.id }} .lp-button[disabled] {
      opacity: 0.4;
      cursor: not-allowed;
      transform: none;
    }

    .lp-product--{{ section.id }} .lp-button--primary {
      background: var(--lp-accent);
      color: #fff;
    }

    .lp-product--{{ section.id }} .lp-button--secondary {
      background: transparent;
      color: var(--lp-text);
    }

    .lp-product--{{ section.id }} .lp-button .loading__spinner {
      position: absolute;
      right: 1.6rem;
      width: 1.8rem;
      height: 1.8rem;
    }

    .lp-product--{{ section.id }} .lp-button .loading__spinner.hidden {
      display: none;
    }

    .lp-product--{{ section.id }} .lp-form-error {
      margin-top: 1.2rem;
      color: #b42318;
      font-size: 1.3rem;
    }

    .lp-product--{{ section.id }} .lp-trust {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      margin-top: 2.8rem;
      text-align: center;
      white-space: nowrap;
      font-size: 1.1rem;
    }

    .lp-product--{{ section.id }} .lp-trust__item {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0;
      background: transparent;
      color: #555555;
      font-size: 1.1rem;
      line-height: 1.5;
      white-space: nowrap;
    }

    .lp-product--{{ section.id }} .lp-trust__icon {
      font-size: 1.3rem;
      color: var(--lp-text);
    }

    .lp-product--{{ section.id }} .lp-trust__text {
      white-space: nowrap;
    }

    .lp-product--{{ section.id }} .lp-trust__divider {
      color: rgba(26, 26, 26, 0.28);
      font-size: 1.1rem;
      margin: 0 0.4rem;
    }

    .lp-product--{{ section.id }} .payment-icons-wrapper {
      background: #F8F7F4;
      border-radius: 8px;
      padding: 12px 16px;
      margin-top: 12px;
      text-align: center;
    }

    .lp-product--{{ section.id }} .payment-icons-label {
      margin: 0 0 8px;
      font-size: 11px;
      color: #888888;
      letter-spacing: 0.05em;
    }

    .lp-product--{{ section.id }} .payment-icons-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 8px;
    }

    .lp-product--{{ section.id }} .payment-icon {
      height: 24px;
      width: auto;
      filter: grayscale(20%);
      opacity: 0.85;
      transition: opacity 0.2s ease;
    }

    .lp-product--{{ section.id }} .payment-icon:hover {
      opacity: 1;
    }

    .lp-product--{{ section.id }} .lp-highlights {
      display: grid;
      grid-template-columns: repeat(2, minmax(28rem, 36rem));
      gap: 1.6rem;
      justify-content: center;
      max-width: 76rem;
      margin: 0 auto;
    }

    .lp-product--{{ section.id }} .lp-highlight {
      padding: 2.6rem 2rem;
      border-radius: 2.2rem;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(26, 26, 26, 0.06);
      min-height: 100%;
    }

    .lp-product--{{ section.id }} .lp-highlight__icon {
      width: 4.8rem;
      height: 4.8rem;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--lp-accent);
      color: #fff;
      font-size: 1.6rem;
      font-weight: 700;
    }

    .lp-product--{{ section.id }} .lp-highlight__title {
      margin: 1.6rem 0 0;
      font-size: 1.8rem;
      font-weight: 700;
    }

    .lp-product--{{ section.id }} .lp-highlight__text {
      margin: 0.8rem 0 0;
      font-size: 1.4rem;
      line-height: 1.75;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-story {
      position: relative;
      min-height: 50rem;
      border-radius: 2.8rem;
      overflow: hidden;
      box-shadow: var(--lp-shadow);
    }

    .lp-product--{{ section.id }} .lp-story__overlay {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, rgba(26, 26, 26, 0.18), rgba(26, 26, 26, 0.55));
      padding: 3rem;
      text-align: center;
      color: #fff;
    }

    .lp-product--{{ section.id }} .lp-story__heading {
      margin: 0;
      font-size: clamp(3.6rem, 6vw, 6.8rem);
      line-height: 0.95;
    }

    .lp-product--{{ section.id }} .lp-story__copy {
      margin: 1.4rem auto 0;
      max-width: 70rem;
      font-size: 1.7rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.86);
    }

    .lp-product--{{ section.id }} .lp-size-guide {
      overflow-x: auto;
    }

    .lp-product--{{ section.id }} .lp-size-guide__table {
      width: min(88rem, 100%);
      margin: 3.2rem auto 0;
      border-collapse: collapse;
      background: #fff;
      border-radius: 2rem;
      overflow: hidden;
      box-shadow: 0 10px 35px rgba(26, 26, 26, 0.05);
    }

    .lp-product--{{ section.id }} .lp-size-guide__table th,
    .lp-product--{{ section.id }} .lp-size-guide__table td {
      padding: 1.6rem 1.4rem;
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
      text-align: center;
      font-size: 1.4rem;
    }

    .lp-product--{{ section.id }} .lp-size-guide__table th {
      background: var(--lp-alt);
      font-size: 1.25rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-size-guide__table tr:last-child td {
      border-bottom: 0;
    }

    .lp-product--{{ section.id }} .lp-size-guide__note {
      margin: 1.8rem 0 0;
      text-align: center;
      color: var(--lp-muted);
      font-size: 1.35rem;
    }

    .lp-product--{{ section.id }} .lp-moments {
      column-count: 3;
      column-gap: 1.6rem;
    }

    .lp-product--{{ section.id }} .lp-moments__item {
      break-inside: avoid;
      margin-bottom: 1.6rem;
      border-radius: 2rem;
      overflow: hidden;
      background: #efefec;
      box-shadow: 0 10px 30px rgba(26, 26, 26, 0.04);
    }

    .lp-product--{{ section.id }} .lp-moments__item img {
      min-height: 22rem;
    }

    .lp-product--{{ section.id }} .lp-reviews {
      max-width: 106rem;
      margin: 0 auto;
    }

    .lp-product--{{ section.id }} .lp-reviews__fallback {
      margin-top: 2rem;
      text-align: center;
    }

    .lp-product--{{ section.id }} .lp-reviews__widget {
      margin-top: 3rem;
    }

    .lp-product--{{ section.id }} .lp-faq {
      max-width: 94rem;
      margin: 0 auto;
      display: grid;
      gap: 1.2rem;
    }

    .lp-product--{{ section.id }} .lp-faq__item {
      border: 1px solid rgba(26, 26, 26, 0.08);
      border-radius: 1.8rem;
      background: rgba(255, 255, 255, 0.7);
      overflow: hidden;
    }

    .lp-product--{{ section.id }} .lp-faq__trigger {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.6rem;
      padding: 2rem 2.2rem;
      border: 0;
      background: transparent;
      text-align: left;
      cursor: pointer;
      color: var(--lp-text);
      font-size: 1.65rem;
      font-weight: 600;
    }

    .lp-product--{{ section.id }} .lp-faq__icon {
      flex: 0 0 auto;
      font-size: 2rem;
      transition: transform 0.25s ease;
    }

    .lp-product--{{ section.id }} .lp-faq__item.is-open .lp-faq__icon {
      transform: rotate(45deg);
    }

    .lp-product--{{ section.id }} .lp-faq__panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.28s ease;
    }

    .lp-product--{{ section.id }} .lp-faq__panel-inner {
      padding: 0 2.2rem 2rem;
      font-size: 1.45rem;
      line-height: 1.85;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-related product-recommendations {
      display: block;
    }

    .lp-product--{{ section.id }} .lp-related__heading {
      margin: 0 0 2.8rem;
      text-align: center;
      font-size: clamp(3rem, 4vw, 4.8rem);
      line-height: 1;
    }

    .lp-product--{{ section.id }} .lp-related__grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem;
      align-items: start;
    }

    .lp-product--{{ section.id }} .lp-related__grid .card-wrapper,
    .lp-product--{{ section.id }} .lp-related__grid .card {
      height: 100%;
    }

    .lp-product--{{ section.id }} .hidden {
      display: none !important;
    }

    @media screen and (max-width: 989px) {
      .lp-product--{{ section.id }} .lp-hero__grid {
        grid-template-columns: 1fr;
      }

      .lp-product--{{ section.id }} .lp-info {
        position: static;
      }

      .lp-product--{{ section.id }} .lp-trust,
      .lp-product--{{ section.id }} .lp-highlights {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .lp-product--{{ section.id }} .lp-related__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 767px) {
      .lp-product--{{ section.id }} .lp-section {
        padding: 5.6rem 0;
      }

      .lp-product--{{ section.id }} .lp-section__intro {
        max-width: 32rem;
        margin-bottom: 2.4rem;
      }

      .lp-product--{{ section.id }} .lp-section__heading {
        max-width: 32rem;
        margin: 0 auto;
        font-size: clamp(2.4rem, 7vw, 3.2rem);
        line-height: 1.2;
        letter-spacing: 0;
      }

      .lp-product--{{ section.id }} .lp-hero {
        padding: 2.4rem 0 5.6rem;
      }

      .lp-product--{{ section.id }} .lp-info__title {
        max-width: 100%;
        font-size: 1.4rem;
        line-height: 1.4;
      }

      .lp-product--{{ section.id }} .lp-gallery__thumbs {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-gallery__thumb-carousel {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-gallery__viewport {
        overflow-x: auto;
        scroll-snap-type: x mandatory;
      }

      .lp-product--{{ section.id }} .lp-gallery__track {
        transition: none;
      }

      .lp-product--{{ section.id }} .lp-highlights,
      .lp-product--{{ section.id }} .lp-related__grid {
        grid-template-columns: 1fr;
      }

      .lp-product--{{ section.id }} .lp-trust {
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-trust__divider {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-trust__item {
        flex: 0 1 calc(50% - 0.8rem);
        justify-content: center;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table {
        min-width: 68rem;
      }

      .lp-product--{{ section.id }} .lp-moments {
        column-count: 1;
      }

      .lp-product--{{ section.id }} .lp-story {
        min-height: 38rem;
      }

      .lp-product--{{ section.id }} .lp-button {
        min-height: 4.8rem;
      }
    }
  </style>

  <div class="page-width lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-gallery" data-lp-gallery>
        <div class="lp-gallery__viewport" data-gallery-viewport>
          <div class="lp-gallery__track" data-gallery-track>
            {%- if product.images.size > 0 -%}
              {%- for image in product.images -%}
                <div
                  class="lp-gallery__slide"
                  data-gallery-slide
                  data-media-id="{{ image.id }}"
                  aria-label="{{ product.title | escape }} image {{ forloop.index }}"
                >
                  {{
                    image
                    | image_url: width: 1800
                    | image_tag:
                      class: 'lp-gallery__image',
                      widths: '540, 720, 960, 1200, 1600, 1800',
                      sizes: '(min-width: 750px) 50vw, 100vw',
                      loading: 'eager',
                      alt: image.alt | default: product.title
                  }}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="lp-gallery__slide">
                {{ 'product-1' | placeholder_svg_tag: 'lp-gallery__image placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- if product.images.size > 1 -%}
          <div class="lp-gallery__thumb-carousel" aria-label="Product thumbnails">
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-prev aria-label="左へ">◀</button>
            <div class="lp-gallery__thumbs-viewport" data-thumbs-viewport>
              <div class="lp-gallery__thumbs" data-thumbs-track>
                {%- for image in product.images -%}
                  <button
                    type="button"
                    class="lp-gallery__thumb{% if image.id == active_media_id or active_media_id == blank and forloop.first %} is-active{% endif %}"
                    data-gallery-thumb
                    data-index="{{ forloop.index0 }}"
                    data-media-id="{{ image.id }}"
                    aria-label="画像 {{ forloop.index }} を表示"
                  >
                    {{
                      image
                      | image_url: width: 400
                      | image_tag:
                        class: 'lp-gallery__thumb-image',
                        widths: '80, 120, 160, 240, 320, 400',
                        sizes: '80px',
                        loading: 'lazy',
                        alt: image.alt | default: product.title
                    }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-next aria-label="右へ">▶</button>
          </div>
        {%- endif -%}

      </div>

      <div class="lp-info">
        <p class="lp-info__brand">pawlux</p>
        <h1 class="lp-info__title lp-serif">{{ product.title }}</h1>

        <div class="lp-info__rating">
          <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
            {{ product.metafields.judgeme.badge }}
          </div>
        </div>

        <div class="lp-info__price" id="LPPrice-{{ section.id }}">
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="lp-info__price-compare" data-compare-price>
              {{ selected_variant.compare_at_price | money }}
            </span>
          {%- else -%}
            <span class="lp-info__price-compare hidden" data-compare-price></span>
          {%- endif -%}
          <span class="lp-info__price-current" data-current-price>{{ selected_variant.price | money }}</span>
        </div>

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign option_name_downcase = option.name | downcase -%}
            {%- assign is_color_option = false -%}
            {%- assign is_ships_from_option = false -%}
            {%- if option_name_downcase contains 'color'
              or option_name_downcase contains 'colour'
              or option_name_downcase contains 'カラー'
              or option_name_downcase contains '色'
            -%}
              {%- assign is_color_option = true -%}
            {%- endif -%}
            {%- if option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM'
            -%}
              {%- assign is_ships_from_option = true -%}
            {%- endif -%}

            {% unless option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM' %}
              <div class="lp-option-group{% if is_ships_from_option %} ships-from-option{% endif %}" data-option-group data-option-index="{{ forloop.index0 }}">
                <div class="lp-option-group__label-row">
                  <span class="lp-option-group__label">{{ option.name }}</span>
                  <span class="lp-option-group__value{% if is_color_option %} is-color-label{% endif %}" data-option-value-label>
                    {% if is_color_option %}
                      {%- assign selected_color_label = option.selected_value -%}
                      {%- assign selected_color_key = option.selected_value | downcase -%}
                      {%- if selected_color_key contains 'beige' or selected_color_key contains 'ベージュ' -%}
                        {%- assign selected_color_label = 'ベージュ' -%}
                      {%- elsif selected_color_key contains 'gray' or selected_color_key contains 'grey' or selected_color_key contains 'グレー' -%}
                        {%- assign selected_color_label = 'グレー' -%}
                      {%- endif -%}
                      {{ selected_color_label }}
                    {% else %}
                      {{ option.selected_value }}
                    {% endif %}
                  </span>
                </div>

                {%- if is_color_option -%}
                  <div class="lp-swatch-wrap">
                    {% assign selected_color_value_lower = option.selected_value | downcase %}
                    {% assign displayed_colors = "" %}
                    {% for value in option.values %}
                      {% assign color_key = "" %}
                      {% assign swatch_color = "" %}
                      {% assign color_label = "" %}
                      {% assign swatch_key = value | downcase %}
                      {% if swatch_key contains "beige" or swatch_key contains "ベージュ" %}
                        {% assign color_key = "beige" %}
                        {% assign swatch_color = "#E8DCC8" %}
                        {% assign color_label = "ベージュ" %}
                      {% elsif swatch_key contains "gray" or swatch_key contains "grey" or swatch_key contains "グレー" %}
                        {% assign color_key = "gray" %}
                        {% assign swatch_color = "#9E9E9E" %}
                        {% assign color_label = "グレー" %}
                      {% endif %}

                      {% unless displayed_colors contains color_key or color_key == "" %}
                        {% assign displayed_colors = displayed_colors | append: color_key | append: "," %}
                        {% assign is_active_color = false %}
                        {% if selected_color_value_lower contains color_key %}
                          {% assign is_active_color = true %}
                        {% endif %}
                        <button
                          type="button"
                          class="lp-swatch variant-option{% if is_active_color %} is-active{% endif %}"
                          data-option-button
                          data-option-kind="color"
                          data-color-key="{{ color_key }}"
                          data-option-index="{{ forloop.parentloop.index0 }}"
                          data-option-value="{{ value | escape }}"
                          data-option-label="{{ color_label }}"
                          data-option-name="{{ option.name }}"
                          aria-label="{{ option.name }} {{ color_label }}"
                          aria-pressed="{% if is_active_color %}true{% else %}false{% endif %}"
                        >
                          <span class="lp-swatch__fill" style="--swatch-color: {{ swatch_color }};"></span>
                          <span class="visually-hidden">{{ color_label }}</span>
                        </button>
                      {% endunless %}
                    {% endfor %}
                  </div>
                {%- else -%}
                  <div class="lp-option-group__buttons">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="lp-option-button variant-option{% if option.selected_value == value %} is-active{% endif %}"
                        data-option-button
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        data-option-name="{{ option.name }}"
                        aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {% endunless %}
          {%- endfor -%}
        {%- endunless -%}

        <div class="lp-quantity">
          <div class="lp-option-group__label-row">
            <span class="lp-option-group__label">数量</span>
          </div>
          <div class="lp-quantity__control">
            <button type="button" class="lp-quantity__button" data-qty-decrease aria-label="数量を減らす">-</button>
            <input
              class="lp-quantity__input"
              type="number"
              min="1"
              step="1"
              value="1"
              inputmode="numeric"
              data-qty-input
              aria-label="数量"
            >
            <button type="button" class="lp-quantity__button" data-qty-increase aria-label="数量を増やす">+</button>
          </div>
        </div>

        <div class="lp-cta">
          <product-form data-hide-errors="false">
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id-input>
              <input type="hidden" name="quantity" value="1" data-qty-hidden-input>
              <button
                id="ProductSubmitButton-{{ section.id }}"
                type="submit"
                name="add"
                class="lp-button lp-button--primary"
                {% unless selected_variant.available %}disabled{% endunless %}
              >
                <span data-atc-label>
                  {% if selected_variant.available %}
                    カートに追加
                  {% else %}
                    売り切れ
                  {% endif %}
                </span>
                <div class="loading__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
              <div class="product-form__error-message-wrapper lp-form-error" hidden>
                <span class="product-form__error-message"></span>
              </div>
            {%- endform -%}
          </product-form>

          {%- form 'product', product, id: buy_now_form_id, class: 'form lp-buy-now-form' -%}
            <input type="hidden" name="id" value="{{ selected_variant.id }}" data-buy-now-variant-input>
            <input type="hidden" name="quantity" value="1" data-buy-now-qty-input>
            <button
              type="submit"
              name="checkout"
              class="lp-button lp-button--secondary"
              {% unless selected_variant.available %}disabled{% endunless %}
              data-buy-now-button
            >
              今すぐ購入
            </button>
          {%- endform -%}

          <div class="payment-icons-wrapper">
            <p class="payment-icons-label">以下の方法でお支払いいただけます</p>
            <div class="payment-icons-list">
              {% for type in shop.enabled_payment_types %}
                <img
                  src="{{ type | payment_type_img_url }}"
                  alt="{{ type }}"
                  class="payment-icon"
                  loading="lazy"
                >
              {% endfor %}
            </div>
          </div>
        </div>

        <div
          class="lp-trust"
          style="display:flex !important; flex-wrap:nowrap !important; justify-content:center; align-items:center; gap:6px; font-size:11px; white-space:nowrap; overflow:hidden;"
        >
          <div class="lp-trust__item" style="display:inline-flex; align-items:center; gap:4px; font-size:11px; white-space:nowrap; flex:0 0 auto;">
            <span class="lp-trust__icon" aria-hidden="true" style="font-size:11px; line-height:1;">⌁</span>
            <span class="lp-trust__text" style="font-size:11px; white-space:nowrap;">送料無料</span>
          </div>
          <span class="lp-trust__divider" aria-hidden="true" style="color:#cccccc; margin:0 4px; font-size:11px;">|</span>
          <div class="lp-trust__item" style="display:inline-flex; align-items:center; gap:4px; font-size:11px; white-space:nowrap; flex:0 0 auto;">
            <span class="lp-trust__icon" aria-hidden="true" style="font-size:11px; line-height:1;">↺</span>
            <span class="lp-trust__text" style="font-size:11px; white-space:nowrap;">30日返品保証</span>
          </div>
          <span class="lp-trust__divider" aria-hidden="true" style="color:#cccccc; margin:0 4px; font-size:11px;">|</span>
          <div class="lp-trust__item" style="display:inline-flex; align-items:center; gap:4px; font-size:11px; white-space:nowrap; flex:0 0 auto;">
            <span class="lp-trust__icon" aria-hidden="true" style="font-size:11px; line-height:1;">⌂</span>
            <span class="lp-trust__text" style="font-size:11px; white-space:nowrap;">安全決済</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="lp-section lp-section--alt">
    <div class="page-width">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Feature Highlights</p>
        <h2 class="lp-section__heading lp-serif">{{ short_value_prop | default: product.title }}</h2>
      </div>
      <div class="lp-highlights">
        <article class="lp-highlight">
          <div class="lp-highlight__icon">01</div>
          <h3 class="lp-highlight__title">商品コンセプト</h3>
          <p class="lp-highlight__text">{{ short_value_prop | default: description_plain | truncate: 90 }}</p>
        </article>
        <article class="lp-highlight">
          <div class="lp-highlight__icon">02</div>
          <h3 class="lp-highlight__title">主な魅力</h3>
          <p class="lp-highlight__text">{{ key_benefits | default: benefit_details | default: description_plain | truncate: 90 }}</p>
        </article>
      </div>
    </div>
  </section>

  {%- if product.description != blank -%}
    <section class="lp-section">
      <div class="page-width">
        <div class="lp-mid-copy">
          <p class="lp-section__eyebrow">Closing Message</p>
          <h2 class="lp-mid-copy__heading lp-serif">{{ short_value_prop | default: '商品について' }}</h2>
          <div class="lp-mid-copy__body lp-info__description rte">
            {{ product.description }}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="lp-section">
    <div class="page-width">
      <div class="lp-story">
        {%- if story_image != blank -%}
          {{
            story_image
            | image_url: width: 2200
            | image_tag:
              class: 'lp-story__image',
              widths: '750, 990, 1320, 1680, 2200',
              sizes: '100vw',
              loading: 'lazy',
              alt: section.settings.story_heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'lp-story__image placeholder-svg' }}
        {%- endif -%}
        <div class="lp-story__overlay">
          <div>
            <h2 class="lp-story__heading lp-serif">{{ story_heading_text }}</h2>
            <p class="lp-story__copy">{{ story_body_text | default: section.settings.story_text }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-section">
    <div class="page-width lp-size-guide">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Size Guide</p>
        <h2 class="lp-section__heading lp-serif">{{ dimensions | default: '商品のサイズ・仕様' }}</h2>
      </div>
      <table class="lp-size-guide__table">
        <thead>
          <tr>
            <th>項目</th>
            <th>内容</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>サイズ・寸法</td>
            <td>{{ dimensions | default: '商品サイズを登録するとここに表示されます。' }}</td>
          </tr>
          <tr>
            <td>素材</td>
            <td>{{ materials | default: '商品素材を登録するとここに表示されます。' }}</td>
          </tr>
          <tr>
            <td>お手入れ方法</td>
            <td>{{ care_instructions | default: 'お手入れ方法を登録するとここに表示されます。' }}</td>
          </tr>
          <tr>
            <td>補足情報</td>
            <td>{{ certifications | default: benefit_details | default: '補足情報を商品ごとに表示できます。' }}</td>
          </tr>
        </tbody>
      </table>
      <p class="lp-size-guide__note">{{ key_benefits | default: '商品ごとの詳細情報はメタフィールドから差し込みます。' }}</p>
    </div>
  </section>

  <section class="lp-section lp-section--alt">
    <div class="page-width">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Real Moments</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }}</h2>
      </div>
      {%- if has_moments -%}
        <div class="lp-moments">
          {%- assign rendered_moments = 0 -%}
          {%- for image in product.images offset: 1 limit: 6 -%}
            {%- assign rendered_moments = rendered_moments | plus: 1 -%}
            <figure class="lp-moments__item">
              {{
                image
                | image_url: width: 1200
                | image_tag:
                  class: 'lp-moments__image',
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  loading: 'lazy',
                  alt: image.alt | default: product.title
              }}
            </figure>
          {%- endfor -%}
          {%- if rendered_moments == 0 and product.featured_image != blank -%}
            <figure class="lp-moments__item">
              {{
                product.featured_image
                | image_url: width: 1200
                | image_tag:
                  class: 'lp-moments__image',
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  loading: 'lazy',
                  alt: product.title
              }}
            </figure>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  <section class="lp-section" id="reviews">
    <div class="page-width lp-reviews">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">Reviews</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }} Reviews</h2>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}
          <div {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="lp-reviews__widget">
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}">
          {{ product.metafields.judgeme.widget }}
        </div>
      </div>

      <div class="lp-reviews__fallback{% if review_count > 0 %} hidden{% endif %}" data-review-fallback>
        <a class="lp-button lp-button--secondary" href="#judgeme_product_reviews">最初のレビューを書く</a>
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--alt">
    <div class="page-width">
      <div class="lp-section__intro">
        <p class="lp-section__eyebrow">FAQ</p>
        <h2 class="lp-section__heading lp-serif">{{ product.title }} FAQ</h2>
      </div>
      <div class="lp-faq" data-faq-root>
        {%- if faq_items != blank -%}
          {%- for item in faq_items -%}
            <article class="lp-faq__item">
              <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
                <span>{{ item.question | default: item.title | escape }}</span>
                <span class="lp-faq__icon">+</span>
              </button>
              <div class="lp-faq__panel" data-faq-panel>
                <div class="lp-faq__panel-inner">{{ item.answer | default: item.content }}</div>
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>{{ product.title }} の特徴は何ですか？</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ key_benefits | default: description_plain | truncate: 140 }}</div>
            </div>
          </article>
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>サイズや仕様について教えてください。</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ dimensions | default: materials | default: '商品メタフィールドを登録すると、ここに仕様が表示されます。' }}</div>
            </div>
          </article>
          <article class="lp-faq__item">
            <button type="button" class="lp-faq__trigger" data-faq-trigger aria-expanded="false">
              <span>お手入れ方法は？</span>
              <span class="lp-faq__icon">+</span>
            </button>
            <div class="lp-faq__panel" data-faq-panel>
              <div class="lp-faq__panel-inner">{{ care_instructions | default: 'お手入れ方法を登録するとここに表示されます。' }}</div>
            </div>
          </article>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="lp-section lp-related">
    <div class="page-width">
      <product-recommendations
        data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.recommendations_limit }}"
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
      >
        {% if recommendations.performed and recommendations.products_count > 0 %}
          <h2 class="lp-related__heading lp-serif">{{ product.title }} とあわせて人気の商品</h2>
          <div class="lp-related__grid">
            {% assign skip_card_product_styles = false %}
            {% for recommendation in recommendations.products %}
              <div class="grid__item">
                {% render 'card-product',
                  card_product: recommendation,
                  media_aspect_ratio: 'square',
                  image_shape: 'default',
                  show_secondary_image: true,
                  show_vendor: false,
                  show_rating: false,
                  skip_styles: skip_card_product_styles
                %}
              </div>
              {% assign skip_card_product_styles = true %}
            {% endfor %}
          </div>
        {% endif %}
      </product-recommendations>
    </div>
  </section>

  <script type="application/json" data-variant-json>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "available": {{ variant.available | json }},
          "options": {{ variant.options | json }},
          "price": {{ variant.price | json }},
          "price_text": {{ variant.price | money | json }},
          "compare_at_price": {{ variant.compare_at_price | default: 0 | json }},
          "compare_at_price_text": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}""{% endif %},
          "featured_media_id": {{ variant.featured_media.id | default: nil | json }},
          "featured_image": {% if variant.featured_image != blank %}{{ variant.featured_image | image_url: width: 1800 | json }}{% else %}null{% endif %},
          "url": {{ product.url | append: '?variant=' | append: variant.id | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  <script>
    (() => {
      const section = document.getElementById('LPMainProduct-{{ section.id }}');
      if (!section) return;

      const variantData = JSON.parse(section.querySelector('[data-variant-json]').textContent);
      const productHasVariants = variantData.length > 0;
      const track = section.querySelector('[data-gallery-track]');
      const viewport = section.querySelector('[data-gallery-viewport]');
      const slides = Array.from(section.querySelectorAll('[data-gallery-slide]'));
      const thumbs = Array.from(section.querySelectorAll('[data-gallery-thumb]'));
      const thumbsTrack = section.querySelector('[data-thumbs-track]');
      const thumbPrevButton = section.querySelector('[data-thumb-prev]');
      const thumbNextButton = section.querySelector('[data-thumb-next]');
      const priceEl = section.querySelector('[data-current-price]');
      const compareEl = section.querySelector('[data-compare-price]');
      const atcButton = section.querySelector('#ProductSubmitButton-{{ section.id }}');
      const atcLabel = section.querySelector('[data-atc-label]');
      const buyNowButton = section.querySelector('[data-buy-now-button]');
      const variantInputs = Array.from(section.querySelectorAll('[data-variant-id-input], [data-buy-now-variant-input]'));
      const qtyInput = section.querySelector('[data-qty-input]');
      const qtyHiddenInputs = Array.from(section.querySelectorAll('[data-qty-hidden-input], [data-buy-now-qty-input]'));
      const optionButtons = Array.from(section.querySelectorAll('[data-option-button]'));
      const reviewWidget = section.querySelector('#judgeme_product_reviews');
      const reviewFallback = section.querySelector('[data-review-fallback]');
      let currentIndex = Math.max(
        0,
        slides.findIndex((slide) => String(slide.dataset.mediaId) === String({{ active_media_id | default: 0 | json }}))
      );
      let thumbStartIndex = 0;
      const visibleThumbCount = 4;

      const isMobile = () => window.matchMedia('(max-width: 767px)').matches;
      const normalizeColorKey = (value = '') => {
        const normalized = String(value).toLowerCase();
        if (normalized.includes('beige') || normalized.includes('ベージュ')) return 'beige';
        if (normalized.includes('gray') || normalized.includes('grey') || normalized.includes('グレー')) return 'gray';
        return '';
      };
      const colorLabelMap = {
        beige: 'ベージュ',
        gray: 'グレー',
      };

      const setQuantity = (value) => {
        const nextValue = Math.max(1, Number(value) || 1);
        qtyInput.value = nextValue;
        qtyHiddenInputs.forEach((input) => {
          input.value = nextValue;
        });
      };

      const syncThumbCarousel = () => {
        if (!thumbsTrack || isMobile()) return;
        const maxStartIndex = Math.max(thumbs.length - visibleThumbCount, 0);
        thumbStartIndex = Math.max(0, Math.min(thumbStartIndex, maxStartIndex));
        const thumbStep = 90;
        thumbsTrack.style.transform = `translateX(-${thumbStartIndex * thumbStep}px)`;
        if (thumbPrevButton) thumbPrevButton.disabled = thumbStartIndex === 0;
        if (thumbNextButton) thumbNextButton.disabled = thumbStartIndex >= maxStartIndex;
      };

      const ensureActiveThumbVisible = (index) => {
        if (isMobile()) return;
        if (index < thumbStartIndex) {
          thumbStartIndex = index;
        } else if (index >= thumbStartIndex + visibleThumbCount) {
          thumbStartIndex = index - visibleThumbCount + 1;
        }
        syncThumbCarousel();
      };

      const setActiveSlide = (index, syncScroll = true) => {
        if (!slides.length) return;
        currentIndex = Math.max(0, Math.min(index, slides.length - 1));
        thumbs.forEach((thumb, thumbIndex) => {
          thumb.classList.toggle('is-active', thumbIndex === currentIndex);
        });
        ensureActiveThumbVisible(currentIndex);
        if (isMobile()) {
          if (syncScroll) {
            viewport.scrollTo({
              left: viewport.clientWidth * currentIndex,
              behavior: 'smooth',
            });
          }
          track.style.transform = 'translateX(0)';
        } else {
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
      };

      const selectedOptions = productHasVariants
        ? (variantData.find((variant) => variant.id === {{ selected_variant.id | json }}) || variantData[0]).options.slice()
        : [];

      const findVariant = () =>
        variantData.find((variant) =>
          variant.options.every((optionValue, optionIndex) => optionValue === selectedOptions[optionIndex])
        );

      const updateOptionAvailability = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const buttonValue = button.dataset.optionValue;
          const isColorButton = button.dataset.optionKind === 'color';
          const colorKey = button.dataset.colorKey;
          const matches = variantData.some((variant) => {
            if (!variant.available) return false;
            if (isColorButton) {
              if (normalizeColorKey(variant.options[buttonIndex]) !== colorKey) return false;
            } else if (variant.options[buttonIndex] !== buttonValue) {
              return false;
            }
            return variant.options.every((optionValue, optionIndex) => {
              if (optionIndex === buttonIndex) return true;
              return optionValue === selectedOptions[optionIndex];
            });
          });
          button.disabled = !matches;
          button.classList.toggle('is-unavailable', !matches);
        });
      };

      const updateOptionUi = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const active =
            button.dataset.optionKind === 'color'
              ? normalizeColorKey(selectedOptions[buttonIndex]) === button.dataset.colorKey
              : selectedOptions[buttonIndex] === button.dataset.optionValue;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        section.querySelectorAll('[data-option-group]').forEach((group) => {
          const label = group.querySelector('[data-option-value-label]');
          const index = Number(group.dataset.optionIndex);
          if (label) {
            const activeColorKey = normalizeColorKey(selectedOptions[index]);
            label.textContent = activeColorKey && colorLabelMap[activeColorKey] ? colorLabelMap[activeColorKey] : selectedOptions[index] || '';
          }
        });
      };

      const updateForVariant = (variant) => {
        if (!variant) return;
        variantInputs.forEach((input) => {
          input.value = variant.id;
        });

        if (priceEl) priceEl.textContent = variant.price_text;
        if (compareEl) {
          if (variant.compare_at_price > variant.price && variant.compare_at_price_text) {
            compareEl.textContent = variant.compare_at_price_text;
            compareEl.classList.remove('hidden');
          } else {
            compareEl.textContent = '';
            compareEl.classList.add('hidden');
          }
        }

        const isAvailable = Boolean(variant.available);
        if (atcButton) atcButton.disabled = !isAvailable;
        if (buyNowButton) buyNowButton.disabled = !isAvailable;
        if (atcLabel) atcLabel.textContent = isAvailable ? 'カートに追加' : '売り切れ';

        if (variant.featured_media_id) {
          const variantIndex = slides.findIndex((slide) => String(slide.dataset.mediaId) === String(variant.featured_media_id));
          if (variantIndex >= 0) setActiveSlide(variantIndex, true);
        }

        if (variant.url && window.history.replaceState) {
          window.history.replaceState({}, '', variant.url);
        }

        updateOptionUi();
        updateOptionAvailability();
      };

      optionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (button.disabled) return;
          const optionIndex = Number(button.dataset.optionIndex);
          let variant = null;
          if (button.dataset.optionKind === 'color') {
            const colorKey = button.dataset.colorKey;
            variant =
              variantData.find((item) => normalizeColorKey(item.options[optionIndex]) === colorKey && item.available) ||
              variantData.find((item) => normalizeColorKey(item.options[optionIndex]) === colorKey);
            if (variant) {
              selectedOptions.splice(0, selectedOptions.length, ...variant.options);
            }
          } else {
            selectedOptions[optionIndex] = button.dataset.optionValue;
            variant = findVariant();
          }
          if (variant) updateForVariant(variant);
        });
      });

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          setActiveSlide(Number(thumb.dataset.index), true);
        });
      });

      thumbPrevButton?.addEventListener('click', () => {
        thumbStartIndex = Math.max(thumbStartIndex - 1, 0);
        syncThumbCarousel();
      });

      thumbNextButton?.addEventListener('click', () => {
        thumbStartIndex = Math.min(thumbStartIndex + 1, Math.max(thumbs.length - visibleThumbCount, 0));
        syncThumbCarousel();
      });

      if (viewport && slides.length > 1) {
        let scrollTimer = null;
        viewport.addEventListener(
          'scroll',
          () => {
            if (!isMobile()) return;
            window.clearTimeout(scrollTimer);
            scrollTimer = window.setTimeout(() => {
              const nextIndex = Math.round(viewport.scrollLeft / Math.max(viewport.clientWidth, 1));
              setActiveSlide(nextIndex, false);
            }, 60);
          },
          { passive: true }
        );
      }

      section.querySelector('[data-qty-decrease]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) - 1);
      });

      section.querySelector('[data-qty-increase]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) + 1);
      });

      qtyInput?.addEventListener('input', () => setQuantity(qtyInput.value));
      qtyInput?.addEventListener('blur', () => setQuantity(qtyInput.value));

      section.querySelectorAll('[data-faq-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const item = trigger.closest('.lp-faq__item');
          const panel = item?.querySelector('[data-faq-panel]');
          const isOpen = item.classList.contains('is-open');
          section.querySelectorAll('.lp-faq__item').forEach((faqItem) => {
            faqItem.classList.remove('is-open');
            const faqTrigger = faqItem.querySelector('[data-faq-trigger]');
            const faqPanel = faqItem.querySelector('[data-faq-panel]');
            if (faqTrigger) faqTrigger.setAttribute('aria-expanded', 'false');
            if (faqPanel) faqPanel.style.maxHeight = '0px';
          });
          if (!isOpen && item && panel) {
            item.classList.add('is-open');
            trigger.setAttribute('aria-expanded', 'true');
            panel.style.maxHeight = `${panel.scrollHeight}px`;
          }
        });
      });

      if (reviewWidget && reviewFallback) {
        const toggleReviewFallback = () => {
          const hasReviewMarkup =
            reviewWidget.querySelector('.jdgm-rev, .jdgm-all-reviews-page, .jdgm-histogram, .jdgm-row-stars') ||
            (reviewWidget.textContent || '').replace(/\s+/g, '').length > 0;
          reviewFallback.classList.toggle('hidden', Boolean(hasReviewMarkup));
        };

        toggleReviewFallback();
        new MutationObserver(toggleReviewFallback).observe(reviewWidget, {
          childList: true,
          subtree: true,
          characterData: true,
        });
      }

      window.addEventListener('resize', () => {
        setActiveSlide(currentIndex, false);
        syncThumbCarousel();
      });

      setQuantity(qtyInput?.value || 1);
      setActiveSlide(currentIndex, true);
      syncThumbCarousel();
      if (productHasVariants) {
        updateOptionUi();
        updateOptionAvailability();
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "LP Main Product",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "ストーリーバナー画像"
    },
    {
      "type": "inline_richtext",
      "id": "story_heading",
      "label": "ストーリーバナー見出し",
      "default": "いつでも、どこでも、一緒に。"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "ストーリーバナー本文",
      "default": "PAWLUXは、ペットとの毎日をもっと上質にするために生まれました。"
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "関連商品数",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
