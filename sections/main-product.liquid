      .lp-product--{{ section.id }} .lp-hero {
        padding: 1.6rem 0 4.8rem;
      }

      .lp-product--{{ section.id }} .lp-gallery {
        gap: 1.2rem;
      }

      .lp-product--{{ section.id }} .lp-gallery__viewport {
        border-radius: 2rem;
        box-shadow: 0 14px 34px rgba(26, 26, 26, 0.08);
      }

      .lp-product--{{ section.id }} .lp-info {
        padding: 2.4rem 2rem;
        border-radius: 2rem;
        background: var(--lp-alt);
        box-shadow: 0 12px 30px rgba(26, 26, 26, 0.05);
      }

      .lp-product--{{ section.id }} .lp-info__brand {
        margin-bottom: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-info__title {
        max-width: 100%;
        font-size: clamp(3rem, 9vw, 4rem);
        line-height: 1.08;
        letter-spacing: -0.01em;
      }

      .lp-product--{{ section.id }} .lp-info__rating {
        margin-top: 1.4rem;
      }

      .lp-product--{{ section.id }} .lp-info__price {
        margin-top: 1.4rem;
        gap: 0.6rem 1.2rem;
      }

      .lp-product--{{ section.id }} .lp-info__price-current {
        font-size: clamp(3rem, 9vw, 3.8rem);
      }

      .lp-product--{{ section.id }} .lp-info__price-compare {
        font-size: 1.5rem;
      }

      .lp-product--{{ section.id }} .lp-hero-copy {
        margin-top: 1.6rem;
        gap: 1rem;
      }

      .lp-product--{{ section.id }} .lp-hero-copy__concept {
        font-size: 1.55rem;
        line-height: 1.75;
      }

      .lp-product--{{ section.id }} .lp-hero-copy__tagline,
      .lp-product--{{ section.id }} .lp-info__description {
        font-size: 1.35rem;
        line-height: 1.85;
      }

      .lp-product--{{ section.id }} .lp-option-group,
      .lp-product--{{ section.id }} .lp-quantity {
        margin-top: 2rem;
      }

      .lp-product--{{ section.id }} .lp-option-group__label-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.4rem;
      }

      .lp-product--{{ section.id }} .lp-option-group__buttons,
      .lp-product--{{ section.id }} .lp-swatch-wrap {
        gap: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-option-button {
        min-height: 4.2rem;
        padding: 0.8rem 1.4rem;
        font-size: 1.35rem;
      }

      .lp-product--{{ section.id }} .lp-swatch {
        min-height: 4.2rem;
        padding: 0.4rem 1rem 0.4rem 0.4rem;
      }

      .lp-product--{{ section.id }} .lp-swatch__label {
        font-size: 1.25rem;
      }

      .lp-product--{{ section.id }} .lp-quantity__control {
        width: 100%;
        grid-template-columns: 4.4rem minmax(0, 1fr) 4.4rem;
      }

      .lp-product--{{ section.id }} .lp-cta {
        margin-top: 2.4rem;
        gap: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-gallery__thumbs {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-gallery__thumb-carousel {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-gallery__viewport {
        overflow-x: auto;
        scroll-snap-type: x mandatory;
      }

      .lp-product--{{ section.id }} .lp-gallery__track {
        transition: none;
      }

      .lp-product--{{ section.id }} .lp-highlights,
      .lp-product--{{ section.id }} .lp-related__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .lp-product--{{ section.id }} .lp-related__heading {
        margin-bottom: 2.2rem;
        font-size: clamp(2.4rem, 7.5vw, 3.2rem);
        line-height: 1.15;
      }

      .lp-product--{{ section.id }} .lp-related__grid .card__information {
        padding: 1.2rem 0.8rem 0;
      }

      .lp-product--{{ section.id }} .lp-related__grid .card__heading {
        font-size: 1.3rem;
        line-height: 1.45;
      }

      .lp-product--{{ section.id }} .lp-related__grid .price {
        font-size: 1.3rem;
        gap: 0.2rem 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-trust {
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem 1rem;
        margin-top: 2rem;
        padding: 1.2rem 1.4rem;
        border-radius: 1.6rem;
        background: rgba(255, 255, 255, 0.78);
        white-space: normal;
      }

      .lp-product--{{ section.id }} .lp-trust__divider {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-trust__item {
        flex: 0 1 calc(50% - 0.8rem);
        justify-content: center;
        text-align: center;
        white-space: normal;
      }

      .lp-product--{{ section.id }} .lp-trust__text {
        white-space: normal;
      }

      .lp-product--{{ section.id }} .payment-icons-wrapper {
        padding: 1.2rem 1.4rem;
      }

      .lp-product--{{ section.id }} .payment-icons-label {
        line-height: 1.5;
      }

      .lp-product--{{ section.id }} .lp-button {
        min-height: 5rem;
        padding: 1.3rem 1.8rem;
        font-size: 1.3rem;
        letter-spacing: 0.06em;
      }

      .lp-product--{{ section.id }} .lp-highlight {
        padding: 2rem 1.6rem;
      }

      .lp-product--{{ section.id }} .lp-size-guide {
        overflow-x: visible;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table {
        width: 100%;
        min-width: 0;
        margin-top: 2.4rem;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        box-shadow: none;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table thead {
        display: none;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table tbody {
        display: grid;
        gap: 1.2rem;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table tr {
        display: block;
        overflow: hidden;
        border-radius: 1.8rem;
        background: #fff;
        box-shadow: 0 10px 24px rgba(26, 26, 26, 0.05);
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.6rem;
        width: 100%;
        padding: 1.4rem 1.6rem;
        text-align: left;
        font-size: 1.35rem;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td::before {
        content: attr(data-label);
        flex: 0 0 7.2rem;
        color: var(--lp-muted);
        font-size: 1.15rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td:first-child {
        background: var(--lp-alt);
        font-weight: 600;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td:first-child::before {
        color: var(--lp-text);
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td[colspan] {
        display: block;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table td[colspan]::before {
        display: block;
        margin-bottom: 0.8rem;
      }

      .lp-product--{{ section.id }} .lp-size-guide__table tr:last-child td:last-child {
        border-bottom: 0;
      }

      .lp-product--{{ section.id }} .lp-moments {
        column-count: 1;
      }

      .lp-product--{{ section.id }} .lp-story {
        min-height: 38rem;
      }

      .lp-product--{{ section.id }} .lp-button {
        min-height: 4.8rem;
      }

      .lp-product--{{ section.id }} .lp-color-preview {
        display: none;
      }
    }
  </style>

  <div id="product-raw-desc" style="display:none;">
    {{ product.description }}
  </div>

  <div class="page-width lp-hero">
    <div class="lp-hero__grid">
      <div class="lp-gallery" data-lp-gallery>
        <div class="lp-gallery__viewport" data-gallery-viewport>
          <div class="lp-gallery__track" data-gallery-track>
            {%- if product.images.size > 0 -%}
              {%- for image in product.images -%}
                <div
                  class="lp-gallery__slide"
                  data-gallery-slide
                  data-media-id="{{ image.id }}"
                  aria-label="{{ product.title | escape }} image {{ forloop.index }}"
                >
                  {{
                    image
                    | image_url: width: 1800
                    | image_tag:
                      class: 'lp-gallery__image',
                      widths: '540, 720, 960, 1200, 1600, 1800',
                      sizes: '(min-width: 750px) 50vw, 100vw',
                      loading: 'eager',
                      alt: image.alt | default: product.title
                  }}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="lp-gallery__slide">
                {{ 'product-1' | placeholder_svg_tag: 'lp-gallery__image placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- if product.images.size > 1 -%}
          <div class="lp-gallery__thumb-carousel" aria-label="Product thumbnails">
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-prev aria-label="左へ">◀</button>
            <div class="lp-gallery__thumbs-viewport" data-thumbs-viewport>
              <div class="lp-gallery__thumbs" data-thumbs-track>
                {%- for image in product.images -%}
                  <button
                    type="button"
                    class="lp-gallery__thumb{% if image.id == active_media_id or active_media_id == blank and forloop.first %} is-active{% endif %}"
                    data-gallery-thumb
                    data-index="{{ forloop.index0 }}"
                    data-media-id="{{ image.id }}"
                    aria-label="画像 {{ forloop.index }} を表示"
                  >
                    {{
                      image
                      | image_url: width: 400
                      | image_tag:
                        class: 'lp-gallery__thumb-image',
                        widths: '80, 120, 160, 240, 320, 400',
                        sizes: '80px',
                        loading: 'lazy',
                        alt: image.alt | default: product.title
                    }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
            <button type="button" class="lp-gallery__thumb-nav" data-thumb-next aria-label="右へ">▶</button>
          </div>
        {%- endif -%}

      </div>

      <div class="lp-info">
        <p class="lp-info__brand">pawlux</p>
        <h1 class="lp-info__title lp-serif">{{ product.title }}</h1>

        <div class="lp-info__rating">
          <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
            {{ product.metafields.judgeme.badge }}
          </div>
        </div>

        <div class="lp-info__price" id="LPPrice-{{ section.id }}">
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="lp-info__price-compare" data-compare-price>
              {{ selected_variant.compare_at_price | money }}
            </span>
          {%- else -%}
            <span class="lp-info__price-compare hidden" data-compare-price></span>
          {%- endif -%}
          <span class="lp-info__price-current" data-current-price>{{ selected_variant.price | money }}</span>
        </div>

        {%- if show_concept or show_tagline -%}
          <div class="lp-hero-copy">
            {%- if show_concept -%}
              <p class="lp-hero-copy__concept">{{ concept }}</p>
            {%- endif -%}
            {%- if show_tagline -%}
              <p class="lp-hero-copy__tagline">{{ tagline }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign option_name_downcase = option.name | downcase -%}
            {%- assign is_color_option = false -%}
            {%- assign is_size_option = false -%}
            {%- assign is_ships_from_option = false -%}
            {%- if option_name_downcase contains 'color'
              or option_name_downcase contains 'colour'
              or option_name_downcase contains 'カラー'
              or option_name_downcase contains '色'
            -%}
              {%- assign is_color_option = true -%}
            {%- endif -%}
            {%- if option_name_downcase contains 'size'
              or option_name_downcase contains '容量'
              or option_name_downcase contains 'volume'
            -%}
              {%- assign is_size_option = true -%}
            {%- endif -%}
            {%- if option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM'
            -%}
              {%- assign is_ships_from_option = true -%}
            {%- endif -%}

            {% unless option.name == 'Ships From'
              or option.name == 'ships from'
              or option.name == 'SHIPS FROM' %}
              <div class="lp-option-group{% if is_ships_from_option %} ships-from-option{% endif %}{% if is_color_option %} lp-option-group--color{% endif %}" data-option-group data-option-index="{{ forloop.index0 }}" data-option-group-kind="{% if is_color_option %}color{% elsif is_size_option %}size{% else %}default{% endif %}">
                <div class="lp-option-group__label-row">
                  <span class="lp-option-group__label">
                    {% if is_color_option %}
                      {{ option.name | upcase }}:
                    {% else %}
                      {{ option.name }}
                    {% endif %}
                  </span>
                  <span class="lp-option-group__value{% if is_color_option %} is-color-label{% endif %}" data-option-value-label>
                    {% if is_color_option %}
                      {{ option.selected_value }}
                    {% else %}
                      {{ option.selected_value }}
                    {% endif %}
                  </span>
                </div>

                {%- if is_color_option -%}
                  <div class="lp-swatch-wrap">
                    {% for value in option.values %}
                      {% assign swatch_key = value | downcase %}
                      {% assign swatch_color = '#d8d8d8' %}
                      {% assign color_label = value %}
                      {% if swatch_key contains "beige" or swatch_key contains "ベージュ" %}
                        {% assign swatch_color = "#E8DCC8" %}
                      {% elsif swatch_key contains "gray" or swatch_key contains "grey" or swatch_key contains "グレー" %}
                        {% assign swatch_color = "#9E9E9E" %}
                      {% elsif swatch_key contains "green" or swatch_key contains "グリーン" or swatch_key contains "緑" %}
                        {% assign swatch_color = "#5B8C51" %}
                      {% elsif swatch_key contains "blue" or swatch_key contains "navy" or swatch_key contains "ブルー" or swatch_key contains "青" or swatch_key contains "ネイビー" %}
                        {% assign swatch_color = "#4B6EA9" %}
                      {% elsif swatch_key contains "pink" or swatch_key contains "ピンク" %}
                        {% assign swatch_color = "#E8A5B8" %}
                      {% elsif swatch_key contains "red" or swatch_key contains "レッド" or swatch_key contains "赤" %}
                        {% assign swatch_color = "#C95A5A" %}
                      {% elsif swatch_key contains "black" or swatch_key contains "ブラック" or swatch_key contains "黒" %}
                        {% assign swatch_color = "#2F2F2F" %}
                      {% elsif swatch_key contains "white" or swatch_key contains "ホワイト" or swatch_key contains "白" %}
                        {% assign swatch_color = "#F5F5F5" %}
                      {% elsif swatch_key contains "brown" or swatch_key contains "ブラウン" or swatch_key contains "茶" %}
                        {% assign swatch_color = "#8A624A" %}
                      {% elsif swatch_key contains "yellow" or swatch_key contains "イエロー" or swatch_key contains "黄" %}
                        {% assign swatch_color = "#E5C24A" %}
                      {% elsif swatch_key contains "orange" or swatch_key contains "オレンジ" %}
                        {% assign swatch_color = "#D88742" %}
                      {% elsif swatch_key contains "purple" or swatch_key contains "パープル" or swatch_key contains "紫" %}
                        {% assign swatch_color = "#8A69C8" %}
                      {% elsif swatch_key contains "cream" or swatch_key contains "ivory" or swatch_key contains "クリーム" or swatch_key contains "アイボリー" %}
                        {% assign swatch_color = "#F3E8CF" %}
                      {% endif %}
                      <button
                        type="button"
                        class="lp-swatch variant-option{% if option.selected_value == value %} is-active{% endif %}"
                        data-option-button
                        data-option-kind="color"
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        data-option-label="{{ color_label | escape }}"
                        data-preview-image=""
                        data-preview-label="{{ color_label | escape }}"
                        data-option-name="{{ option.name }}"
                        aria-label="{{ option.name }} {{ color_label }}"
                        aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                      >
                        <span class="lp-swatch__fill" style="--swatch-color: {{ swatch_color }};"></span>
                        <span class="lp-swatch__label">{{ color_label }}</span>
                      </button>
                    {% endfor %}
                  </div>
                  <div class="lp-color-preview" data-color-preview aria-hidden="true">
                    <div class="lp-color-preview__image-wrap">
                      <img
                        class="lp-color-preview__image"
                        src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
                        alt=""
                        loading="lazy"
                        data-color-preview-image
                      >
                    </div>
                    <div class="lp-color-preview__meta">
                      <span class="lp-color-preview__eyebrow">Color preview</span>
                      <span class="lp-color-preview__label" data-color-preview-label></span>
                    </div>
                  </div>
                {%- else -%}
                  <div class="lp-option-group__buttons">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="lp-option-button variant-option{% if option.selected_value == value %} is-active{% endif %}"
                        data-option-button
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        data-option-name="{{ option.name }}"
                        aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {% endunless %}
          {%- endfor -%}
        {%- endunless -%}

        <div class="lp-quantity">
          <div class="lp-option-group__label-row">
            <span class="lp-option-group__label">数量</span>
          </div>
          <div class="lp-quantity__control">
            <button type="button" class="lp-quantity__button" data-qty-decrease aria-label="数量を減らす">-</button>
            <input
              class="lp-quantity__input"
              type="number"
              min="1"
              step="1"
              value="1"
              inputmode="numeric"
              data-qty-input
              aria-label="数量"
            >
            <button type="button" class="lp-quantity__button" data-qty-increase aria-label="数量を増やす">+</button>
          </div>
        </div>

        <div class="lp-cta">
          <product-form data-hide-errors="false">
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id-input>
              <input type="hidden" name="quantity" value="1" data-qty-hidden-input>
              <button
                id="ProductSubmitButton-{{ section.id }}"
                type="submit"
                name="add"
                class="lp-button lp-button--primary"
                {% unless selected_variant.available %}disabled{% endunless %}
              >
                <span data-atc-label>
                  {% if selected_variant.available %}
                    カートに追加
                  {% else %}
                    売り切れ
                  {% endif %}
                </span>
                <div class="loading__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
              <div class="product-form__error-message-wrapper lp-form-error" hidden>
                <span class="product-form__error-message"></span>
              </div>
            {%- endform -%}
          </product-form>

          {%- form 'product', product, id: buy_now_form_id, class: 'form lp-buy-now-form' -%}
            <input type="hidden" name="id" value="{{ selected_variant.id }}" data-buy-now-variant-input>
            <input type="hidden" name="quantity" value="1" data-buy-now-qty-input>
            <button
              type="submit"
              name="checkout"
              class="lp-button lp-button--secondary"
              {% unless selected_variant.available %}disabled{% endunless %}
              data-buy-now-button
            >
              今すぐ購入
            </button>
          {%- endform -%}

          <div class="payment-icons-wrapper">
            <p class="payment-icons-label">以下の方法でお支払いいただけます</p>
            <div class="payment-icons-list">
              {% for type in shop.enabled_payment_types %}
                <img
                  src="{{ type | payment_type_img_url }}"
                  alt="{{ type }}"
                  class="payment-icon"
                  loading="lazy"
                >
              {% endfor %}
            </div>
          </div>
        </div>

        {%- if show_trust -%}
          <div class="lp-trust">
            {%- if show_shipping_time -%}
              <div class="lp-trust__item">
                <span class="lp-trust__icon" aria-hidden="true">⌁</span>
                <span class="lp-trust__text">{{ shipping_time }}</span>
              </div>
            {%- endif -%}
            {%- if show_shipping_time and show_return_policy -%}
              <span class="lp-trust__divider" aria-hidden="true">|</span>
            {%- endif -%}
            {%- if show_return_policy -%}
              <div class="lp-trust__item">
                <span class="lp-trust__icon" aria-hidden="true">↺</span>
                <span class="lp-trust__text">{{ return_policy }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if feature_count > 0 -%}
    <section class="lp-section lp-section--alt">
      <div class="page-width">
        <div class="lp-section__intro">
          <p class="lp-section__eyebrow">Feature Highlights</p>
          <h2 class="lp-section__heading lp-serif">{{ feature_section_heading }}</h2>
        </div>
        <div class="lp-highlights" style="--lp-highlight-columns: {{ feature_count }};">
          {%- if show_feature_1 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">01</div>
              <h3 class="lp-highlight__title">{{ feature_1_title }}</h3>
              <p class="lp-highlight__text">{{ feature_1_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_2 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">02</div>
              <h3 class="lp-highlight__title">{{ feature_2_title }}</h3>
              <p class="lp-highlight__text">{{ feature_2_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_3 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">03</div>
              <h3 class="lp-highlight__title">{{ feature_3_title }}</h3>
              <p class="lp-highlight__text">{{ feature_3_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_4 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">04</div>
              <h3 class="lp-highlight__title">{{ feature_4_title }}</h3>
              <p class="lp-highlight__text">{{ feature_4_desc }}</p>
            </article>
          {%- endif -%}
          {%- if show_feature_5 -%}
            <article class="lp-highlight">
              <div class="lp-highlight__icon">05</div>
              <h3 class="lp-highlight__title">{{ feature_5_title }}</h3>
