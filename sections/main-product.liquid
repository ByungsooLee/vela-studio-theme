<section
  id="LPMainProduct-{{ section.id }}"
  class="lp-product lp-product--{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap');

    .lp-product--{{ section.id }} {
      --lp-bg: #ffffff;
      --lp-alt: #f8f7f4;
      --lp-text: #1a1a1a;
      --lp-border: rgba(26, 26, 26, 0.14);
      --lp-muted: rgba(26, 26, 26, 0.64);
      --lp-accent: #1a1a1a;
      --lp-sale: #b23a3a;
      --lp-radius: 2.4rem;
      --lp-shadow: 0 24px 60px rgba(26, 26, 26, 0.08);
      background: var(--lp-bg);
      color: var(--lp-text);
      font-family: 'Noto Sans JP', sans-serif;
    }

    .lp-product--{{ section.id }} *,
    .lp-product--{{ section.id }} *::before,
    .lp-product--{{ section.id }} *::after {
      box-sizing: border-box;
    }

    .lp-product--{{ section.id }} .page-width {
      max-width: 138rem;
    }

    .lp-product--{{ section.id }} .lp-serif {
      font-family: 'Cormorant Garamond', serif;
      letter-spacing: 0.01em;
    }

    .lp-product--{{ section.id }} .lp-section {
      padding: 8rem 0;
    }

    .lp-product--{{ section.id }} .lp-section--alt {
      background: var(--lp-alt);
    }

    .lp-product--{{ section.id }} .lp-section__intro {
      max-width: 72rem;
      margin: 0 auto 3.6rem;
      text-align: center;
    }

    .lp-product--{{ section.id }} .lp-section__eyebrow {
      margin: 0 0 1rem;
      font-size: 1.2rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-section__heading {
      margin: 0;
      font-size: clamp(3.2rem, 5vw, 5.4rem);
      line-height: 0.96;
    }

    .lp-product--{{ section.id }} .lp-section__subtext {
      margin: 1.4rem 0 0;
      font-size: 1.5rem;
      line-height: 1.8;
      color: var(--lp-muted);
    }

    .lp-product--{{ section.id }} .lp-hero {
      padding: 5.6rem 0 8rem;
    }

    .lp-product--{{ section.id }} .lp-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
      gap: 4.8rem;
      align-items: start;
    }

    .lp-product--{{ section.id }} .lp-gallery {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.6rem;
      align-items: start;
    }

    .lp-product--{{ section.id }} .lp-gallery__viewport {
      position: relative;
      overflow: hidden;
      border-radius: var(--lp-radius);
      background: #f1f1ef;
      box-shadow: var(--lp-shadow);
    }

    .lp-product--{{ section.id }} .lp-gallery__track {
      display: flex;
      transition: transform 0.45s ease;
      will-change: transform;
    }

    .lp-product--{{ section.id }} .lp-gallery__slide {
      flex: 0 0 100%;
      position: relative;
      aspect-ratio: 1 / 1;
      scroll-snap-align: start;
      background: #f1f1ef;
    }

    .lp-product--{{ section.id }} .lp-gallery__image,
    .lp-product--{{ section.id }} .lp-story__image,
    .lp-product--{{ section.id }} .lp-moments__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-carousel {
      display: grid;
      grid-template-columns: 3.6rem minmax(0, 1fr) 3.6rem;
      align-items: center;
      gap: 1rem;
      max-width: 43rem;
      margin: 0 auto;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-nav {
      width: 3.6rem;
      height: 3.2rem;
      border: 1px solid rgba(26, 26, 26, 0.14);
      border-radius: 999px;
      background: #fff;
      color: var(--lp-text);
      cursor: pointer;
      font-size: 1.3rem;
      line-height: 1;
      transition: opacity 0.2s ease, border-color 0.2s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb-nav[disabled] {
      opacity: 0.35;
      cursor: default;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs-viewport {
      width: 100%;
      height: 8rem;
      overflow: hidden;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      width: max-content;
      transition: transform 0.3s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumbs-grid {
      display: none !important;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb {
      border: 1px solid transparent;
      border-radius: 1.6rem;
      padding: 0;
      background: transparent;
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .lp-product--{{ section.id }} .lp-gallery__thumb:hover {
