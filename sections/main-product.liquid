    ]
  </script>

  <script>
    window.productData = {
      variants: {{ product.variants | json }},
      options: {{ product.options_with_values | json }}
    };
  </script>

  <script>
    (() => {
      const section = document.getElementById('LPMainProduct-{{ section.id }}');
      if (!section) return;

      const parseNumericOptionValue = (value = '') => {
        const match = String(value).replace(/,/g, '').match(/-?\d+(?:\.\d+)?/);
        return match ? Number(match[0]) : Number.POSITIVE_INFINITY;
      };

      section.querySelectorAll('[data-option-group-kind="size"] .lp-option-group__buttons').forEach((container) => {
        const buttons = Array.from(container.querySelectorAll('[data-option-button]'));
        buttons
          .map((button, index) => ({
            button,
            index,
            numericValue: parseNumericOptionValue(button.dataset.optionValue || button.textContent || ''),
          }))
          .sort((a, b) => {
            if (a.numericValue === b.numericValue) return a.index - b.index;
            return a.numericValue - b.numericValue;
          })
          .forEach(({ button }) => container.appendChild(button));
      });

      const variantData = JSON.parse(section.querySelector('[data-variant-json]').textContent);
      const productOptions =
        window.productData && Array.isArray(window.productData.options) ? window.productData.options : [];
      const productHasVariants = variantData.length > 0;
      const track = section.querySelector('[data-gallery-track]');
      const viewport = section.querySelector('[data-gallery-viewport]');
      const slides = Array.from(section.querySelectorAll('[data-gallery-slide]'));
      const thumbs = Array.from(section.querySelectorAll('[data-gallery-thumb]'));
      const thumbsTrack = section.querySelector('[data-thumbs-track]');
      const thumbPrevButton = section.querySelector('[data-thumb-prev]');
      const thumbNextButton = section.querySelector('[data-thumb-next]');
      const priceEl = section.querySelector('[data-current-price]');
      const compareEl = section.querySelector('[data-compare-price]');
      const atcButton = section.querySelector('#ProductSubmitButton-{{ section.id }}');
      const atcLabel = section.querySelector('[data-atc-label]');
      const buyNowButton = section.querySelector('[data-buy-now-button]');
      const variantInputs = Array.from(section.querySelectorAll('[data-variant-id-input], [data-buy-now-variant-input]'));
      const qtyInput = section.querySelector('[data-qty-input]');
      const qtyHiddenInputs = Array.from(section.querySelectorAll('[data-qty-hidden-input], [data-buy-now-qty-input]'));
      const optionButtons = Array.from(section.querySelectorAll('[data-option-button]'));
      const colorButtons = optionButtons.filter((button) => button.dataset.optionKind === 'color');
      const colorPreview = section.querySelector('[data-color-preview]');
      const colorPreviewImage = colorPreview?.querySelector('[data-color-preview-image]');
      const colorPreviewLabel = colorPreview?.querySelector('[data-color-preview-label]');
      const colorPreviewGroup = colorPreview?.closest('[data-option-group]');
      const reviewWidget = section.querySelector('#judgeme_product_reviews');
      const reviewFallback = section.querySelector('[data-review-fallback]');
      let currentIndex = Math.max(
        0,
        slides.findIndex((slide) => String(slide.dataset.mediaId) === String({{ active_media_id | default: 0 | json }}))
      );
      let thumbStartIndex = 0;
      const visibleThumbCount = 4;

      const isMobile = () => window.matchMedia('(max-width: 749px)').matches;
      const isShipsFromOptionName = (value = '') => {
        const normalized = String(value).trim().toLowerCase();
        return normalized === 'ships from';
      };
      const hiddenOptionIndexes = productOptions.reduce((indexes, option, index) => {
        if (isShipsFromOptionName(option?.name)) indexes.push(index);
        return indexes;
      }, []);
      const visibleOptionIndexes = productOptions.reduce((indexes, _option, index) => {
        if (!hiddenOptionIndexes.includes(index)) indexes.push(index);
        return indexes;
      }, []);

      const setQuantity = (value) => {
        const nextValue = Math.max(1, Number(value) || 1);
        qtyInput.value = nextValue;
        qtyHiddenInputs.forEach((input) => {
          input.value = nextValue;
        });
      };

      const syncThumbCarousel = () => {
        if (!thumbsTrack || isMobile()) return;
        const maxStartIndex = Math.max(thumbs.length - visibleThumbCount, 0);
        thumbStartIndex = Math.max(0, Math.min(thumbStartIndex, maxStartIndex));
        const thumbStep = 90;
        thumbsTrack.style.transform = `translateX(-${thumbStartIndex * thumbStep}px)`;
        if (thumbPrevButton) thumbPrevButton.disabled = thumbStartIndex === 0;
        if (thumbNextButton) thumbNextButton.disabled = thumbStartIndex >= maxStartIndex;
      };

      const ensureActiveThumbVisible = (index) => {
        if (isMobile()) return;
        if (index < thumbStartIndex) {
          thumbStartIndex = index;
        } else if (index >= thumbStartIndex + visibleThumbCount) {
          thumbStartIndex = index - visibleThumbCount + 1;
        }
        syncThumbCarousel();
      };

      const setActiveSlide = (index, syncScroll = true) => {
        if (!slides.length) return;
        currentIndex = Math.max(0, Math.min(index, slides.length - 1));
        thumbs.forEach((thumb, thumbIndex) => {
          thumb.classList.toggle('is-active', thumbIndex === currentIndex);
        });
        ensureActiveThumbVisible(currentIndex);
        if (isMobile()) {
          if (syncScroll) {
            viewport.scrollTo({
              left: viewport.clientWidth * currentIndex,
              behavior: 'smooth',
            });
          }
          track.style.transform = 'translateX(0)';
        } else {
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
      };

      const findSlideIndexForVariant = (variant) => {
        if (!variant || !slides.length) return -1;

        const candidateIds = [variant.featured_image_id, variant.featured_media_id].filter(Boolean);
        for (const candidateId of candidateIds) {
          const slideIndex = slides.findIndex((slide) => String(slide.dataset.mediaId) === String(candidateId));
          if (slideIndex >= 0) return slideIndex;
        }

        if (variant.featured_image) {
          const slideIndex = slides.findIndex((slide) => {
            const image = slide.querySelector('img');
            return image && [image.currentSrc, image.src].includes(variant.featured_image);
          });
          if (slideIndex >= 0) return slideIndex;
        }

        return -1;
      };

      const selectedOptions = productHasVariants
        ? (variantData.find((variant) => variant.id === {{ selected_variant.id | json }}) || variantData[0]).options.slice()
        : [];

      const getComparableOptionIndexes = (buttonIndex = null) => {
        const indexes = visibleOptionIndexes.length
          ? visibleOptionIndexes
          : selectedOptions.map((_value, index) => index);
        return buttonIndex === null ? indexes : indexes.filter((index) => index !== buttonIndex);
      };

      const getMatchingVariants = () => {
        const indexes = getComparableOptionIndexes();
        return variantData.filter((variant) =>
          indexes.every((optionIndex) => variant.options[optionIndex] === selectedOptions[optionIndex])
        );
      };

      const findVariant = () => {
        const matches = getMatchingVariants();
        return matches.find((variant) => variant.available) || matches[0] || null;
      };

      const getPreviewVariantForColor = (buttonValue, optionIndex) => {
        const comparableIndexes = getComparableOptionIndexes(optionIndex);
        const exactMatches = variantData.filter((variant) => {
          if (variant.options[optionIndex] !== buttonValue) return false;
          return comparableIndexes.every((index) => variant.options[index] === selectedOptions[index]);
        });
        const exactWithImage = exactMatches.filter((variant) => variant.featured_image);
        const sameColorWithImage = variantData.filter(
          (variant) => variant.options[optionIndex] === buttonValue && variant.featured_image
        );

        return (
          exactWithImage.find((variant) => variant.available) ||
          exactWithImage[0] ||
          sameColorWithImage.find((variant) => variant.available) ||
          sameColorWithImage[0] ||
          null
        );
      };

      const getPreviewMediaVariantForColor = (buttonValue, optionIndex) => {
        const comparableIndexes = getComparableOptionIndexes(optionIndex);
        const exactWithMedia = variantData.filter((variant) => {
          if (variant.options[optionIndex] !== buttonValue) return false;
          if (!variant.featured_image_id && !variant.featured_media_id) return false;
          return comparableIndexes.every((index) => variant.options[index] === selectedOptions[index]);
        });
        const sameColorWithMedia = variantData.filter(
          (variant) => variant.options[optionIndex] === buttonValue && (variant.featured_image_id || variant.featured_media_id)
        );

        return (
          exactWithMedia.find((variant) => variant.available) ||
          exactWithMedia[0] ||
          sameColorWithMedia.find((variant) => variant.available) ||
          sameColorWithMedia[0] ||
          null
        );
      };

      const syncColorButtonPreviews = () => {
        colorButtons.forEach((button) => {
          const optionIndex = Number(button.dataset.optionIndex);
          const previewVariant = getPreviewVariantForColor(button.dataset.optionValue, optionIndex);
          button.dataset.previewImage = previewVariant?.featured_image || '';
          if (!button.dataset.previewLabel) {
            button.dataset.previewLabel = button.dataset.optionValue;
          }
        });
      };

      const hideColorPreview = () => {
        if (!colorPreview || !colorPreviewImage || !colorPreviewLabel) return;
        colorPreview.classList.remove('is-visible');
        colorPreview.setAttribute('aria-hidden', 'true');
      };

      const showColorPreview = (button, pointerEvent = null) => {
        if (isMobile() || !colorPreview || !colorPreviewImage || !colorPreviewLabel || !colorPreviewGroup) return;
        const previewImage = button.dataset.previewImage;
        if (!previewImage) {
          hideColorPreview();
          return;
        }

        colorPreviewImage.src = previewImage;
        colorPreviewImage.alt = `${button.dataset.previewLabel || button.dataset.optionValue} preview`;
        colorPreviewLabel.textContent = button.dataset.previewLabel || button.dataset.optionValue || '';

        const groupRect = colorPreviewGroup.getBoundingClientRect();
        const buttonRect = button.getBoundingClientRect();
        const previewWidth = colorPreview.offsetWidth || 190;
        const previewHeight = colorPreview.offsetHeight || 240;
        const anchorX = pointerEvent?.clientX ?? buttonRect.left + buttonRect.width / 2;
        const anchorY = pointerEvent?.clientY ?? buttonRect.top;
        const desiredLeft = anchorX - groupRect.left - previewWidth / 2;
        const desiredTop = anchorY - groupRect.top - previewHeight - 12;
        const maxLeft = Math.max(groupRect.width - previewWidth, 0);
        const clampedLeft = Math.min(Math.max(desiredLeft, 0), maxLeft);
        const minTop = -previewHeight + 24;
        const maxTop = Math.max(groupRect.height - 12, minTop);
        const clampedTop = Math.min(Math.max(desiredTop, minTop), maxTop);

        colorPreview.style.left = `${clampedLeft}px`;
        colorPreview.style.top = `${clampedTop}px`;
        colorPreview.classList.add('is-visible');
        colorPreview.setAttribute('aria-hidden', 'false');
      };

      const updateOptionAvailability = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const buttonValue = button.dataset.optionValue;
          const matches = variantData.some((variant) => {
            if (!variant.available) return false;
            if (variant.options[buttonIndex] !== buttonValue) {
              return false;
            }
            return getComparableOptionIndexes(buttonIndex).every(
              (optionIndex) => variant.options[optionIndex] === selectedOptions[optionIndex]
            );
          });
          button.disabled = !matches;
          button.classList.toggle('is-unavailable', !matches);
          button.setAttribute('aria-disabled', matches ? 'false' : 'true');
        });
      };

      const updateOptionUi = () => {
        optionButtons.forEach((button) => {
          const buttonIndex = Number(button.dataset.optionIndex);
          const active = selectedOptions[buttonIndex] === button.dataset.optionValue;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });

        section.querySelectorAll('[data-option-group]').forEach((group) => {
          const label = group.querySelector('[data-option-value-label]');
          const index = Number(group.dataset.optionIndex);
          if (label) {
            label.textContent = selectedOptions[index] || '';
          }
        });

        syncColorButtonPreviews();
      };

      const updateForVariant = (variant) => {
        if (!variant) return;
        selectedOptions.splice(0, selectedOptions.length, ...variant.options);
        variantInputs.forEach((input) => {
          input.value = variant.id;
        });

        if (priceEl) priceEl.textContent = variant.price_text;
        if (compareEl) {
          if (variant.compare_at_price > variant.price && variant.compare_at_price_text) {
            compareEl.textContent = variant.compare_at_price_text;
            compareEl.classList.remove('hidden');
          } else {
            compareEl.textContent = '';
            compareEl.classList.add('hidden');
          }
        }

        const isAvailable = Boolean(variant.available);
        if (atcButton) atcButton.disabled = !isAvailable;
        if (buyNowButton) buyNowButton.disabled = !isAvailable;
        if (atcLabel) atcLabel.textContent = isAvailable ? 'カートに追加' : '売り切れ';

        const variantIndex = findSlideIndexForVariant(variant);
        if (variantIndex >= 0) setActiveSlide(variantIndex, true);

        if (variant.url && window.history.replaceState) {
          window.history.replaceState({}, '', variant.url);
        }

        updateOptionUi();
        updateOptionAvailability();
      };

      optionButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const optionIndex = Number(button.dataset.optionIndex);
          const isColorButton = button.dataset.optionKind === 'color';

          if (isMobile() && isColorButton) {
            const mobilePreviewVariant = getPreviewMediaVariantForColor(button.dataset.optionValue, optionIndex);
            const previewSlideIndex = findSlideIndexForVariant(mobilePreviewVariant);
            if (previewSlideIndex >= 0) setActiveSlide(previewSlideIndex, true);
          }

          if (button.disabled) return;
          hideColorPreview();
          selectedOptions[optionIndex] = button.dataset.optionValue;
          const variant = findVariant();
          if (variant) updateForVariant(variant);
        });
      });

      colorButtons.forEach((button) => {
        button.addEventListener('mouseenter', (event) => showColorPreview(button, event));
        button.addEventListener('mousemove', (event) => showColorPreview(button, event));
        button.addEventListener('mouseleave', hideColorPreview);
        button.addEventListener('focus', () => showColorPreview(button));
        button.addEventListener('blur', hideColorPreview);
      });

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          setActiveSlide(Number(thumb.dataset.index), true);
        });
      });

      thumbPrevButton?.addEventListener('click', () => {
        thumbStartIndex = Math.max(thumbStartIndex - 1, 0);
        syncThumbCarousel();
      });

      thumbNextButton?.addEventListener('click', () => {
        thumbStartIndex = Math.min(thumbStartIndex + 1, Math.max(thumbs.length - visibleThumbCount, 0));
        syncThumbCarousel();
      });

      if (viewport && slides.length > 1) {
        let scrollTimer = null;
        viewport.addEventListener(
          'scroll',
          () => {
            if (!isMobile()) return;
            window.clearTimeout(scrollTimer);
            scrollTimer = window.setTimeout(() => {
              const nextIndex = Math.round(viewport.scrollLeft / Math.max(viewport.clientWidth, 1));
              setActiveSlide(nextIndex, false);
            }, 60);
          },
          { passive: true }
        );
      }

      section.querySelector('[data-qty-decrease]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) - 1);
      });

      section.querySelector('[data-qty-increase]')?.addEventListener('click', () => {
        setQuantity(Number(qtyInput.value) + 1);
      });

      qtyInput?.addEventListener('input', () => setQuantity(qtyInput.value));
      qtyInput?.addEventListener('blur', () => setQuantity(qtyInput.value));

      section.querySelectorAll('[data-faq-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const item = trigger.closest('.lp-faq__item');
          const panel = item?.querySelector('[data-faq-panel]');
          const isOpen = item.classList.contains('is-open');
          section.querySelectorAll('.lp-faq__item').forEach((faqItem) => {
            faqItem.classList.remove('is-open');
            const faqTrigger = faqItem.querySelector('[data-faq-trigger]');
            const faqPanel = faqItem.querySelector('[data-faq-panel]');
            if (faqTrigger) faqTrigger.setAttribute('aria-expanded', 'false');
            if (faqPanel) faqPanel.style.maxHeight = '0px';
          });
          if (!isOpen && item && panel) {
            item.classList.add('is-open');
            trigger.setAttribute('aria-expanded', 'true');
            panel.style.maxHeight = `${panel.scrollHeight}px`;
          }
        });
      });

      if (reviewWidget && reviewFallback) {
        const toggleReviewFallback = () => {
          const hasReviewMarkup =
            reviewWidget.querySelector('.jdgm-rev, .jdgm-all-reviews-page, .jdgm-histogram, .jdgm-row-stars') ||
            (reviewWidget.textContent || '').replace(/\s+/g, '').length > 0;
          reviewFallback.classList.toggle('hidden', Boolean(hasReviewMarkup));
        };

        toggleReviewFallback();
        new MutationObserver(toggleReviewFallback).observe(reviewWidget, {
          childList: true,
          subtree: true,
          characterData: true,
        });
      }

      window.addEventListener('resize', () => {
        hideColorPreview();
        setActiveSlide(currentIndex, false);
        syncThumbCarousel();
      });

      setQuantity(qtyInput?.value || 1);
      setActiveSlide(currentIndex, true);
      syncThumbCarousel();
      if (productHasVariants) {
        updateOptionUi();
        updateOptionAvailability();
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "LP Main Product",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "ストーリーバナー画像"
    },
    {
      "type": "inline_richtext",
      "id": "story_heading",
      "label": "ストーリーバナー見出し",
      "default": "いつでも、どこでも、一緒に。"
    },
    {
      "type": "textarea",
      "id": "story_text",
      "label": "ストーリーバナー本文",
      "default": "PAWLUXは、ペットとの毎日をもっと上質にするために生まれました。"
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "関連商品数",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
