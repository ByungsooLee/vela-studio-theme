{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-social-proof-v2">
  <div class="page-width">
    {%- assign trust_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign trust_heading = section.settings.heading | strip -%}
    {%- assign trust_lead = section.settings.lead | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- if trust_eyebrow == blank -%}
      {%- assign trust_eyebrow = 'Trust' -%}
    {%- endif -%}
    {%- if trust_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign trust_heading = '主張しすぎない、確かな安心。' -%}
      {%- else -%}
        {%- assign trust_heading = 'Support that stays unobtrusive.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if trust_lead == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign trust_lead = '必要な信頼情報だけを端的に。' -%}
      {%- else -%}
        {%- assign trust_lead = 'Reliable basics, presented with restraint.' -%}
      {%- endif -%}
    {%- endif -%}

    <header class="perfume-social-proof-v2__head">
      <p class="perfume-eyebrow">{{ trust_eyebrow | escape }}</p>
      <h2 class="perfume-heading perfume-social-proof-v2__heading">{{ trust_heading }}</h2>
      <p class="perfume-copy perfume-social-proof-v2__lead">{{ trust_lead }}</p>
    </header>

    <div class="perfume-social-proof-v2__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign trust_title = block.settings.feature | strip -%}
        {%- assign trust_body = block.settings.primary_value | strip -%}
        {%- if trust_title == blank -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign trust_title = '配送の見通しが明確' -%}
                {%- assign trust_body = '注文前に発送目安を分かりやすく提示。' -%}
              {%- else -%}
                {%- assign trust_title = 'Shipping clarity' -%}
                {%- assign trust_body = 'Transparent delivery timelines before checkout.' -%}
              {%- endif -%}
            {%- when 2 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign trust_title = '購入後サポート' -%}
                {%- assign trust_body = '困った時にすぐ確認できる導線を整備。' -%}
              {%- else -%}
                {%- assign trust_title = 'Satisfaction support' -%}
                {%- assign trust_body = 'Simple post-purchase support when needed.' -%}
              {%- endif -%}
            {%- when 3 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign trust_title = '実生活基準で選定' -%}
                {%- assign trust_body = '見た目だけでなく、日常での使いやすさを重視。' -%}
              {%- else -%}
                {%- assign trust_title = 'Real-use selection' -%}
                {%- assign trust_body = 'Products chosen from practical use cases.' -%}
              {%- endif -%}
            {%- when 4 -%}
              {%- if is_ja == 'ja' -%}
                {%- assign trust_title = '品質チェックを継続' -%}
                {%- assign trust_body = '仕上げ・サイズ感・耐久面を定期確認。' -%}
              {%- else -%}
                {%- assign trust_title = 'Consistent quality checks' -%}
                {%- assign trust_body = 'Reviewed for finish, fit, and durability.' -%}
              {%- endif -%}
          {%- endcase -%}
        {%- endif -%}
        <article class="perfume-social-proof-v2__item" role="listitem" {{ block.shopify_attributes }}>
          <h3 class="perfume-social-proof-v2__title">{{ trust_title }}</h3>
          <p class="perfume-copy">{{ trust_body }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Perfume Trust",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Trust"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Support that stays unobtrusive."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "リード",
      "default": "Reliable basics, presented with restraint."
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "比較行",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "タイトル",
          "default": "Shipping clarity"
        },
        {
          "type": "text",
          "id": "primary_value",
          "label": "本文",
          "default": "Transparent delivery timelines."
        },
        {
          "type": "text",
          "id": "secondary_value",
          "label": "未使用",
          "default": "N/A"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Trust",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Shipping clarity",
            "primary_value": "Transparent delivery timelines.",
            "secondary_value": "N/A"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Satisfaction support",
            "primary_value": "Simple post-purchase support.",
            "secondary_value": "N/A"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Quality checks",
            "primary_value": "Reviewed for finish and fit.",
            "secondary_value": "N/A"
          }
        }
      ]
    }
  ]
}
{% endschema %}
