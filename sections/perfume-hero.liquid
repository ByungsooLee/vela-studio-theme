{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-hero-v2">
  <div class="page-width">
    {%- assign hero_eyebrow = section.settings.eyebrow | strip -%}
    {%- assign hero_heading = section.settings.heading | strip -%}
    {%- assign hero_subheading = section.settings.subheading | strip -%}
    {%- assign hero_label = section.settings.primary_label | strip -%}
    {%- assign is_ja = request.locale.iso_code | slice: 0, 2 -%}
    {%- assign hero_collection = section.settings.hero_collection -%}
    {%- if hero_collection == blank -%}
      {%- assign hero_collection = collections['all'] -%}
    {%- endif -%}

    {%- if hero_eyebrow == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign hero_eyebrow = '一人暮らしの質を上げる日用品' -%}
      {%- else -%}
        {%- assign hero_eyebrow = 'Everyday upgrades for solo living' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if hero_heading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign hero_heading = '小さく選んで、部屋を整える。' -%}
      {%- else -%}
        {%- assign hero_heading = 'Choose small. Live better.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if hero_subheading == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign hero_subheading = '気になる商品をそのままタップして、すぐ詳細へ進めます。' -%}
      {%- else -%}
        {%- assign hero_subheading = 'Tap any block to jump straight into the product page.' -%}
      {%- endif -%}
    {%- endif -%}
    {%- if hero_label == blank -%}
      {%- if is_ja == 'ja' -%}
        {%- assign hero_label = '商品を見る' -%}
      {%- else -%}
        {%- assign hero_label = 'Shop the collection' -%}
      {%- endif -%}
    {%- endif -%}

    {%- if hero_collection != blank and hero_collection.products.size > 0 -%}
      <div class="perfume-hero-v2__media-wrap">
        <div class="perfume-hero-v2__mosaic" role="list">
          {%- for product in hero_collection.products limit: 4 -%}
            <article
              class="perfume-hero-v2__tile perfume-hero-v2__tile--{{ forloop.index }}"
              role="listitem"
            >
              <a class="perfume-hero-v2__tile-link" href="{{ product.url }}">
                <div class="perfume-hero-v2__tile-media">
                  {%- if product.featured_media != blank -%}
                    {{
                      product.featured_media
                      | image_url: width: 1600
                      | image_tag:
                        class: 'perfume-hero-v2__tile-image',
                        widths: '320, 480, 720, 960, 1280, 1600',
                        sizes: '(min-width: 990px) 28vw, (min-width: 750px) 42vw, 50vw',
                        loading: 'lazy',
                        alt: product.title
                    }}
                  {%- endif -%}
                </div>
                <div class="perfume-hero-v2__tile-copy">
                  <p class="perfume-hero-v2__tile-title">{{ product.title }}</p>
                  <p class="perfume-hero-v2__tile-meta">
                    {%- if is_ja == 'ja' -%}商品を見る{%- else -%}View product{%- endif -%}
                  </p>
                </div>
              </a>
            </article>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Perfume Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "hero_collection",
      "label": "表示するコレクション"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "メイン画像"
    },
    {
      "type": "image_picker",
      "id": "support_image_1",
      "label": "補助画像 1"
    },
    {
      "type": "image_picker",
      "id": "support_image_2",
      "label": "補助画像 2"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Everyday upgrades"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Small ideas. Better days."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "サブコピー",
      "default": "Curated essentials for solo living."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "CTAラベル",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "CTAリンク"
    }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "信頼ラベル",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "ラベル",
          "default": "Fast shipping"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Perfume Hero",
      "blocks": [
        {
          "type": "trust",
          "settings": {
            "text": "Fast shipping"
          }
        },
        {
          "type": "trust",
          "settings": {
            "text": "30-day support"
          }
        },
        {
          "type": "trust",
          "settings": {
            "text": "Compact-space ready"
          }
        }
      ]
    }
  ]
}
{% endschema %}
