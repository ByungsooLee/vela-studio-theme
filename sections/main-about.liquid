<div class="about-page">

  <!-- HERO -->
  <section class="about-hero">
    <div class="about-hero__inner">
      <p class="about-eyebrow">Our Story</p>
      <h1 class="about-title">We exist for the pets<br>who are family.</h1>
      <p class="about-subtitle">
        PAWLUX was born from one simple belief -
        your pet deserves the same quality of life you do.
      </p>
    </div>
  </section>

  <!-- MISSION -->
  <section class="about-mission page-width">
    <div class="about-mission__grid">
      <div class="about-mission__content">
        <p class="about-eyebrow">Our Mission</p>
        <h2>Premium gear.<br>Happy pets.</h2>
        <p>
          We handpick every product with one question in mind:
          <em>"Would we use this for our own pet?"</em>
          If the answer isn't an immediate yes, it doesn't make the cut.
        </p>
        <p>
          Every item in our collection is tested for safety,
          comfort, and durability - so you can shop with total confidence.
        </p>
      </div>
      <div class="about-mission__image">
        <img src="{{ 'about-mission.jpg' | asset_url }}"
             alt="Happy pet with owner"
             onerror="this.style.background='#F2F0EB';this.style.aspectRatio='4/3'">
      </div>
    </div>
  </section>

  <!-- TRUST PILLARS -->
  <section class="about-pillars">
    <div class="page-width">
      <p class="about-eyebrow" style="text-align:center">Why PAWLUX</p>
      <h2 style="text-align:center;margin-bottom:56px">
        The standard every pet owner deserves
      </h2>
      <div class="about-pillars__grid">
        <div class="about-pillar">
          <div class="about-pillar__icon">🔍</div>
          <h3>Carefully Curated</h3>
          <p>Every product is handpicked from trusted global suppliers. We test before we sell - no exceptions.</p>
        </div>
        <div class="about-pillar">
          <div class="about-pillar__icon">🛡️</div>
          <h3>Safe & Certified</h3>
          <p>All products meet international safety standards. Your pet's wellbeing is our top priority, always.</p>
        </div>
        <div class="about-pillar">
          <div class="about-pillar__icon">✈️</div>
          <h3>Free Worldwide Shipping</h3>
          <p>We ship to 50+ countries with full tracking. No hidden fees, no surprises at checkout.</p>
        </div>
        <div class="about-pillar">
          <div class="about-pillar__icon">🔄</div>
          <h3>30-Day Returns</h3>
          <p>Not happy? Return it within 30 days, no questions asked. We stand behind everything we sell.</p>
        </div>
        <div class="about-pillar">
          <div class="about-pillar__icon">⭐</div>
          <h3>2,000+ Happy Pets</h3>
          <p>Pet owners across the world trust PAWLUX for their daily adventures. Join our growing family.</p>
        </div>
        <div class="about-pillar">
          <div class="about-pillar__icon">💬</div>
          <h3>Real Support</h3>
          <p>Questions? Our team responds within 24 hours. We're here before, during, and after your purchase.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROMISE -->
  <section class="about-promise">
    <div class="about-promise__inner page-width">
      <p class="about-eyebrow">Our Promise</p>
      <blockquote class="about-promise__quote">
        "Every product we sell, we'd buy for our own pet."
      </blockquote>
      <p class="about-promise__sub">
        That's the PAWLUX standard. Nothing ships unless we believe in it completely.
      </p>
      <a href="/collections/all" class="about-cta">
        Shop the Collection →
      </a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "About page content",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
