<product-info
  id="MainProductPerfume-{{ section.id }}"
  class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }} perfume-pdp"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
  {{ 'section-main-product-perfume.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'main-product-perfume.js' | asset_url }}" defer="defer"></script>

  {%- assign display_name = product.metafields.custom.display_name.value | default: product.title -%}
  {%- assign subcopy = product.metafields.custom.subcopy.value -%}
  {%- assign fragrance_family = product.metafields.custom.fragrance_family.value -%}
  {%- assign scent_impressions = product.metafields.custom.scent_impressions.value -%}
  {%- assign recommended_scenes = product.metafields.custom.recommended_scenes.value -%}
  {%- assign recommended_seasons = product.metafields.custom.recommended_seasons.value -%}
  {%- assign top_notes = product.metafields.custom.top_notes.value -%}
  {%- assign middle_notes = product.metafields.custom.middle_notes.value -%}
  {%- assign last_notes = product.metafields.custom.last_notes.value -%}
  {%- assign benefit_points = product.metafields.custom.benefit_points.value -%}
  {%- assign linked_products_metafield = product.metafields.custom.linked_products.value -%}
  {%- assign return_period_metafield = product.metafields.custom.return_period.value -%}
  {%- assign return_period_text = return_period_metafield | default: section.settings.return_period_text -%}
  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' -%}
  {%- assign selected_variant = product.selected_or_first_available_variant -%}

  <div class="page-width">
    <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
      <div class="grid__item product__media-wrapper">
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <div class="product__info-wrapper grid__item">
        <section id="ProductInfo-{{ section.id }}" class="product__info-container perfume-pdp__info {% if section.settings.enable_sticky_info %}product__column-sticky{% endif %}">
          <p class="perfume-pdp__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          <h1 class="perfume-pdp__title">{{ display_name | escape }}</h1>

          {%- if subcopy != blank -%}
            <p class="perfume-pdp__subcopy">{{ subcopy | escape }}</p>
          {%- endif -%}

          <div class="perfume-pdp__price" id="PerfumePrice-{{ section.id }}">
            {% render 'price', product: product, use_variant: true, show_badges: false, price_class: 'price--large' %}
          </div>

          <div class="perfume-pdp__quick-summary">
            {%- if fragrance_family != blank -%}
              <div class="perfume-pdp__summary-row">
                <p class="perfume-pdp__summary-label">{{ section.settings.fragrance_family_label | escape }}</p>
                <p class="perfume-pdp__summary-text">{{ fragrance_family | escape }}</p>
              </div>
            {%- endif -%}

            {%- if scent_impressions != blank -%}
              <div class="perfume-pdp__summary-row">
                <p class="perfume-pdp__summary-label">{{ section.settings.impression_label | escape }}</p>
                <div class="perfume-pdp__tag-list">
                  {%- for impression in scent_impressions -%}
                    <span class="perfume-pdp__tag">{{ impression | escape }}</span>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            {%- if recommended_scenes != blank -%}
              <div class="perfume-pdp__summary-row">
                <p class="perfume-pdp__summary-label">{{ section.settings.scene_label | escape }}</p>
                <div class="perfume-pdp__tag-list">
                  {%- for scene in recommended_scenes -%}
                    <span class="perfume-pdp__tag">{{ scene | escape }}</span>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            {%- if recommended_seasons != blank -%}
              <div class="perfume-pdp__summary-row">
                <p class="perfume-pdp__summary-label">{{ section.settings.season_label | escape }}</p>
                <div class="perfume-pdp__tag-list">
                  {%- for season in recommended_seasons -%}
                    <span class="perfume-pdp__tag">{{ season | escape }}</span>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>

          <div class="perfume-pdp__purchase-card" id="PerfumePurchase-{{ section.id }}">
            {%- assign product_form_id = 'perfume-product-form-' | append: section.id -%}
            <div class="perfume-pdp__variant-wrap{% if product.has_only_default_variant %} perfume-pdp__variant-wrap--hidden{% endif %}">
              <p class="form__label perfume-pdp__variant-label">
                {{ section.settings.variant_label | escape }}
              </p>
              <div class="perfume-pdp__variant-toggle" role="radiogroup" aria-label="{{ section.settings.variant_label | escape }}">
                {%- for variant in product.variants -%}
                  <button
                    type="button"
                    class="perfume-pdp__variant-option{% if variant.id == selected_variant.id %} is-active{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                    data-variant-option
                    data-variant-id="{{ variant.id }}"
                    aria-pressed="{% if variant.id == selected_variant.id %}true{% else %}false{% endif %}"
                  >
                    {{ variant.title | escape }}
                  </button>
                {%- endfor -%}
              </div>
            </div>

            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                <span class="product-form__error-message"></span>
              </div>
              {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <input type="hidden" class="product-variant-id" name="id" value="{{ selected_variant.id }}">

                <label class="form__label perfume-pdp__quantity-label" for="PerfumeQuantity-{{ section.id }}">
                  {{ 'products.product.quantity.label' | t }}
                </label>
                <input id="PerfumeQuantity-{{ section.id }}" class="perfume-pdp__quantity-input field__input" type="number" name="quantity" min="1" value="1">

                <div class="product-form__buttons perfume-pdp__buttons">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    class="product-form__submit button button--full-width button--primary"
                    data-add-text="{{ section.settings.add_to_cart_label | escape }}"
                    data-soldout-text="{{ section.settings.sold_out_label | escape }}"
                    {% unless selected_variant.available %}disabled{% endunless %}
                  >
                    <span>{% if selected_variant.available %}{{ section.settings.add_to_cart_label | escape }}{% else %}{{ section.settings.sold_out_label | escape }}{% endif %}</span>
                    {%- render 'loading-spinner' -%}
                  </button>
                </div>
              {%- endform -%}
            </product-form>

            <p class="perfume-pdp__inventory" data-inventory-status data-in-stock="{{ section.settings.in_stock_message | escape }}" data-soldout="{{ section.settings.sold_out_message | escape }}">
              {% if selected_variant.available %}
                {{ section.settings.in_stock_message | escape }}
              {% else %}
                {{ section.settings.sold_out_message | escape }}
              {% endif %}
            </p>

            {%- if return_period_text != blank -%}
              <p class="perfume-pdp__policy-item">
                <span class="perfume-pdp__policy-label">{{ section.settings.return_period_label | escape }}</span>
                <span class="perfume-pdp__policy-text">{{ return_period_text | escape }}</span>
              </p>
            {%- endif -%}

            <div class="perfume-pdp__soldout-actions{% if selected_variant.available %} perfume-pdp__soldout-actions--hidden{% endif %}" data-soldout-actions>
              {%- if section.settings.restock_link != blank -%}
                <a class="perfume-pdp__secondary-link" href="{{ section.settings.restock_link }}">{{ section.settings.restock_label | escape }}</a>
              {%- endif -%}
              {%- if section.settings.alt_collection_link != blank -%}
                <a class="perfume-pdp__secondary-link" href="{{ section.settings.alt_collection_link }}">{{ section.settings.alt_collection_label | escape }}</a>
              {%- endif -%}
            </div>
          </div>

          {%- if benefit_points != blank or section.settings.benefit_fallback_1 != blank or section.settings.benefit_fallback_2 != blank or section.settings.benefit_fallback_3 != blank -%}
            <section class="perfume-pdp__benefits">
              <h2 class="h3 perfume-pdp__section-heading">{{ section.settings.benefits_heading | escape }}</h2>
              <ul class="perfume-pdp__benefit-list">
                {%- if benefit_points != blank -%}
                  {%- for point in benefit_points -%}
                    <li>{{ point | escape }}</li>
                  {%- endfor -%}
                {%- else -%}
                  {%- if section.settings.benefit_fallback_1 != blank -%}<li>{{ section.settings.benefit_fallback_1 | escape }}</li>{%- endif -%}
                  {%- if section.settings.benefit_fallback_2 != blank -%}<li>{{ section.settings.benefit_fallback_2 | escape }}</li>{%- endif -%}
                  {%- if section.settings.benefit_fallback_3 != blank -%}<li>{{ section.settings.benefit_fallback_3 | escape }}</li>{%- endif -%}
                {%- endif -%}
              </ul>
            </section>
          {%- endif -%}

          {%- if top_notes != blank or middle_notes != blank or last_notes != blank -%}
            <section class="perfume-pdp__notes">
              <h2 class="h3 perfume-pdp__section-heading">{{ section.settings.notes_heading | escape }}</h2>
              <div class="perfume-pdp__note-grid">
                {%- if top_notes != blank -%}
                  <article class="perfume-pdp__note-card">
                    <h3 class="h5">{{ section.settings.top_label | escape }}</h3>
                    <p>{{ top_notes | escape }}</p>
                  </article>
                {%- endif -%}
                {%- if middle_notes != blank -%}
                  <article class="perfume-pdp__note-card">
                    <h3 class="h5">{{ section.settings.middle_label | escape }}</h3>
                    <p>{{ middle_notes | escape }}</p>
                  </article>
                {%- endif -%}
                {%- if last_notes != blank -%}
                  <article class="perfume-pdp__note-card">
                    <h3 class="h5">{{ section.settings.last_label | escape }}</h3>
                    <p>{{ last_notes | escape }}</p>
                  </article>
                {%- endif -%}
              </div>
            </section>
          {%- endif -%}

          <section class="perfume-pdp__visual-story">
            <div class="perfume-pdp__story-copy">
              <h2 class="h3 perfume-pdp__section-heading">{{ section.settings.story_heading | escape }}</h2>
              <p class="perfume-pdp__story-text">{{ section.settings.story_body | escape }}</p>
            </div>
            <div class="perfume-pdp__story-media">
              {%- if section.settings.story_image_1 != blank -%}
                <div class="perfume-pdp__story-image-wrap">
                  {{
                    section.settings.story_image_1
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '360, 540, 720, 900, 1200',
                      sizes: '(min-width: 990px) 32vw, 92vw',
                      class: 'perfume-pdp__story-image',
                      alt: section.settings.story_heading
                  }}
                </div>
              {%- endif -%}
              {%- if section.settings.story_image_2 != blank -%}
                <div class="perfume-pdp__story-image-wrap">
                  {{
                    section.settings.story_image_2
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '360, 540, 720, 900, 1200',
                      sizes: '(min-width: 990px) 32vw, 92vw',
                      class: 'perfume-pdp__story-image',
                      alt: section.settings.story_heading
                  }}
                </div>
              {%- endif -%}
            </div>
          </section>

          <section class="perfume-pdp__scene-proposal">
            <h2 class="h3 perfume-pdp__section-heading">{{ section.settings.scene_proposal_heading | escape }}</h2>
            <p class="perfume-pdp__scene-intro">{{ section.settings.scene_proposal_intro | escape }}</p>
            <ul class="perfume-pdp__scene-list">
              {%- if recommended_scenes != blank -%}
                {%- for scene in recommended_scenes -%}
                  <li>{{ scene | escape }}</li>
                {%- endfor -%}
              {%- else -%}
                <li>{{ section.settings.scene_fallback_1 | escape }}</li>
                <li>{{ section.settings.scene_fallback_2 | escape }}</li>
                <li>{{ section.settings.scene_fallback_3 | escape }}</li>
              {%- endif -%}
            </ul>
          </section>

          {%- if linked_products_metafield != blank -%}
            <section class="perfume-pdp__related">
              <h2 class="h4 perfume-pdp__section-heading">{{ section.settings.related_heading | escape }}</h2>
              <div class="perfume-pdp__related-list" role="list">
                {%- for linked_product in linked_products_metafield -%}
                  {%- assign linked_label = linked_product.metafields.custom.fragrance_name.value | default: linked_product.metafields.custom.fragrance_name | default: linked_product.title -%}
                  <a class="perfume-pdp__related-chip{% if linked_product.id == product.id %} is-active{% endif %}" href="{{ linked_product.url }}" role="listitem">
                    {{ linked_label | escape }}
                  </a>
                {%- endfor -%}
              </div>
            </section>
          {%- endif -%}

          <section class="perfume-pdp__final-cta">
            <h2 class="h3 perfume-pdp__section-heading">{{ section.settings.final_cta_heading | escape }}</h2>
            <p class="perfume-pdp__final-copy">
              {% if selected_variant.available %}
                {{ section.settings.final_cta_copy_available | escape }}
              {% else %}
                {{ section.settings.final_cta_copy_soldout | escape }}
              {% endif %}
            </p>
            <button
              type="button"
              class="button button--primary button--full-width"
              data-scroll-to-purchase
              data-final-cta-button
              data-available-label="{{ section.settings.final_cta_button_available | escape }}"
              data-soldout-label="{{ section.settings.final_cta_button_soldout | escape }}"
            >
              {% if selected_variant.available %}
                {{ section.settings.final_cta_button_available | escape }}
              {% else %}
                {{ section.settings.final_cta_button_soldout | escape }}
              {% endif %}
            </button>
          </section>
        </section>
      </div>
    </div>
  </div>

  {% render 'product-media-modal', variant_images: variant_images %}
  <script type="application/json" data-perfume-variants>
    {{ product.variants | json }}
  </script>

  <div class="perfume-pdp__sticky-cta" data-sticky-cta>
    <div class="perfume-pdp__sticky-inner page-width">
      <div class="perfume-pdp__sticky-text">
        <p class="perfume-pdp__sticky-title">{{ display_name | escape }}</p>
        <p class="perfume-pdp__sticky-price" data-sticky-price>{{ selected_variant.price | money }}</p>
      </div>
      <button
        type="button"
        class="button button--primary"
        data-scroll-to-purchase
        data-sticky-cta-button
        data-available-label="{{ section.settings.sticky_button_available | escape }}"
        data-soldout-label="{{ section.settings.sticky_button_soldout | escape }}"
      >
        {% if selected_variant.available %}
          {{ section.settings.sticky_button_available | escape }}
        {% else %}
          {{ section.settings.sticky_button_soldout | escape }}
        {% endif %}
      </button>
    </div>
  </div>
</product-info>

{% schema %}
{
  "name": "Main product perfume",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Fragrance"
    },
    {
      "type": "text",
      "id": "fragrance_family_label",
      "label": "香調ラベル",
      "default": "香調"
    },
    {
      "type": "text",
      "id": "impression_label",
      "label": "印象ラベル",
      "default": "印象"
    },
    {
      "type": "text",
      "id": "scene_label",
      "label": "シーンラベル",
      "default": "おすすめシーン"
    },
    {
      "type": "text",
      "id": "season_label",
      "label": "季節ラベル",
      "default": "おすすめの季節"
    },
    {
      "type": "text",
      "id": "variant_label",
      "label": "バリアントラベル",
      "default": "サイズ"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "購入ボタン(在庫あり)",
      "default": "カートに入れる"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "購入ボタン(在庫なし)",
      "default": "現在在庫がありません"
    },
    {
      "type": "text",
      "id": "in_stock_message",
      "label": "在庫ありメッセージ",
      "default": "ご購入いただけます"
    },
    {
      "type": "text",
      "id": "sold_out_message",
      "label": "在庫なしメッセージ",
      "default": "再入荷のお知らせをご利用ください"
    },
    {
      "type": "text",
      "id": "return_period_label",
      "label": "返品期間ラベル",
      "default": "返品期間"
    },
    {
      "type": "text",
      "id": "return_period_text",
      "label": "返品期間テキスト",
      "default": "商品到着後7日以内にご連絡ください。"
    },
    {
      "type": "url",
      "id": "restock_link",
      "label": "再入荷通知リンク"
    },
    {
      "type": "text",
      "id": "restock_label",
      "label": "再入荷通知ラベル",
      "default": "再入荷通知を受け取る"
    },
    {
      "type": "url",
      "id": "alt_collection_link",
      "label": "類似香りリンク"
    },
    {
      "type": "text",
      "id": "alt_collection_label",
      "label": "類似香りラベル",
      "default": "似た香りを見る"
    },
    {
      "type": "text",
      "id": "benefits_heading",
      "label": "ベネフィット見出し",
      "default": "この香りがもたらす印象"
    },
    {
      "type": "text",
      "id": "benefit_fallback_1",
      "label": "ベネフィット予備1",
      "default": "甘すぎず、やわらかく印象に残る。"
    },
    {
      "type": "text",
      "id": "benefit_fallback_2",
      "label": "ベネフィット予備2",
      "default": "近づいたときに、ふわっと感じる上品さ。"
    },
    {
      "type": "text",
      "id": "benefit_fallback_3",
      "label": "ベネフィット予備3",
      "default": "日常にも特別な日にもなじむ使いやすさ。"
    },
    {
      "type": "text",
      "id": "notes_heading",
      "label": "ノート見出し",
      "default": "香りのノート"
    },
    {
      "type": "text",
      "id": "top_label",
      "label": "トップラベル",
      "default": "Top"
    },
    {
      "type": "text",
      "id": "middle_label",
      "label": "ミドルラベル",
      "default": "Middle"
    },
    {
      "type": "text",
      "id": "last_label",
      "label": "ラストラベル",
      "default": "Last"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "関連見出し",
      "default": "香りを選ぶ"
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "世界観見出し",
      "default": "香りの余韻を、静かに纏う"
    },
    {
      "type": "textarea",
      "id": "story_body",
      "label": "世界観テキスト",
      "default": "ガラス越しの光、肌に残るやわらかな余韻。主張しすぎず、近づいた瞬間に印象を残す香りです。"
    },
    {
      "type": "image_picker",
      "id": "story_image_1",
      "label": "世界観画像1"
    },
    {
      "type": "image_picker",
      "id": "story_image_2",
      "label": "世界観画像2"
    },
    {
      "type": "text",
      "id": "scene_proposal_heading",
      "label": "シーン提案見出し",
      "default": "こんな日や場面におすすめ"
    },
    {
      "type": "text",
      "id": "scene_proposal_intro",
      "label": "シーン提案導入",
      "default": "香り選びに迷ったときは、過ごしたい空気感で選んでください。"
    },
    {
      "type": "text",
      "id": "scene_fallback_1",
      "label": "シーン予備1",
      "default": "休日の外出に"
    },
    {
      "type": "text",
      "id": "scene_fallback_2",
      "label": "シーン予備2",
      "default": "気分をやさしく整えたい日に"
    },
    {
      "type": "text",
      "id": "scene_fallback_3",
      "label": "シーン予備3",
      "default": "近づいたときの印象を大切にしたい場面に"
    },
    {
      "type": "text",
      "id": "final_cta_heading",
      "label": "最終CTA見出し",
      "default": "迷ったら、香りの印象で選んでください"
    },
    {
      "type": "text",
      "id": "final_cta_copy_available",
      "label": "最終CTAコピー(在庫あり)",
      "default": "日常にも、少し特別な日にも似合う香りです。"
    },
    {
      "type": "text",
      "id": "final_cta_copy_soldout",
      "label": "最終CTAコピー(在庫なし)",
      "default": "人気のため現在欠品中です。再入荷通知をご利用ください。"
    },
