  "name": "PAWLY Trust Bar",
  "max_blocks": 10,
  "blocks": [
    {
      "type": "item",
      "name": "アイテム",
      "settings": [
        {
          "id": "text",
          "type": "text",
          "label": "テキスト"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PAWLY Trust Bar",
      "blocks": [
        {
          "type": "item",
