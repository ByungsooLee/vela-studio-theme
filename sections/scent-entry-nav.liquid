{{ 'section-perfume-home.css' | asset_url | stylesheet_tag }}

<section class="perfume-shell perfume-section perfume-section--surface scent-entry">
  <div class="page-width">
    <header class="scent-entry__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="perfume-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="perfume-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.lead != blank -%}
        <p class="perfume-copy">{{ section.settings.lead }}</p>
      {%- endif -%}
    </header>

    <div class="scent-entry__rail" role="list">
      {%- for block in section.blocks -%}
        <a class="scent-entry__card" href="{{ block.settings.link | default: '#' }}" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.kicker != blank -%}
            <span class="scent-entry__kicker">{{ block.settings.kicker | escape }}</span>
          {%- endif -%}
          <h3 class="scent-entry__title">{{ block.settings.title }}</h3>
          {%- if block.settings.desc != blank -%}
            <p class="scent-entry__desc">{{ block.settings.desc }}</p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scent Entry Navigation",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "アイブロウ",
      "default": "Scent Navigation"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "選ぶ時間まで、美しく。"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "説明",
      "default": "香りの系統、気分、シーン、ギフト。あなたの入り口から探せます。"
    }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "ナビカード",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "小見出し",
          "default": "By Notes"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "香りの系統で選ぶ"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "説明",
          "default": "Floral / Citrus / Woody / Musk から選択。"
        },
        {
          "type": "url",
          "id": "link",
          "label": "リンク"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scent Entry Navigation",
      "blocks": [
        {
          "type": "entry",
          "settings": {
            "kicker": "By Notes",
            "title": "香りの系統で選ぶ",
            "desc": "Floral / Citrus / Woody / Musk から選択。"
          }
        },
        {
          "type": "entry",
          "settings": {
            "kicker": "By Mood",
            "title": "気分で選ぶ",
            "desc": "落ち着きたい、印象を残したい、清潔感を纏いたい。"
          }
        },
        {
          "type": "entry",
          "settings": {
            "kicker": "By Scene",
            "title": "シーンで選ぶ",
            "desc": "仕事、休日、夜のお出かけ、贈り物の場面から。"
          }
        },
        {
          "type": "entry",
          "settings": {
            "kicker": "For Newcomers",
            "title": "初めての方へ",
            "desc": "失敗しにくいスターターセットや人気順から。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
