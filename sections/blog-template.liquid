{{ 'blog-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'blog-page.js' | asset_url }}" defer="defer"></script>

{%- paginate blog.articles by section.settings.articles_per_page -%}
  <div class="blog-page" data-blog-page>
    <section class="blog-hero">
      <div class="page-width blog-hero__inner">
        <p class="blog-hero__label">{{ blog.title }}</p>
        <h1 class="blog-hero__title">Stories, guides &amp; everyday ideas.</h1>
        <p class="blog-hero__sub">Thoughtfully written for a slower, better life.</p>
      </div>
    </section>

    <div class="blog-filters-wrap">
      <div class="page-width">
        <nav class="blog-filters" aria-label="Filter by topic">
          <a href="{{ blog.url }}" class="blog-filter-tab{% unless current_tags %} blog-filter-tab--active{% endunless %}">
            All
          </a>
          {%- for tag in blog.all_tags -%}
            <a
              href="{{ blog.url }}/tagged/{{ tag | handle }}"
              class="blog-filter-tab{% if current_tags contains tag %} blog-filter-tab--active{% endif %}"
            >
              {{ tag }}
            </a>
          {%- endfor -%}
        </nav>
      </div>
    </div>

    <div class="page-width blog-main">
      {%- if paginate.current_page == 1 and blog.articles_count > 0 -%}
        {%- assign featured = blog.articles.first -%}
        <article class="blog-featured">
          <a href="{{ featured.url }}" class="blog-featured__media-link">
            {%- if featured.image -%}
              <div class="blog-featured__img-wrap">
                <img
                  src="{{ featured.image | image_url: width: 1400 }}"
                  alt="{{ featured.image.alt | default: featured.title | escape }}"
                  width="1400"
                  height="700"
                  loading="eager"
                >
              </div>
            {%- endif -%}
          </a>
          <div class="blog-featured__info">
            <div class="blog-featured__meta">
              {%- if featured.tags.size > 0 -%}
                <span class="article-tag">{{ featured.tags.first }}</span>
              {%- endif -%}
              <span class="article-date">{{ featured.published_at | date: '%B %d, %Y' }}</span>
              <span
                class="article-read-time"
                data-word-count="{{ featured.content | strip_html | split: ' ' | size }}"
              >
                {{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read
              </span>
            </div>
            <h2 class="blog-featured__title">
              <a href="{{ featured.url }}">{{ featured.title }}</a>
            </h2>
            {%- if featured.excerpt != blank -%}
              <p class="blog-featured__excerpt">{{ featured.excerpt | strip_html | truncate: 160 }}</p>
            {%- endif -%}
            <a href="{{ featured.url }}" class="blog-featured__cta">Read the story →</a>
          </div>
        </article>
      {%- endif -%}

      {%- assign articles_to_show = blog.articles -%}
      {%- if paginate.current_page == 1 -%}
        {%- assign articles_to_show = blog.articles | slice: 1, 100 -%}
      {%- endif -%}

      <div class="blog-grid" data-blog-grid>
        {%- for article in articles_to_show -%}
          {%- assign position = forloop.index0 | modulo: 6 -%}
          {%- assign is_large = false -%}
          {%- if position == 0 or position == 5 -%}
            {%- assign is_large = true -%}
          {%- endif -%}

          {%- render 'blog-card', article: article, is_large: is_large, index: forloop.index0 -%}
        {%- endfor -%}
      </div>

      {%- if paginate.next -%}
        {%- assign remaining_count = paginate.items | minus: paginate.current_offset | minus: blog.articles.size -%}
        {%- if remaining_count < 0 -%}
          {%- assign remaining_count = 0 -%}
        {%- endif -%}
        <div class="blog-load-more" data-blog-load-more-wrap>
          <a href="{{ paginate.next.url }}" class="btn-load-more js-blog-load-more" data-next-url="{{ paginate.next.url }}">
            Load more articles
            <span class="load-more__count">({{ remaining_count }} more)</span>
          </a>
        </div>
      {%- endif -%}
    </div>

    <section class="blog-newsletter">
      <div class="page-width">
        <div class="blog-newsletter__inner">
          <p class="blog-newsletter__label">Stay in the loop</p>
          <h2 class="blog-newsletter__title">Ideas for a better everyday life,<br>in your inbox.</h2>
          <p class="blog-newsletter__sub">No spam. Just thoughtful picks and quiet upgrades.</p>

          {%- form 'customer', id: 'blog-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="blog-newsletter__form">
              <input
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="your@email.com"
                required
                class="blog-newsletter__input"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                aria-label="Email address"
              >
              <button type="submit" class="blog-newsletter__btn">Subscribe</button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="blog-newsletter__success">You're in. Welcome.</p>
            {%- endif -%}

            {%- if form.errors -%}
              <p class="blog-newsletter__success">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
            {%- endif -%}
          {%- endform -%}

          <p class="blog-newsletter__disclaimer">Unsubscribe anytime. We mean it.</p>
        </div>
      </div>
    </section>
  </div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Blog template",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 7,
      "label": "Articles per page"
    }
  ]
}
{% endschema %}
