<section class="video-feature {% if section.settings.reverse %}video-feature--reverse{% endif %}">
  <div class="video-feature__media">
    {%- if section.settings.video != blank -%}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          class: 'video-feature__video'
      }}
    {%- elsif section.settings.fallback_image != blank -%}
      <img
        src="{{ section.settings.fallback_image | image_url: width: 1200 }}"
        alt="{{ section.settings.fallback_image.alt | default: 'Fallback image' }}"
        class="video-feature__fallback"
        loading="lazy"
        width="{{ section.settings.fallback_image.width }}"
        height="{{ section.settings.fallback_image.height }}"
      >
    {%- endif -%}
  </div>

  <div class="video-feature__content" style="background-color: {{ section.settings.bg_color }};">
    {%- if section.settings.eyebrow != blank -%}
      <p class="video-feature__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="video-feature__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="video-feature__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="video-feature__cta">
        {{ section.settings.cta_text }} →
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Video Feature",
  "tag": "section",
  "class": "video-feature-section",
  "settings": [
    {
      "type": "header",
      "content": "🎬 メディア設定"
    },
    {
      "type": "video",
      "id": "video",
      "label": "動画（Shopifyにアップロード）",
      "info": "管理画面 → Content → Files にMP4をアップロード後に選択。動画が優先表示されます。"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "画像（動画がない場合 / 動画読み込み前の表示）",
      "info": "動画をアップしない場合はこちらの画像が表示されます"
    },
    {
      "type": "header",
      "content": "📝 テキスト設定"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "小見出し（上部ラベル）",
      "default": "Bestseller",
      "info": "例: Bestseller / New Arrival / Most Loved"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "メイン見出し",
      "default": "The backpack they'll love."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "説明文",
      "default": "360° bubble window. Ventilated mesh. Ergonomic design. Your cat sees everything — in total comfort."
    },
    {
      "type": "header",
      "content": "🔗 ボタン設定"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "ボタンテキスト",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "ボタンリンク先"
    },
    {
      "type": "header",
      "content": "⚙️ レイアウト設定"
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "左右を反転する（画像を右側に表示）",
      "default": false,
      "info": "複数このセクションを使う場合、交互にオンにするとKockums風になります"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "テキスト側の背景色",
      "default": "#F2F0EB"
    }
  ],
  "presets": [
    {
      "name": "Video Feature",
      "category": "Custom"
    }
  ]
}
{% endschema %}
